{
  "mcpServers": {
    "nx-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["nx", "mcp"]
    },
    "angular-cli": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp"]
    },
    "storybook-angular": {
      "type": "http",
      "url": "http://localhost:4400/mcp"
    },
    "storybook-react": {
      "type": "http",
      "url": "http://localhost:4401/mcp"
    },
    "figma-console": {
      "command": "npx",
      "args": ["-y", "figma-console-mcp@latest"],
      "env": {
        "FIGMA_ACCESS_TOKEN": "FIGMA_TOKEN_REMOVED",
        "ENABLE_MCP_APPS": "true"
      }
    }
  }
}
