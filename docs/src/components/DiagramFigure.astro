---
interface Props {
  caption?: string;
  align?: 'start' | 'center';
  compact?: boolean;
  /**
   * `mockup` flags the figure as a placeholder UI rendering awaiting a real
   * screenshot. Visually adds a small "MOCKUP" eyebrow in the top-right
   * corner so contributors can spot replacement targets at a glance.
   */
  kind?: 'diagram' | 'mockup';
}

const { caption, align = 'center', compact = false, kind = 'diagram' } = Astro.props;
---

<figure class:list={["diagram-figure", `diagram-figure--${align}`, compact && "diagram-figure--compact", kind === 'mockup' && "diagram-figure--mockup"]}>
  <div class="diagram-figure-surface">
    {kind === 'mockup' && <span class="diagram-figure-mockup-tag" aria-hidden="true">Mockup</span>}
    <slot />
  </div>
  {caption && <figcaption class="diagram-figure-caption">{caption}</figcaption>}
</figure>

<style>
  .diagram-figure {
    margin: 1.5rem 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .diagram-figure--start { align-items: flex-start; }
  .diagram-figure--center { align-items: stretch; }

  .diagram-figure-surface {
    width: 100%;
    padding: 1.5rem 1.25rem;
    background:
      radial-gradient(
        ellipse at top,
        color-mix(in srgb, var(--ui-color-primary) 6%, transparent),
        transparent 60%
      ),
      var(--ui-color-surface-raised);
    border: 1px solid var(--ui-color-border);
    border-radius: var(--ui-radius-lg);
    overflow: hidden;
    position: relative;
  }

  .diagram-figure--compact .diagram-figure-surface {
    padding: 1rem;
  }

  .diagram-figure-surface :global(svg) {
    width: 100%;
    height: auto;
    display: block;
    max-width: 100%;
  }

  /* Mockup eyebrow — small italic flag in the top-right corner. */
  .diagram-figure-mockup-tag {
    position: absolute;
    top: 0.55rem;
    right: 0.7rem;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ui-color-text-muted);
    background: var(--ui-color-surface-sunken);
    border: 1px solid var(--ui-color-border);
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
    font-style: italic;
    pointer-events: none;
  }

  /* Mobile rescue: SVG labels declared at small font-size attributes shrink
   * proportionally with the diagram width and become unreadable on phones.
   * Below 640px we let the surface scroll horizontally and force a minimum
   * SVG width that keeps the labels at human-readable sizes. The mask fades
   * the right edge to hint at scrollable content. */
  @media (max-width: 640px) {
    .diagram-figure-surface {
      overflow-x: auto;
      -webkit-mask-image: linear-gradient(to right, black calc(100% - 28px), transparent 100%);
      mask-image: linear-gradient(to right, black calc(100% - 28px), transparent 100%);
    }
    .diagram-figure-surface :global(svg) {
      min-width: 600px;
      max-width: none;
    }
  }

  .diagram-figure-caption {
    font-size: 0.78rem;
    color: var(--ui-color-text-muted);
    line-height: 1.45;
    padding: 0 0.25rem;
    text-align: center;
  }

  .diagram-figure--start .diagram-figure-caption {
    text-align: left;
  }

  /* Shared SVG typographic defaults so all diagrams look consistent */
  .diagram-figure-surface :global(svg text) {
    font-family: var(--font-sans), ui-sans-serif, system-ui, sans-serif;
    fill: var(--ui-color-text);
  }

  .diagram-figure-surface :global(svg text.diagram-mono) {
    font-family: var(--font-mono), ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  .diagram-figure-surface :global(svg text.diagram-muted) {
    fill: var(--ui-color-text-muted);
  }

  .diagram-figure-surface :global(svg text.diagram-eyebrow) {
    fill: var(--ui-color-text-muted);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .diagram-figure-surface :global(svg .diagram-node) {
    fill: var(--ui-color-surface);
    stroke: var(--ui-color-border);
    stroke-width: 1.25;
  }

  .diagram-figure-surface :global(svg .diagram-node--accent) {
    fill: color-mix(in srgb, var(--ui-color-primary) 10%, var(--ui-color-surface));
    stroke: var(--ui-color-primary);
    stroke-width: 1.5;
  }

  .diagram-figure-surface :global(svg .diagram-connector) {
    fill: none;
    stroke: var(--ui-color-border-hover);
    stroke-width: 1.5;
    stroke-linecap: round;
  }

  .diagram-figure-surface :global(svg .diagram-connector--accent) {
    stroke: var(--ui-color-primary);
    stroke-width: 2;
  }

  /* Dashed connector is used for feedback loops — needs to read as
     "alternative path" at a glance, not fade into the background. */
  .diagram-figure-surface :global(svg .diagram-connector--dashed) {
    stroke: color-mix(in srgb, var(--ui-color-primary) 55%, var(--ui-color-border-hover));
    stroke-dasharray: 5 5;
    stroke-width: 1.75;
  }

  .diagram-figure-surface :global(svg .diagram-arrow) {
    fill: var(--ui-color-border-hover);
  }

  .diagram-figure-surface :global(svg .diagram-arrow--accent) {
    fill: var(--ui-color-primary);
  }

  .diagram-figure-surface :global(svg .diagram-arrow--muted-accent) {
    fill: color-mix(in srgb, var(--ui-color-primary) 55%, var(--ui-color-border-hover));
  }

  .diagram-figure-surface :global(svg .diagram-icon) {
    fill: none;
    stroke: var(--ui-color-primary);
    stroke-width: 1.75;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
</style>
