---
import accessibility_new from '@material-symbols/svg-400/outlined/accessibility_new.svg?raw';
import arrow_back from '@material-symbols/svg-400/outlined/arrow_back.svg?raw';
import article from '@material-symbols/svg-400/outlined/article.svg?raw';
import book from '@material-symbols/svg-400/outlined/book.svg?raw';
import build_circle from '@material-symbols/svg-400/outlined/build_circle.svg?raw';
import cable from '@material-symbols/svg-400/outlined/cable.svg?raw';
import chat from '@material-symbols/svg-400/outlined/chat.svg?raw';
import check_circle from '@material-symbols/svg-400/outlined/check_circle.svg?raw';
import dashboard from '@material-symbols/svg-400/outlined/dashboard.svg?raw';
import description from '@material-symbols/svg-400/outlined/description.svg?raw';
import download from '@material-symbols/svg-400/outlined/download.svg?raw';
import grid_view from '@material-symbols/svg-400/outlined/grid_view.svg?raw';
import help from '@material-symbols/svg-400/outlined/help.svg?raw';
import lightbulb from '@material-symbols/svg-400/outlined/lightbulb.svg?raw';
import menu_book from '@material-symbols/svg-400/outlined/menu_book.svg?raw';
import palette from '@material-symbols/svg-400/outlined/palette.svg?raw';
import robot_2 from '@material-symbols/svg-400/outlined/robot_2.svg?raw';
import schedule from '@material-symbols/svg-400/outlined/schedule.svg?raw';
import schema from '@material-symbols/svg-400/outlined/schema.svg?raw';
import school from '@material-symbols/svg-400/outlined/school.svg?raw';
import search from '@material-symbols/svg-400/outlined/search.svg?raw';
import smart_toy from '@material-symbols/svg-400/outlined/smart_toy.svg?raw';
import widgets from '@material-symbols/svg-400/outlined/widgets.svg?raw';

const MATERIAL_ICONS = {
  accessibility_new,
  arrow_back,
  article,
  book,
  build_circle,
  cable,
  chat,
  check_circle,
  dashboard,
  description,
  download,
  grid_view,
  help,
  lightbulb,
  menu_book,
  palette,
  robot_2,
  schedule,
  schema,
  school,
  search,
  smart_toy,
  widgets,
} as const;

// Lucide-style line glyphs hand-ported from skills/atelier-design/ui_kits/docs-site/landing.jsx.
// 1.75 stroke, 24px viewBox, currentColor — matches the brand-guide iconography rules.
const LUCIDE_ICONS = {
  figma:
    '<path d="M5 5.5A3.5 3.5 0 0 1 8.5 2H12v7H8.5A3.5 3.5 0 0 1 5 5.5z"/>' +
    '<path d="M12 2h3.5a3.5 3.5 0 0 1 0 7H12V2z"/>' +
    '<path d="M5 12.5A3.5 3.5 0 0 1 8.5 9H12v7H8.5A3.5 3.5 0 0 1 5 12.5z"/>' +
    '<path d="M12 9h3.5a3.5 3.5 0 0 1 0 7H12V9z"/>' +
    '<path d="M5 19.5A3.5 3.5 0 0 1 8.5 16H12v3.5a3.5 3.5 0 1 1-7 0z"/>',
  sparkles:
    '<path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/>',
  terminal:
    '<polyline points="4 17 10 11 4 5"/>' +
    '<line x1="12" y1="19" x2="20" y2="19"/>',
  arrow_right:
    '<line x1="5" y1="12" x2="19" y2="12"/>' +
    '<polyline points="12 5 19 12 12 19"/>',
  arrow_left:
    '<line x1="19" y1="12" x2="5" y2="12"/>' +
    '<polyline points="12 19 5 12 12 5"/>',
  moon:
    '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>',
  sun:
    '<circle cx="12" cy="12" r="5"/>' +
    '<line x1="12" y1="1" x2="12" y2="3"/>' +
    '<line x1="12" y1="21" x2="12" y2="23"/>' +
    '<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>' +
    '<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>' +
    '<line x1="1" y1="12" x2="3" y2="12"/>' +
    '<line x1="21" y1="12" x2="23" y2="12"/>' +
    '<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>' +
    '<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>',
  github:
    '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>',
  info:
    '<circle cx="12" cy="12" r="10"/>' +
    '<line x1="12" y1="16" x2="12" y2="12"/>' +
    '<line x1="12" y1="8" x2="12.01" y2="8"/>',
  warning:
    '<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>' +
    '<line x1="12" y1="9" x2="12" y2="13"/>' +
    '<line x1="12" y1="17" x2="12.01" y2="17"/>',
  danger:
    '<circle cx="12" cy="12" r="10"/>' +
    '<line x1="12" y1="8" x2="12" y2="12"/>' +
    '<line x1="12" y1="16" x2="12.01" y2="16"/>',
  copy:
    '<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>' +
    '<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>',
  close:
    '<line x1="18" y1="6" x2="6" y2="18"/>' +
    '<line x1="6" y1="6" x2="18" y2="18"/>',
} as const;

export type IconName = keyof typeof MATERIAL_ICONS | keyof typeof LUCIDE_ICONS;

interface Props {
  /**
   * Icon name. Accepts the typed `IconName` union for autocomplete, but also
   * tolerates plain strings so consumers driven by data (BottomNav,
   * SECTION_ICONS) don't need a cast at every call site.
   */
  name: IconName | (string & {});
  class?: string;
}

const { name, class: className } = Astro.props;

const isLucide = (name as string) in LUCIDE_ICONS;

// Material Symbols ship as 24x24 SVGs with their own viewBox; strip the outer
// <svg> tag and rebuild with our own attributes so `currentColor` + sizing
// inherit from CSS.
let viewBox = '0 0 24 24';
let inner: string;

if (isLucide) {
  inner = LUCIDE_ICONS[name as keyof typeof LUCIDE_ICONS];
} else {
  const raw = MATERIAL_ICONS[name as keyof typeof MATERIAL_ICONS];
  const viewBoxMatch = raw.match(/viewBox="([^"]+)"/);
  if (viewBoxMatch) viewBox = viewBoxMatch[1];
  inner = raw.replace(/^[\s\S]*?<svg[^>]*>/, '').replace(/<\/svg>\s*$/, '');
}
---

{isLucide ? (
  <svg
    class={className}
    viewBox={viewBox}
    width="1em"
    height="1em"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    focusable="false"
    set:html={inner}
  />
) : (
  <svg
    class={className}
    viewBox={viewBox}
    width="1em"
    height="1em"
    xmlns="http://www.w3.org/2000/svg"
    fill="currentColor"
    aria-hidden="true"
    focusable="false"
    set:html={inner}
  />
)}
