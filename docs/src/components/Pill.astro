---
interface Props {
  /** Visible label. */
  label: string;
  /** Stable identifier within the group; emitted as `data-pill-value`. */
  value: string;
  /** Pre-pressed state on initial render (uncontrolled). */
  active?: boolean;
}

const { label, value, active = false } = Astro.props;
---

<button
  type="button"
  class:list={['docs-pill', { 'is-active': active }]}
  data-pill-value={value}
  aria-pressed={active}>
  {label}
</button>

<style>
  .docs-pill {
    padding: 0.375rem 0.875rem;
    border-radius: var(--ui-radius-full);
    border: 1px solid var(--ui-color-border);
    background: transparent;
    color: var(--ui-color-text-muted);
    font-size: 0.8125rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: color var(--ui-duration-fast) var(--ui-ease-out),
      border-color var(--ui-duration-fast) var(--ui-ease-out),
      background var(--ui-duration-fast) var(--ui-ease-out);
  }

  .docs-pill:hover {
    color: var(--ui-color-primary);
    border-color: var(--ui-color-primary);
  }

  .docs-pill.is-active,
  .docs-pill[aria-pressed="true"] {
    background: var(--ui-color-primary-light);
    border-color: var(--ui-color-primary);
    color: var(--ui-color-primary);
  }

  .docs-pill:focus-visible {
    outline: none;
    box-shadow: var(--ui-focus-ring);
  }
</style>
