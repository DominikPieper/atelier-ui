---
interface Props {
  eyebrow?: string;
  title: string;
  /**
   * Optional keyword within `title` to render as the serif-italic signature
   * accent. Must be an exact substring of `title`; the first match is wrapped.
   * Keep it to one keyword. Omit for a plain heading.
   */
  titleAccent?: string;
  sub?: string;
  align?: 'left' | 'center';
  /**
   * Heading level for the title. Use h2 for top-level page sections (default),
   * h3 inside an h2-led section, etc.
   */
  level?: 1 | 2 | 3 | 4;
  id?: string;
}

const {
  eyebrow,
  title,
  titleAccent,
  sub,
  align = 'left',
  level = 2,
  id,
} = Astro.props;

const Tag = `h${level}` as 'h1' | 'h2' | 'h3' | 'h4';
const accentAt = titleAccent ? title.indexOf(titleAccent) : -1;
---

<header class:list={['docs-section-head', `docs-section-head--${align}`]}>
  {eyebrow && <span class="docs-section-eyebrow">{eyebrow}</span>}
  <Tag class="docs-section-title" id={id}>
    {accentAt === -1 ? title : (
      <Fragment>{title.slice(0, accentAt)}<em class="docs-accent">{titleAccent}</em>{title.slice(accentAt + titleAccent!.length)}</Fragment>
    )}
  </Tag>
  {sub && <p class="docs-section-sub">{sub}</p>}
</header>

<style>
  .docs-section-head {
    margin-bottom: 2.5rem;
  }

  .docs-section-head--center {
    text-align: center;
  }

  .docs-section-head--center .docs-section-sub {
    margin-left: auto;
    margin-right: auto;
  }

  .docs-section-eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ui-color-primary);
    margin-bottom: 0.75rem;
  }

  .docs-section-title {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin: 0 0 0.75rem;
    color: var(--ui-color-text);
  }

  .docs-section-sub {
    font-size: 1.0625rem;
    color: var(--ui-color-text-muted);
    line-height: 1.6;
    max-width: 38rem;
    margin: 0;
  }
</style>
