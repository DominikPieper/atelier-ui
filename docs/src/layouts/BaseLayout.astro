---
import { ClientRouter } from 'astro:transitions';
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import '../styles/tokens.css';
import '../styles/docs-theme.css';
import '../styles/global.css';
import Search from '../components/Search';
import { COMPONENT_CATEGORIES, CATEGORY_ICONS, SECTION_ICONS } from '../data/components';

interface Props {
  title?: string;
  currentPath: string;
}

const { title = 'Atelier UI', currentPath } = Astro.props;
const hasToc = Astro.slots.has('toc');
const pageTitle = title !== 'Atelier UI' ? `${title} — Atelier UI` : 'Atelier UI';

const isComponents = currentPath.startsWith('/components');
const isMcp = currentPath === '/mcp';
const isWorkshop = currentPath === '/workshop';
const isStorybook = currentPath === '/storybook';
const isFigma = currentPath === '/figma';
const isDocs = !isComponents && !isMcp && !isWorkshop && !isStorybook && !isFigma;

function isActive(path: string): boolean {
  if (path === '/') return currentPath === '/';
  return currentPath === path || currentPath.startsWith(path + '/');
}

function isTopActive(path: string): boolean {
  if (path === '/workshop') return isWorkshop;
  if (path === '/storybook') return isStorybook;
  if (path === '/figma') return isFigma;
  if (path === '/mcp') return isMcp;
  return false;
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content="Build UIs with AI, Storybook, and Figma — the Atelier workshop." />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content="AI-assisted UI development with Figma as design source of truth and Storybook as your live component explorer." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://atelier.pieper.io${currentPath}`} />
  <meta property="og:image" content="https://atelier.pieper.io/logo.png" />
  <meta name="twitter:card" content="summary" />
  <link rel="icon" href="/logo.ico" sizes="any" />
  <link rel="icon" href="/logo.png" type="image/png" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
  <ClientRouter />
  <!-- Prevent flash of wrong theme & preserve across View Transitions -->
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('docs-theme');
      var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();

    // Before Astro swaps in the new document, copy data-theme to it so there's no flash
    document.addEventListener('astro:before-swap', function(e) {
      var theme = document.documentElement.getAttribute('data-theme');
      if (theme) e.newDocument.documentElement.setAttribute('data-theme', theme);
    });
  </script>
</head>
<body>
  <div class="docs-shell" id="docs-shell">
    <!-- Top Bar -->
    <header class="docs-topbar">
      <button class="docs-menu-btn" id="menu-btn" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </button>

      <a href="/" class="docs-logo">
        <Image src={logo} alt="Atelier" class="docs-logo-img" width={56} height={54} densities={[1, 2]} />
        <span class="docs-logo-text">Atelier</span>
      </a>

      <div class="docs-topbar-sep"></div>

      <nav class="docs-topbar-links">
        <a href="/workshop"  class={`docs-topbar-link${isTopActive('/workshop') ? ' active' : ''}`}>Workshop</a>
        <a href="/storybook" class={`docs-topbar-link${isTopActive('/storybook') ? ' active' : ''}`}>Storybook</a>
        <a href="/figma"     class={`docs-topbar-link${isTopActive('/figma') ? ' active' : ''}`}>Figma</a>
        <a href="/mcp"       class={`docs-topbar-link${isTopActive('/mcp') ? ' active' : ''}`}>MCP Explorer</a>
      </nav>

      <Search client:load />

      <button class="docs-theme-btn" id="theme-btn" aria-label="Toggle theme">
        <svg id="theme-icon-moon" class="docs-theme-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg id="theme-icon-sun" class="docs-theme-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
    </header>

    <!-- Sidebar backdrop (mobile) -->
    <div class="docs-sidebar-backdrop" id="sidebar-backdrop"></div>

    <!-- Sidebar -->
    <nav class="docs-sidebar" id="sidebar">
      <div class="docs-sidebar-header">
        <div class="docs-sidebar-header-top">
          <div>
            <div class="docs-sidebar-title">Technical Atelier</div>
            <div class="docs-sidebar-version">v1.0.4-beta</div>
          </div>
          <button class="docs-sidebar-close" id="sidebar-close" aria-label="Close navigation">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
      </div>

      {!isComponents ? (
        <>
          <div class="docs-nav-section">
            <div class="docs-nav-heading">
              <span class="docs-nav-heading-icon">{SECTION_ICONS['Get Started']}</span>
              Get Started
            </div>
            <a href="/" class={`docs-nav-link${isActive('/') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">dashboard</span>
              Overview
            </a>
            <a href="/workshop" class={`docs-nav-link${isActive('/workshop') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">build_circle</span>
              Workshop Setup
            </a>
            <a href="/figma-token" class={`docs-nav-link${isActive('/figma-token') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">cable</span>
              Figma Setup
            </a>
            <a href="/troubleshooting" class={`docs-nav-link${isActive('/troubleshooting') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">help</span>
              Troubleshooting
            </a>
          </div>

          <div class="docs-nav-section">
            <div class="docs-nav-heading">
              <span class="docs-nav-heading-icon">{SECTION_ICONS['Workflow']}</span>
              Workflow
            </div>
            <a href="/figma" class={`docs-nav-link${isActive('/figma') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">palette</span>
              Figma
            </a>
            <a href="/tutorial" class={`docs-nav-link${isActive('/tutorial') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">school</span>
              Figma to Code
            </a>
            <a href="/storybook" class={`docs-nav-link${isActive('/storybook') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">book</span>
              Storybook
            </a>
            <a href="/mcp" class={`docs-nav-link${isActive('/mcp') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">smart_toy</span>
              AI Tools
            </a>
          </div>

          <div class="docs-nav-section">
            <div class="docs-nav-heading">
              <span class="docs-nav-heading-icon">{SECTION_ICONS['Reference']}</span>
              Reference
            </div>
            <a href="/components" class={`docs-nav-link${isActive('/components') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">widgets</span>
              Components
            </a>
            <a href="/install" class={`docs-nav-link${isActive('/install') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">download</span>
              Installation
            </a>
            <a href="/tokens" class={`docs-nav-link${isActive('/tokens') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">palette</span>
              Design Tokens
            </a>
            <a href="/patterns" class={`docs-nav-link${isActive('/patterns') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">menu_book</span>
              Cookbook Patterns
            </a>
            <a href="/llms" class={`docs-nav-link${isActive('/llms') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">description</span>
              llms.txt
            </a>
            <a href="/agent-skills" class={`docs-nav-link${isActive('/agent-skills') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">robot_2</span>
              Agent Skills
            </a>
            <a href="/claude-md" class={`docs-nav-link${isActive('/claude-md') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">article</span>
              CLAUDE.md
            </a>
            <a href="/prompts" class={`docs-nav-link${isActive('/prompts') ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">chat</span>
              Prompt Templates
            </a>
          </div>
        </>
      ) : (
        <>
          <div class="docs-nav-section">
            <div class="docs-nav-heading">
              <span class="docs-nav-heading-icon">{SECTION_ICONS['Overview']}</span>
              Overview
            </div>
            <a href="/" class="docs-nav-link docs-nav-link--back">
              <span class="docs-nav-link-icon material-symbols-outlined">arrow_back</span>
              Back to Docs
            </a>
            <a href="/components" class={`docs-nav-link${currentPath === '/components' ? ' active' : ''}`}>
              <span class="docs-nav-link-icon material-symbols-outlined">grid_view</span>
              All Components
            </a>
          </div>

          {Object.entries(COMPONENT_CATEGORIES).map(([category, components]) => (
            <div class="docs-nav-section">
              <div class="docs-nav-heading">
                <span class="docs-nav-heading-icon">{CATEGORY_ICONS[category]}</span>
                {category}
              </div>
              {components.map((name) => {
                const label = name.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
                return (
                  <a href={`/components/${name}`} class={`docs-nav-link${currentPath === `/components/${name}` ? ' active' : ''}`}>
                    {label}
                  </a>
                );
              })}
            </div>
          ))}
        </>
      )}
    </nav>

    <!-- Main -->
    <main class={`docs-main${hasToc ? ' docs-main--with-toc' : ''}`}>
      <div class="docs-main-content">
        <slot />
      </div>
      {hasToc && (
        <aside class="docs-toc" aria-label="On this page">
          <div class="docs-toc-header">On this page</div>
          <slot name="toc" />
        </aside>
      )}
    </main>

    <!-- Bottom Nav (mobile) -->
    <nav class="docs-bottom-nav">
      <a href="/workshop"  class={`docs-bottom-nav-item${isWorkshop ? ' active' : ''}`}>
        <span class="docs-bottom-nav-icon material-symbols-outlined">build_circle</span>
        <span class="docs-bottom-nav-label">Workshop</span>
      </a>
      <a href="/storybook" class={`docs-bottom-nav-item${isStorybook ? ' active' : ''}`}>
        <span class="docs-bottom-nav-icon material-symbols-outlined">book</span>
        <span class="docs-bottom-nav-label">Storybook</span>
      </a>
      <a href="/figma"     class={`docs-bottom-nav-item${isFigma ? ' active' : ''}`}>
        <span class="docs-bottom-nav-icon material-symbols-outlined">palette</span>
        <span class="docs-bottom-nav-label">Figma</span>
      </a>
      <a href="/mcp"       class={`docs-bottom-nav-item${isMcp ? ' active' : ''}`}>
        <span class="docs-bottom-nav-icon material-symbols-outlined">smart_toy</span>
        <span class="docs-bottom-nav-label">MCP</span>
      </a>
    </nav>
  </div>

  <!-- Scroll to top button -->
  <button class="docs-scroll-top" id="scroll-top" aria-label="Scroll to top">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="18 15 12 9 6 15"/>
    </svg>
  </button>

  <script is:inline>
    // ── Re-runs on every page load (initial + Astro View Transitions) ──
    function initPage() {
      // Theme toggle
      var themeBtn = document.getElementById('theme-btn');
      var moonIcon = document.getElementById('theme-icon-moon');
      var sunIcon  = document.getElementById('theme-icon-sun');

      function updateThemeIcon() {
        var theme = document.documentElement.getAttribute('data-theme');
        if (moonIcon && sunIcon) {
          moonIcon.style.display = theme === 'dark' ? 'block' : 'none';
          sunIcon.style.display  = theme === 'dark' ? 'none'  : 'block';
        }
      }

      updateThemeIcon();

      if (themeBtn) {
        themeBtn.addEventListener('click', function() {
          var current = document.documentElement.getAttribute('data-theme');
          var next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('docs-theme', next);
          updateThemeIcon();
        });
      }

      // Mobile sidebar
      var menuBtn  = document.getElementById('menu-btn');
      var sidebar  = document.getElementById('sidebar');
      var backdrop = document.getElementById('sidebar-backdrop');
      var closeBtn = document.getElementById('sidebar-close');

      function openSidebar() {
        if (sidebar && backdrop && menuBtn) {
          sidebar.classList.add('docs-sidebar--open');
          backdrop.classList.add('docs-sidebar-backdrop--visible');
          menuBtn.classList.add('docs-menu-btn--open');
        }
      }

      function closeSidebar() {
        if (sidebar && backdrop && menuBtn) {
          sidebar.classList.remove('docs-sidebar--open');
          backdrop.classList.remove('docs-sidebar-backdrop--visible');
          menuBtn.classList.remove('docs-menu-btn--open');
        }
      }

      if (menuBtn) {
        menuBtn.addEventListener('click', function() {
          sidebar && sidebar.classList.contains('docs-sidebar--open')
            ? closeSidebar()
            : openSidebar();
        });
      }

      if (backdrop) backdrop.addEventListener('click', closeSidebar);
      if (closeBtn) closeBtn.addEventListener('click', closeSidebar);

      // Scroll to top button
      var scrollTopBtn = document.getElementById('scroll-top');
      var mainEl = document.querySelector('.docs-main');

      function handleScroll() {
        var scrollY = mainEl ? mainEl.scrollTop : window.scrollY;
        if (scrollTopBtn) {
          scrollTopBtn.classList.toggle('docs-scroll-top--visible', scrollY > 400);
        }
      }

      if (mainEl) mainEl.addEventListener('scroll', handleScroll);
      else window.addEventListener('scroll', handleScroll);

      if (scrollTopBtn) {
        scrollTopBtn.addEventListener('click', function() {
          if (mainEl) mainEl.scrollTo({ top: 0, behavior: 'smooth' });
          else window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      // TOC active state via IntersectionObserver
      var toc = document.querySelector('.docs-toc');
      if (toc) {
        var links = Array.from(toc.querySelectorAll('.docs-toc-link'));
        var headings = links.map(function(l) {
          var href = l.getAttribute('href');
          return href ? document.getElementById(href.slice(1)) : null;
        }).filter(Boolean);
        if (headings.length) {
          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                var id = entry.target.id;
                links.forEach(function(l) {
                  l.classList.toggle('active', l.getAttribute('href') === '#' + id);
                });
              }
            });
          }, { rootMargin: '-68px 0px -70% 0px', threshold: 0 });
          headings.forEach(function(h) { observer.observe(h); });
        }
      }
    }

    // Run on initial load and after every Astro page transition
    document.addEventListener('astro:page-load', initPage);
    initPage();
  </script>
</body>
</html>
