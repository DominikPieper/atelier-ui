---
import { ClientRouter } from 'astro:transitions';
import { Font } from 'astro:assets';
import logo from '../assets/logo.png';
import '../styles/tokens.css';
import '../styles/docs-theme.css';
import '../styles/global.css';
import Search from '../components/Search';
import Icon from '../components/Icon.astro';
import { COMPONENT_CATEGORIES, CATEGORY_ICONS, SECTION_ICONS } from '../data/components';
import libPkg from '../../../libs/angular/package.json';

const LIB_VERSION = libPkg.version;

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogImage?: string;
  currentPath: string;
}

const SITE_URL = 'https://atelier.pieper.io';
const SITE_NAME = 'Atelier';
const DEFAULT_DESCRIPTION =
  'Build UIs with AI, Storybook, and Figma — the Atelier workshop. Framework-agnostic component library with Angular, React, and Vue adapters.';

const {
  title = SITE_NAME,
  description = DEFAULT_DESCRIPTION,
  ogTitle,
  ogImage = `${SITE_URL}/logo.png`,
  currentPath,
} = Astro.props;

const hasToc = Astro.slots.has('toc');
const pageTitle = title !== SITE_NAME ? `${title} — ${SITE_NAME}` : SITE_NAME;
const canonicalUrl = `${SITE_URL}${currentPath}`;
const shareTitle = ogTitle ?? pageTitle;

const isComponents = currentPath.startsWith('/components');
const isMcp = currentPath === '/mcp';
const isWorkshop = currentPath === '/workshop';
const isStorybook = currentPath === '/storybook';
const isFigma = currentPath === '/figma';

function isActive(path: string): boolean {
  if (path === '/') return currentPath === '/';
  return currentPath === path || currentPath.startsWith(path + '/');
}

function isTopActive(path: string): boolean {
  if (path === '/workshop') return isWorkshop;
  if (path === '/storybook') return isStorybook;
  if (path === '/figma') return isFigma;
  if (path === '/mcp') return isMcp;
  return false;
}

// Breadcrumb labels mirror the sidebar nav so JSON-LD crumbs match UI.
const BREADCRUMB_LABELS: Record<string, string> = {
  workshop: 'Workshop Setup',
  'figma-token': 'Figma Access',
  troubleshooting: 'Troubleshooting',
  figma: 'Figma as Source',
  tutorial: 'Figma to Code',
  storybook: 'Storybook',
  mcp: 'AI Tools',
  components: 'Components',
  install: 'Installation',
  tokens: 'Design Tokens',
  patterns: 'Cookbook Patterns',
  llms: 'llms.txt',
  'agent-skills': 'Agent Skills',
  'claude-md': 'CLAUDE.md',
  prompts: 'Prompt Templates',
  'design-principles': 'Design Principles',
  accessibility: 'Accessibility',
};

function titleCase(slug: string): string {
  return (
    BREADCRUMB_LABELS[slug] ??
    slug
      .split('-')
      .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
      .join(' ')
  );
}

const pathSegments = currentPath.split('/').filter(Boolean);
const breadcrumbItems = [
  { name: 'Home', url: SITE_URL + '/' },
  ...pathSegments.map((segment, i) => ({
    name: titleCase(segment),
    url: SITE_URL + '/' + pathSegments.slice(0, i + 1).join('/'),
  })),
];

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: SITE_URL,
  description: DEFAULT_DESCRIPTION,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    item: item.url,
  })),
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />
  <meta name="theme-color" content="#0b1220" media="(prefers-color-scheme: dark)" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={shareTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={shareTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="icon" href="/logo.ico" sizes="any" />
  <link rel="icon" href="/logo.png" type="image/png" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <Font cssVariable="--font-sans" preload />
  <Font cssVariable="--font-mono" />
  <ClientRouter />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <!-- Prevent flash of wrong theme & preserve across View Transitions -->
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('docs-theme');
      var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();

    // Before Astro swaps in the new document, copy data-theme to it so there's no flash
    document.addEventListener('astro:before-swap', function(e) {
      var theme = document.documentElement.getAttribute('data-theme');
      if (theme) e.newDocument.documentElement.setAttribute('data-theme', theme);
    });
  </script>
</head>
<body>
  <div class="docs-shell" id="docs-shell">
    <!-- Top Bar -->
    <header class="docs-topbar">
      <button class="docs-menu-btn" id="menu-btn" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </button>

      <a href="/" class="docs-logo">
        {/* alt="" — decorative; the adjacent .docs-logo-text already names the link. */}
        <img src={logo.src} alt="" class="docs-logo-img" width={224} height={214} />
        <span class="docs-logo-text">Atelier</span>
      </a>

      <div class="docs-topbar-sep"></div>

      <nav class="docs-topbar-links" aria-label="Primary">
        <a href="/workshop"  class={`docs-topbar-link${isTopActive('/workshop') ? ' active' : ''}`}>Workshop</a>
        <a href="/storybook" class={`docs-topbar-link${isTopActive('/storybook') ? ' active' : ''}`}>Storybook</a>
        <a href="/figma"     class={`docs-topbar-link${isTopActive('/figma') ? ' active' : ''}`}>Figma</a>
        <a href="/mcp"       class={`docs-topbar-link${isTopActive('/mcp') ? ' active' : ''}`}>MCP Explorer</a>
      </nav>

      <Search client:idle />

      <button class="docs-theme-btn" id="theme-btn" aria-label="Toggle theme">
        <svg id="theme-icon-moon" class="docs-theme-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg id="theme-icon-sun" class="docs-theme-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" style="display:none">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
    </header>

    <!-- Sidebar backdrop (mobile) -->
    <div class="docs-sidebar-backdrop" id="sidebar-backdrop"></div>

    <!-- Sidebar -->
    <nav class="docs-sidebar" id="sidebar" aria-label="Section navigation">
      <div class="docs-sidebar-header">
        <div class="docs-sidebar-header-top">
          <div>
            <div class="docs-sidebar-title">Technical Atelier</div>
            <a
              href="https://github.com/DominikPieper/atelier-ui/blob/main/CHANGELOG.md"
              target="_blank"
              rel="noopener noreferrer"
              class="docs-sidebar-version"
              title="View changelog"
            >v{LIB_VERSION}</a>
          </div>
          <button class="docs-sidebar-close" id="sidebar-close" aria-label="Close navigation">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
      </div>

      {!isComponents ? (
        <>
          {/* Workshop track — sequential, follow in order. Numbered to set the
              expectation that this is a path, not a menu. */}
          <div class="docs-nav-section">
            <div class="docs-nav-heading">
              <span class="docs-nav-heading-icon">{SECTION_ICONS['Workshop']}</span>
              Workshop
            </div>
            <a href="/" class={`docs-nav-link${isActive('/') ? ' active' : ''}`}>
              <Icon name="dashboard" class="docs-nav-link-icon" />
              <span class="docs-nav-link-num">1</span>
              Overview
            </a>
            <a href="/workshop" class={`docs-nav-link${isActive('/workshop') ? ' active' : ''}`}>
              <Icon name="build_circle" class="docs-nav-link-icon" />
              <span class="docs-nav-link-num">2</span>
              Setup
            </a>
            <a href="/figma-token" class={`docs-nav-link${isActive('/figma-token') ? ' active' : ''}`}>
              <Icon name="cable" class="docs-nav-link-icon" />
              <span class="docs-nav-link-num">3</span>
              Figma Access
            </a>
            <a href="/tutorial" class={`docs-nav-link${isActive('/tutorial') ? ' active' : ''}`}>
              <Icon name="school" class="docs-nav-link-icon" />
              <span class="docs-nav-link-num">4</span>
              Tutorial
            </a>
            <a href="/first-component" class={`docs-nav-link${isActive('/first-component') ? ' active' : ''}`}>
              <Icon name="check_circle" class="docs-nav-link-icon" />
              <span class="docs-nav-link-num">5</span>
              First Component
            </a>
            <a href="/patterns" class={`docs-nav-link${isActive('/patterns') ? ' active' : ''}`}>
              <Icon name="menu_book" class="docs-nav-link-icon" />
              <span class="docs-nav-link-num">6</span>
              Patterns
            </a>
          </div>

          {/* How-To — problem-oriented recipes. Look here when stuck or when
              you have a specific task in mind. */}
          <div class="docs-nav-section">
            <div class="docs-nav-heading">
              <span class="docs-nav-heading-icon">{SECTION_ICONS['How-To']}</span>
              How-To
            </div>
            <a href="/install" class={`docs-nav-link${isActive('/install') ? ' active' : ''}`}>
              <Icon name="download" class="docs-nav-link-icon" />
              Installation
            </a>
            <a href="/figma" class={`docs-nav-link${isActive('/figma') ? ' active' : ''}`}>
              <Icon name="palette" class="docs-nav-link-icon" />
              Figma — manual workflow
            </a>
            <a href="/prompts" class={`docs-nav-link${isActive('/prompts') ? ' active' : ''}`}>
              <Icon name="chat" class="docs-nav-link-icon" />
              Prompt Templates
            </a>
            <a href="/troubleshooting" class={`docs-nav-link${isActive('/troubleshooting') ? ' active' : ''}`}>
              <Icon name="help" class="docs-nav-link-icon" />
              Troubleshooting
            </a>
          </div>

          {/* Reference — random-access lookups. */}
          <div class="docs-nav-section">
            <div class="docs-nav-heading">
              <span class="docs-nav-heading-icon">{SECTION_ICONS['Reference']}</span>
              Reference
            </div>
            <a href="/components" class={`docs-nav-link${isActive('/components') ? ' active' : ''}`}>
              <Icon name="widgets" class="docs-nav-link-icon" />
              Components
            </a>
            <a href="/storybook" class={`docs-nav-link${isActive('/storybook') ? ' active' : ''}`}>
              <Icon name="book" class="docs-nav-link-icon" />
              Storybook
            </a>
            <a href="/tokens" class={`docs-nav-link${isActive('/tokens') ? ' active' : ''}`}>
              <Icon name="palette" class="docs-nav-link-icon" />
              Design Tokens
            </a>
            <a href="/mcp" class={`docs-nav-link${isActive('/mcp') ? ' active' : ''}`}>
              <Icon name="smart_toy" class="docs-nav-link-icon" />
              MCP Playground
            </a>
            <a href="/llms" class={`docs-nav-link${isActive('/llms') ? ' active' : ''}`}>
              <Icon name="description" class="docs-nav-link-icon" />
              llms.txt
            </a>
            <a href="/claude-md" class={`docs-nav-link${isActive('/claude-md') ? ' active' : ''}`}>
              <Icon name="article" class="docs-nav-link-icon" />
              CLAUDE.md
            </a>
            <a href="/agent-skills" class={`docs-nav-link${isActive('/agent-skills') ? ' active' : ''}`}>
              <Icon name="robot_2" class="docs-nav-link-icon" />
              Agent Skills
            </a>
          </div>

          {/* Explanation — the why behind the design. Consult to understand,
              not to do. */}
          <div class="docs-nav-section">
            <div class="docs-nav-heading">
              <span class="docs-nav-heading-icon">{SECTION_ICONS['Explanation']}</span>
              Explanation
            </div>
            <a href="/design-principles" class={`docs-nav-link${isActive('/design-principles') ? ' active' : ''}`}>
              <Icon name="schema" class="docs-nav-link-icon" />
              Design Principles
            </a>
            <a href="/accessibility" class={`docs-nav-link${isActive('/accessibility') ? ' active' : ''}`}>
              <Icon name="accessibility_new" class="docs-nav-link-icon" />
              Accessibility
            </a>
          </div>
        </>
      ) : (
        <>
          <div class="docs-nav-section">
            <div class="docs-nav-heading">
              <span class="docs-nav-heading-icon">{SECTION_ICONS['Overview']}</span>
              Docs
            </div>
            <a href="/" class="docs-nav-link docs-nav-link--back">
              <Icon name="arrow_back" class="docs-nav-link-icon" />
              Back to Docs
            </a>
            <a href="/workshop" class="docs-nav-link">
              <Icon name="build_circle" class="docs-nav-link-icon" />
              Workshop Setup
            </a>
            <a href="/install" class="docs-nav-link">
              <Icon name="download" class="docs-nav-link-icon" />
              Installation
            </a>
            <a href="/troubleshooting" class="docs-nav-link">
              <Icon name="help" class="docs-nav-link-icon" />
              Troubleshooting
            </a>
            <a href="/components" class={`docs-nav-link${currentPath === '/components' ? ' active' : ''}`}>
              <Icon name="grid_view" class="docs-nav-link-icon" />
              All Components
            </a>
          </div>

          {Object.entries(COMPONENT_CATEGORIES).map(([category, components]) => (
            <div class="docs-nav-section">
              <div class="docs-nav-heading">
                <span class="docs-nav-heading-icon">{CATEGORY_ICONS[category]}</span>
                {category}
              </div>
              {components.map((name) => {
                const label = name.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
                return (
                  <a href={`/components/${name}`} class={`docs-nav-link${currentPath === `/components/${name}` ? ' active' : ''}`}>
                    {label}
                  </a>
                );
              })}
            </div>
          ))}
        </>
      )}
    </nav>

    <!-- Main -->
    <main class={`docs-main${hasToc ? ' docs-main--with-toc' : ''}`}>
      <div class="docs-main-content" data-pagefind-body>
        <slot />
      </div>
      {hasToc && (
        <aside class="docs-toc" aria-label="On this page">
          <div class="docs-toc-header">On this page</div>
          <slot name="toc" />
        </aside>
      )}
    </main>

    <!-- Bottom Nav (mobile) -->
    <nav class="docs-bottom-nav" aria-label="Bottom">
      <a href="/workshop"  class={`docs-bottom-nav-item${isWorkshop ? ' active' : ''}`}>
        <Icon name="build_circle" class="docs-bottom-nav-icon" />
        <span class="docs-bottom-nav-label">Workshop</span>
      </a>
      <a href="/storybook" class={`docs-bottom-nav-item${isStorybook ? ' active' : ''}`}>
        <Icon name="book" class="docs-bottom-nav-icon" />
        <span class="docs-bottom-nav-label">Storybook</span>
      </a>
      <a href="/figma"     class={`docs-bottom-nav-item${isFigma ? ' active' : ''}`}>
        <Icon name="palette" class="docs-bottom-nav-icon" />
        <span class="docs-bottom-nav-label">Figma</span>
      </a>
      <a href="/mcp"       class={`docs-bottom-nav-item${isMcp ? ' active' : ''}`}>
        <Icon name="smart_toy" class="docs-bottom-nav-icon" />
        <span class="docs-bottom-nav-label">MCP</span>
      </a>
    </nav>
  </div>

  <!-- Scroll to top button -->
  <button class="docs-scroll-top" id="scroll-top" aria-label="Scroll to top">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
      <polyline points="18 15 12 9 6 15"/>
    </svg>
  </button>

  <script is:inline>
    // ── Re-runs on every page load (initial + Astro View Transitions) ──
    function initPage() {
      // Theme toggle
      var themeBtn = document.getElementById('theme-btn');
      var moonIcon = document.getElementById('theme-icon-moon');
      var sunIcon  = document.getElementById('theme-icon-sun');

      function updateThemeIcon() {
        var theme = document.documentElement.getAttribute('data-theme');
        if (moonIcon && sunIcon) {
          moonIcon.style.display = theme === 'dark' ? 'block' : 'none';
          sunIcon.style.display  = theme === 'dark' ? 'none'  : 'block';
        }
      }

      updateThemeIcon();

      if (themeBtn) {
        themeBtn.addEventListener('click', function() {
          var current = document.documentElement.getAttribute('data-theme');
          var next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('docs-theme', next);
          updateThemeIcon();
        });
      }

      // Mobile sidebar
      var menuBtn  = document.getElementById('menu-btn');
      var sidebar  = document.getElementById('sidebar');
      var backdrop = document.getElementById('sidebar-backdrop');
      var closeBtn = document.getElementById('sidebar-close');

      function openSidebar() {
        if (sidebar && backdrop && menuBtn) {
          sidebar.classList.add('docs-sidebar--open');
          backdrop.classList.add('docs-sidebar-backdrop--visible');
          menuBtn.classList.add('docs-menu-btn--open');
        }
      }

      function closeSidebar() {
        if (sidebar && backdrop && menuBtn) {
          sidebar.classList.remove('docs-sidebar--open');
          backdrop.classList.remove('docs-sidebar-backdrop--visible');
          menuBtn.classList.remove('docs-menu-btn--open');
        }
      }

      if (menuBtn) {
        menuBtn.addEventListener('click', function() {
          sidebar && sidebar.classList.contains('docs-sidebar--open')
            ? closeSidebar()
            : openSidebar();
        });
      }

      if (backdrop) backdrop.addEventListener('click', closeSidebar);
      if (closeBtn) closeBtn.addEventListener('click', closeSidebar);

      // Scroll to top button
      var scrollTopBtn = document.getElementById('scroll-top');
      var mainEl = document.querySelector('.docs-main');

      function handleScroll() {
        var scrollY = mainEl ? mainEl.scrollTop : window.scrollY;
        if (scrollTopBtn) {
          scrollTopBtn.classList.toggle('docs-scroll-top--visible', scrollY > 400);
        }
      }

      if (mainEl) mainEl.addEventListener('scroll', handleScroll);
      else window.addEventListener('scroll', handleScroll);

      if (scrollTopBtn) {
        scrollTopBtn.addEventListener('click', function() {
          if (mainEl) mainEl.scrollTo({ top: 0, behavior: 'smooth' });
          else window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }

      // axe-core flags scrollable <pre> blocks (from astro-expressive-code)
      // as not keyboard-focusable. Add tabindex=0 so keyboard users can
      // scroll horizontally through long code lines. WCAG 2.1.1.
      Array.prototype.forEach.call(
        document.querySelectorAll('.expressive-code pre, pre.preflight-mock-body'),
        function(pre) { if (!pre.hasAttribute('tabindex')) pre.setAttribute('tabindex', '0'); }
      );

      // TOC active state via IntersectionObserver
      var toc = document.querySelector('.docs-toc');
      if (toc) {
        var links = Array.from(toc.querySelectorAll('.docs-toc-link'));
        var headings = links.map(function(l) {
          var href = l.getAttribute('href');
          return href ? document.getElementById(href.slice(1)) : null;
        }).filter(Boolean);
        if (headings.length) {
          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                var id = entry.target.id;
                links.forEach(function(l) {
                  l.classList.toggle('active', l.getAttribute('href') === '#' + id);
                });
              }
            });
          }, { rootMargin: '-68px 0px -70% 0px', threshold: 0 });
          headings.forEach(function(h) { observer.observe(h); });
        }
      }
    }

    // Run on initial load and after every Astro page transition
    document.addEventListener('astro:page-load', initPage);
    initPage();
  </script>

  <script>
    import '../scripts/framework-pref-init';
  </script>
</body>
</html>
