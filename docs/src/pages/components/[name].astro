---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComponentDetail from '../../components/ComponentDetail';
import { ALL_COMPONENTS, componentDocs } from '../../data/components';

export function getStaticPaths() {
  return ALL_COMPONENTS.map(name => ({ params: { name } }));
}

const { name } = Astro.params;
const doc = componentDocs[name as string];
const title = doc?.name ?? name;
const description = doc?.description
  ? `${doc.description} Framework-agnostic component with Angular, React, and Vue adapters.`
  : `${title} — framework-agnostic UI component with Angular, React, and Vue adapters.`;
---

<BaseLayout title={title} description={description} currentPath={`/components/${name}`}>
  <ComponentDetail name={name as string} client:load />
</BaseLayout>
