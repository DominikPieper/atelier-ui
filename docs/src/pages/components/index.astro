---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComponentGallery from '../../components/ComponentGallery';
---

<BaseLayout
  title="Components"
  description="Explore the Atelier component library — buttons, inputs, dialogs, and more, with framework-agnostic APIs and Angular, React, and Vue adapters."
  currentPath="/components"
>
  <div style="max-width: 1280px; margin: 0 auto; padding: 0 1.5rem">
    <div class="page-eyebrow" style="margin-top: 1rem">
      <span class="page-eyebrow-kind page-eyebrow-kind--reference">Reference</span>
    </div>
  </div>
  <ComponentGallery client:load />
</BaseLayout>
