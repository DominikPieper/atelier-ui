---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Code } from 'astro-expressive-code/components';
import DiagramFigure from '../components/DiagramFigure.astro';
import Jargon from '../components/Jargon.astro';
import WorkflowDiagram from '../components/WorkflowDiagram.astro';
const FIGMA_URL = 'https://www.figma.com/design/QMnDD8uZQPldPrlCwZZ58T/LLM%20Components';
---

<BaseLayout
  title="Figma"
  description="How Atelier uses Figma as the design source of truth — component frames, design tokens, and the Figma → Storybook → code workflow."
  currentPath="/figma"
>
  <div class="docs-inline-page">
    <div style="margin-bottom: 1.25rem">
      <div class="page-eyebrow">
        <span class="page-eyebrow-kind page-eyebrow-kind--howto">How-To</span>
      </div>
      <h1 class="docs-page-h1">Figma</h1>
      <p style="font-size: 0.9rem; color: var(--ui-color-text-muted); margin: 0; max-width: 520px; line-height: 1.65">
        The design source of truth for every Atelier component — variables, frames, and token mappings, all in one file.
      </p>
    </div>

    <!-- Page-pair: this page covers the manual workflow; figma-token covers
         the MCP-driven workflow that skips inspection entirely. -->
    <aside class="docs-pagepair" aria-label="Two related Figma pages">
      <div class="docs-pagepair-card docs-pagepair-card--here">
        <span class="docs-pagepair-eyebrow">You're here</span>
        <span class="docs-pagepair-title">/figma</span>
        <span class="docs-pagepair-desc">Manual workflow — open the inspect panel, copy token names, prompt Claude with them. No setup needed.</span>
      </div>
      <div class="docs-pagepair-arrow" aria-hidden="true">›</div>
      <a href="/figma-token" class="docs-pagepair-card docs-pagepair-card--next">
        <span class="docs-pagepair-eyebrow">Skip the manual step</span>
        <span class="docs-pagepair-title">/figma-token →</span>
        <span class="docs-pagepair-desc">Configure the figma-console MCP (Desktop Bridge plugin + token) so Claude reads boundVariables directly.</span>
      </a>
    </aside>

    <!-- The Figma file -->
    <div class="docs-section" style="margin-bottom: 2.5rem">
      <h2 class="docs-section-title">The Figma file</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1.25rem">
        <a href={FIGMA_URL} target="_blank" rel="noopener noreferrer" class="docs-link-primary docs-link-primary--bold">LLM Components</a> is the single Figma file for the Atelier design system.
        It contains two pages and a variable collection that maps 1:1 to the CSS token system.
      </p>
      <table class="docs-props-table" style="margin-bottom: 1.25rem">
        <thead>
          <tr>
            <th>Page</th>
            <th>Purpose</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>Tokens</code></td>
            <td>Variable collection viewer — all 56 <Jargon term="design tokens">design tokens</Jargon> across Light and Dark modes</td>
          </tr>
          <tr>
            <td><code>Components</code></td>
            <td>All component frames organized by section — every variant, size, and state</td>
          </tr>
        </tbody>
      </table>
      <a
        href={FIGMA_URL}
        target="_blank"
        rel="noopener noreferrer"
        style="display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; font-weight: 600; color: var(--ui-color-primary); text-decoration: none"
      >
        Open in Figma →
      </a>
    </div>

    <!-- Token → CSS mapping -->
    <div class="docs-section" style="margin-bottom: 2.5rem">
      <h2 class="docs-section-title">Token → CSS mapping</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1.25rem">
        Every Figma variable maps directly to a CSS custom property using the same name.
        When AI references a token from Figma, it uses the identical name in code — no translation needed.
      </p>

      <DiagramFigure caption="Identical names on both sides: there is no naming layer to learn, translate, or maintain.">
        <svg viewBox="0 0 880 320" role="img" aria-labelledby="tok-title tok-desc" preserveAspectRatio="xMidYMid meet">
          <title id="tok-title">Figma variable to CSS custom property mapping</title>
          <desc id="tok-desc">Each Figma variable on the left maps one-to-one to a CSS custom property on the right. The names are identical across four rows: color/primary, color/surface-raised, spacing/6, radius/lg.</desc>

          <defs>
            <marker id="tok-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
              <path d="M 0 0 L 10 5 L 0 10 z" class="diagram-arrow--accent"/>
            </marker>
          </defs>

          <!-- Left card: Figma variables -->
          <g>
            <rect x="40" y="48" width="320" height="248" rx="14" ry="14" class="diagram-node"/>
            <text x="64" y="32" font-size="11" font-weight="600" class="diagram-eyebrow">Figma variable</text>

            <!-- Token rows -->
            <rect x="64" y="64" width="272" height="36" rx="8" ry="8" style="fill: var(--ui-color-primary-light); stroke: none;"/>
            <text x="78" y="87" class="diagram-mono" font-size="13">color/primary</text>

            <rect x="64" y="112" width="272" height="36" rx="8" ry="8" style="fill: var(--ui-color-primary-light); stroke: none;"/>
            <text x="78" y="135" class="diagram-mono" font-size="13">color/surface-raised</text>

            <rect x="64" y="160" width="272" height="36" rx="8" ry="8" style="fill: var(--ui-color-primary-light); stroke: none;"/>
            <text x="78" y="183" class="diagram-mono" font-size="13">spacing/6</text>

            <rect x="64" y="208" width="272" height="36" rx="8" ry="8" style="fill: var(--ui-color-primary-light); stroke: none;"/>
            <text x="78" y="231" class="diagram-mono" font-size="13">radius/lg</text>
          </g>

          <!-- Right card: CSS custom properties -->
          <g>
            <rect x="520" y="48" width="320" height="248" rx="14" ry="14" class="diagram-node"/>
            <text x="544" y="32" font-size="11" font-weight="600" class="diagram-eyebrow">CSS custom property</text>

            <rect x="544" y="64" width="272" height="36" rx="8" ry="8" style="fill: var(--ui-color-primary-light); stroke: none;"/>
            <text x="558" y="87" class="diagram-mono" font-size="13">--ui-color-primary</text>

            <rect x="544" y="112" width="272" height="36" rx="8" ry="8" style="fill: var(--ui-color-primary-light); stroke: none;"/>
            <text x="558" y="135" class="diagram-mono" font-size="13">--ui-color-surface-raised</text>

            <rect x="544" y="160" width="272" height="36" rx="8" ry="8" style="fill: var(--ui-color-primary-light); stroke: none;"/>
            <text x="558" y="183" class="diagram-mono" font-size="13">--ui-spacing-6</text>

            <rect x="544" y="208" width="272" height="36" rx="8" ry="8" style="fill: var(--ui-color-primary-light); stroke: none;"/>
            <text x="558" y="231" class="diagram-mono" font-size="13">--ui-radius-lg</text>
          </g>

          <!-- Per-row bidirectional arrows -->
          <line x1="364" y1="82"  x2="516" y2="82"  class="diagram-connector diagram-connector--accent" marker-start="url(#tok-arrow)" marker-end="url(#tok-arrow)"/>
          <line x1="364" y1="130" x2="516" y2="130" class="diagram-connector diagram-connector--accent" marker-start="url(#tok-arrow)" marker-end="url(#tok-arrow)"/>
          <line x1="364" y1="178" x2="516" y2="178" class="diagram-connector diagram-connector--accent" marker-start="url(#tok-arrow)" marker-end="url(#tok-arrow)"/>
          <line x1="364" y1="226" x2="516" y2="226" class="diagram-connector diagram-connector--accent" marker-start="url(#tok-arrow)" marker-end="url(#tok-arrow)"/>

          <!-- Center label -->
          <rect x="384" y="258" width="112" height="28" rx="14" ry="14" class="diagram-node diagram-node--accent"/>
          <text x="440" y="276" text-anchor="middle" font-size="11" font-weight="700" style="fill: var(--ui-color-primary)">1 : 1 mapping</text>
          <text x="440" y="306" text-anchor="middle" font-size="10" class="diagram-muted">automatic · no build step</text>
        </svg>
      </DiagramFigure>

      <table class="docs-props-table" style="margin-bottom: 1rem">
        <thead>
          <tr>
            <th>Figma variable</th>
            <th>CSS custom property</th>
            <th>Light value</th>
            <th>Dark value</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>color/primary</code></td>
            <td><code>--ui-color-primary</code></td>
            <td><code>#2563eb</code></td>
            <td><code>#3b82f6</code></td>
          </tr>
          <tr>
            <td><code>color/surface-raised</code></td>
            <td><code>--ui-color-surface-raised</code></td>
            <td><code>#fafafa</code></td>
            <td><code>#252535</code></td>
          </tr>
          <tr>
            <td><code>spacing/4</code></td>
            <td><code>--ui-spacing-4</code></td>
            <td colspan="2"><code>1rem (16px)</code></td>
          </tr>
          <tr>
            <td><code>spacing/6</code></td>
            <td><code>--ui-spacing-6</code></td>
            <td colspan="2"><code>1.5rem (24px)</code></td>
          </tr>
          <tr>
            <td><code>radius/md</code></td>
            <td><code>--ui-radius-md</code></td>
            <td colspan="2"><code>0.5rem (8px)</code></td>
          </tr>
          <tr>
            <td><code>radius/lg</code></td>
            <td><code>--ui-radius-lg</code></td>
            <td colspan="2"><code>0.75rem (12px)</code></td>
          </tr>
        </tbody>
      </table>
      <p style="font-size: 0.8rem; color: var(--ui-color-text-muted); margin: 0">
        56 variables total: 29 color, 10 spacing, 5 radius, 12 typography. Full list in <code>libs/llm-components-angular/src/styles/tokens.css</code>.
      </p>
    </div>

    <!-- Component frames -->
    <div class="docs-section" style="margin-bottom: 2.5rem">
      <h2 class="docs-section-title">Component frames</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1.25rem">
        The <code>Components</code> page has one Figma Section per component. Each section shows all variants,
        sizes, and states — the complete visual spec.
      </p>
      <table class="docs-props-table">
        <thead>
          <tr>
            <th>Component</th>
            <th>Figma section</th>
            <th>What it shows</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><code>LlmButton</code></td>
            <td>P0 — Core</td>
            <td>3 variants × 3 sizes × 4 states (default / hover / disabled / loading)</td>
          </tr>
          <tr>
            <td><code>LlmInput</code></td>
            <td>P0 — Core</td>
            <td>3 types × 5 states + error message</td>
          </tr>
          <tr>
            <td><code>LlmCard</code></td>
            <td>P0 — Core</td>
            <td>3 variants × 4 padding levels</td>
          </tr>
          <tr>
            <td><code>LlmBadge</code></td>
            <td>P0 — Core</td>
            <td>5 variants × 2 sizes + inline usage example</td>
          </tr>
          <tr>
            <td>14 more…</td>
            <td>P1 + P2</td>
            <td>Select, Dialog, Tabs, Accordion, Menu, Tooltip, Alert, Checkbox, Toggle, and more</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Using Figma in the workshop -->
    <div class="docs-section" style="margin-bottom: 2.5rem">
      <h2 class="docs-section-title">Using Figma in the workshop</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1.75rem">
        This is how Figma, Storybook, and AI work together to produce component code that matches the design exactly.
      </p>

      <WorkflowDiagram figureId="figma-workflow" caption="This is how Figma, Storybook, and AI work together to produce component code that matches the design exactly." />

      <div class="docs-step-list">
        <div class="docs-step-row">
          <span class="docs-step-badge">01</span>
          <div class="docs-step-body">
            <h3 class="docs-h3">Open the Figma file — find the component frame</h3>
            <p class="docs-step-desc">
              Navigate to the <code>Components</code> page and locate the section for the component you want to build.
              Note the variant names and states — these map directly to the component's props.
            </p>
          </div>
        </div>

        <div class="docs-step-row">
          <span class="docs-step-badge">02</span>
          <div class="docs-step-body">
            <h3 class="docs-h3">Note the token values from the variable panel</h3>
            <p class="docs-step-desc">
              In the Figma inspect panel (right sidebar, <strong>Design</strong> tab), hover over fills,
              padding, or radius values to see the bound variable name
              (e.g. <code>color/primary</code>, <code>spacing/6</code>, <code>radius/lg</code>). These are the exact
              CSS token names you’ll use in code.
            </p>

            <DiagramFigure caption="The right sidebar in Figma. Every property bound to a variable shows the variable name instead of a raw value — that name is your CSS custom property name.">
              <svg viewBox="0 0 640 400" role="img" aria-labelledby="insp-title insp-desc" preserveAspectRatio="xMidYMid meet">
                <title id="insp-title">Figma Design panel with variable bindings highlighted</title>
                <desc id="insp-desc">A mockup of the Figma right-hand Design panel. Three properties are shown — Fill, Padding, Corner radius — each with its value on the left and its bound variable name on the right. The variable names color/primary, spacing/6, and radius/lg are highlighted.</desc>

                <!-- Panel background -->
                <rect x="24" y="24" width="592" height="352" rx="12" ry="12" class="diagram-node"/>

                <!-- Panel header tabs -->
                <text x="52" y="58" font-size="12" font-weight="700" style="fill: var(--ui-color-primary)">Design</text>
                <text x="110" y="58" font-size="12" class="diagram-muted">Prototype</text>
                <text x="178" y="58" font-size="12" class="diagram-muted">Inspect</text>
                <line x1="44" y1="68" x2="80" y2="68" style="stroke: var(--ui-color-primary); stroke-width: 2;"/>

                <!-- Selected frame label -->
                <rect x="44" y="84" width="120" height="22" rx="4" ry="4" style="fill: color-mix(in srgb, var(--ui-color-primary) 14%, transparent); stroke: var(--ui-color-primary); stroke-width: 1;"/>
                <text x="104" y="99" text-anchor="middle" font-size="11" font-weight="600" class="diagram-mono" style="fill: var(--ui-color-primary)">Settings Card</text>

                <!-- Section: Fill -->
                <text x="44" y="140" font-size="10" font-weight="700" class="diagram-eyebrow">Fill</text>
                <rect x="44" y="150" width="32" height="32" rx="6" ry="6" style="fill: var(--ui-color-primary); stroke: none;"/>
                <text x="90" y="162" font-size="11" class="diagram-mono diagram-muted">#00BEBE · 100%</text>
                <rect x="260" y="146" width="300" height="36" rx="6" ry="6" style="fill: color-mix(in srgb, var(--ui-color-primary) 14%, transparent); stroke: var(--ui-color-primary); stroke-width: 1.25;"/>
                <text x="276" y="169" font-size="12" font-weight="700" class="diagram-mono" style="fill: var(--ui-color-primary)">color/primary</text>

                <!-- Section: Padding -->
                <text x="44" y="214" font-size="10" font-weight="700" class="diagram-eyebrow">Padding</text>
                <text x="44" y="244" font-size="13" class="diagram-mono" font-weight="600">24 px</text>
                <rect x="260" y="224" width="300" height="36" rx="6" ry="6" style="fill: color-mix(in srgb, var(--ui-color-primary) 14%, transparent); stroke: var(--ui-color-primary); stroke-width: 1.25;"/>
                <text x="276" y="247" font-size="12" font-weight="700" class="diagram-mono" style="fill: var(--ui-color-primary)">spacing/6</text>

                <!-- Section: Corner radius -->
                <text x="44" y="292" font-size="10" font-weight="700" class="diagram-eyebrow">Corner radius</text>
                <text x="44" y="322" font-size="13" class="diagram-mono" font-weight="600">12 px</text>
                <rect x="260" y="302" width="300" height="36" rx="6" ry="6" style="fill: color-mix(in srgb, var(--ui-color-primary) 14%, transparent); stroke: var(--ui-color-primary); stroke-width: 1.25;"/>
                <text x="276" y="325" font-size="12" font-weight="700" class="diagram-mono" style="fill: var(--ui-color-primary)">radius/lg</text>

                <!-- Right-hand caption -->
                <text x="620" y="166" text-anchor="end" font-size="9" class="diagram-muted">bound variable</text>
                <text x="620" y="244" text-anchor="end" font-size="9" class="diagram-muted">bound variable</text>
                <text x="620" y="322" text-anchor="end" font-size="9" class="diagram-muted">bound variable</text>
              </svg>
            </DiagramFigure>
          </div>
        </div>

        <div class="docs-step-row">
          <span class="docs-step-badge">03</span>
          <div class="docs-step-body">
            <h3 class="docs-h3">Ask AI — reference token names and Storybook MCP</h3>
            <p class="docs-step-desc">
              Include the Figma token names in your prompt. AI will use the same names in code,
              and will look up accurate prop names and examples from the Storybook MCP:
            </p>
            <Code code={`Build a settings card using LlmCard with variant="elevated".\nMatch the Figma spec: --ui-color-surface-raised background,\n--ui-spacing-6 padding, --ui-radius-lg border-radius.\nUse the storybook-react MCP to check LlmCard props.`} lang="text" title="example prompt" />
          </div>
        </div>

        <div class="docs-step-row">
          <span class="docs-step-badge">04</span>
          <div class="docs-step-body">
            <h3 class="docs-h3">Ship — the component matches the design</h3>
            <p class="docs-step-desc">
              Because Figma variables and CSS custom properties share the same names, there is no gap between
              what the designer specified and what ships. Light and dark mode work automatically — the tokens
              resolve to their mode-specific values at runtime.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom quicknav -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.85rem; margin-top: 2.5rem">
      {[
        { to: '/workshop', label: 'Setup', title: 'Workshop', icon: '🔧' },
        { to: '/storybook', label: 'Explore', title: 'Storybook', icon: '📖' },
        { to: '/mcp', label: 'Tools', title: 'MCP Explorer', icon: '⬡' },
      ].map(({ to, label, title, icon }) => (
        <a href={to} style="display: flex; align-items: center; gap: 0.85rem; padding: 0.9rem 1rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); text-decoration: none; color: inherit; border: 1px solid var(--ui-color-border)">
          <span style="font-size: 1.25rem; flex-shrink: 0">{icon}</span>
          <div>
            <div style="font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ui-color-text-muted); margin-bottom: 0.15rem">{label}</div>
            <div style="font-size: 0.88rem; font-weight: 700; color: var(--ui-color-text)">{title}</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

