---
import BaseLayout from '../layouts/BaseLayout.astro';
import Jargon from '../components/Jargon.astro';
import Icon from '../components/Icon.astro';
import WorkflowDiagram from '../components/WorkflowDiagram.astro';
---

<BaseLayout
  description="Atelier — build UIs with AI, Storybook, and Figma. A framework-agnostic component library with Angular, React, and Vue adapters, designed for LLM-assisted development."
  currentPath="/"
>
  <!-- Hero -->
  <section class="docs-hero-v2">
    <div class="docs-hero-grid-bg"></div>
    <div class="docs-hero-glow"></div>
    <div class="docs-hero-glow-2"></div>

    <div class="docs-hero-eyebrow">
      <span>✦</span> AI Workshop for Component-Driven UIs
    </div>

    <h1 class="docs-hero-wordmark">ATELIER</h1>

    <p class="docs-hero-subtitle">
      <strong>Workshop in a box.</strong> Design in Figma, explore in Storybook,
      ship with Claude — across <strong>Angular</strong>, <strong>React</strong>,
      and <strong>Vue</strong>.
    </p>
    <p class="docs-hero-disclaimer">
      Teaching artifact · not a production library
    </p>

    <div class="docs-hero-actions">
      <a href="/workshop" class="docs-btn docs-btn-primary">
        Start the Workshop →
      </a>
      <a href="/figma" class="docs-btn docs-btn-outline">
        View Figma File
      </a>
    </div>
  </section>

  <!-- Where to start — 3-step orientation strip -->
  <section class="docs-orient-strip" aria-label="Where to start">
    <div class="docs-orient-eyebrow">Where to start</div>
    <div class="docs-orient-cards">
      <a href="#workflow" class="docs-orient-card">
        <div class="docs-orient-card-time">⏱ Read · 5 min</div>
        <div class="docs-orient-card-title">What is Atelier?</div>
        <div class="docs-orient-card-desc">The three pillars and how they connect.</div>
        <div class="docs-orient-card-link">Read the overview →</div>
      </a>
      <a href="/workshop" class="docs-orient-card">
        <div class="docs-orient-card-time">⏱ Run · 15 min</div>
        <div class="docs-orient-card-title">Scaffold your workspace</div>
        <div class="docs-orient-card-desc">One command + preflight verifies your setup.</div>
        <div class="docs-orient-card-link">Open the Workshop →</div>
      </a>
      <a href="/tutorial" class="docs-orient-card docs-orient-card--accent">
        <div class="docs-orient-card-time">⏱ Build · 30 min</div>
        <div class="docs-orient-card-title">First component with Claude</div>
        <div class="docs-orient-card-desc">Figma → MCP → token-exact code.</div>
        <div class="docs-orient-card-link">Open the Tutorial →</div>
      </a>
    </div>
  </section>

  <!-- Workflow section -->
  <h2 class="docs-home-section-heading" id="workflow">Workflow</h2>

  <WorkflowDiagram figureId="home-workflow" />

  <div class="docs-feature-grid">
    <div class="docs-feature-card">
      <span class="docs-feature-card-num">01</span>
      <h3 class="docs-feature-card-title">Design in Figma</h3>
      <p class="docs-feature-card-desc">
        Figma is the single source of truth. <Jargon term="design tokens">Design tokens</Jargon>, component frames, and spacing — all defined here before code is written.
      </p>
      <a href="/figma" class="docs-btn docs-btn-outline" style="margin-top: auto; width: fit-content; font-size: 0.8rem; padding: 0.35rem 0.75rem">Explore Figma →</a>
    </div>

    <div class="docs-feature-card">
      <span class="docs-feature-card-num">02</span>
      <h3 class="docs-feature-card-title">Explore in Storybook</h3>
      <p class="docs-feature-card-desc">
        Storybook is the live component library. Browse props, test states, and reference stories — AI reads it directly via <Jargon term="MCP">MCP</Jargon>.
      </p>
      <a href="/storybook" class="docs-btn docs-btn-outline" style="margin-top: auto; width: fit-content; font-size: 0.8rem; padding: 0.35rem 0.75rem">Open Storybook →</a>
    </div>

    <div class="docs-feature-card">
      <span class="docs-feature-card-num">03</span>
      <h3 class="docs-feature-card-title">Build with AI</h3>
      <p class="docs-feature-card-desc">
        Claude Code connects Figma specs to Storybook components. Reference a Figma frame, ask AI, get production-ready component code.
      </p>
      <a href="/mcp" class="docs-btn docs-btn-outline" style="margin-top: auto; width: fit-content; font-size: 0.8rem; padding: 0.35rem 0.75rem">AI Tools →</a>
    </div>
  </div>

  <!-- 3-pillar ribbon -->
  <div class="docs-stats-ribbon" style="grid-template-columns: repeat(3, 1fr)">
    <div class="docs-stat-item">
      <span class="docs-stat-num" style="font-size: 1.25rem">Figma</span>
      <span class="docs-stat-lbl">Design Source of Truth</span>
    </div>
    <div class="docs-stat-item">
      <span class="docs-stat-num" style="font-size: 1.25rem">Storybook</span>
      <span class="docs-stat-lbl">Live Component Explorer</span>
    </div>
    <div class="docs-stat-item">
      <span class="docs-stat-num" style="font-size: 1.25rem">AI · MCP</span>
      <span class="docs-stat-lbl">Connects Design to Code</span>
    </div>
  </div>

  <!-- Terminal showcase -->
  <h2 class="docs-home-section-heading">Get Started</h2>
  <div class="docs-terminal">
    <div class="docs-terminal-bar">
      <div class="docs-terminal-dots">
        <span class="docs-terminal-dot docs-terminal-dot--red"></span>
        <span class="docs-terminal-dot docs-terminal-dot--yellow"></span>
        <span class="docs-terminal-dot docs-terminal-dot--green"></span>
      </div>
      <span class="docs-terminal-title">terminal — atelier-init — 80x24</span>
      <div style="width: 2.5rem"></div>
    </div>
    <div class="docs-terminal-body">
      <div>
        <span class="docs-term-prompt">➜</span>
        <span class="docs-term-cmd">npx create-atelier-ui-workspace</span>
      </div>
      <div class="docs-term-muted">Initializing Atelier workspace...</div>
      <div class="docs-term-row">
        <span class="docs-term-tag">[STAGE]</span>
        <span>Fetch Component Registry.</span>
        <span class="docs-term-ok">DONE</span>
      </div>
      <div class="docs-term-row">
        <span class="docs-term-tag">[STAGE]</span>
        <span>Inject Design Tokens.......</span>
        <span class="docs-term-ok">DONE</span>
      </div>
      <div class="docs-term-row">
        <span class="docs-term-tag">[STAGE]</span>
        <span>Wire MCP Server...........</span>
        <span class="docs-term-running">RUNNING (87%)</span>
      </div>
      <div class="docs-terminal-success">
        <div class="docs-term-success-msg">✓ Workspace created at ./my-workshop</div>
        <div class="docs-term-muted">Start dev server: <span class="docs-term-cmd">nx serve my-workshop</span></div>
      </div>
      <div>
        <span class="docs-term-prompt">➜</span>
        <span class="docs-term-blink">█</span>
      </div>
    </div>
  </div>

  <!-- Quick nav grid -->
  <h2 class="docs-home-section-heading">Explore</h2>
  <div class="docs-quicknav docs-quicknav--four">
    <a href="/workshop" class="docs-quicknav-card">
      <div class="docs-quicknav-icon">
        <Icon name="build_circle" />
      </div>
      <div>
        <div class="docs-quicknav-label">Setup</div>
        <div class="docs-quicknav-title">Workshop</div>
      </div>
    </a>
    <a href="/storybook" class="docs-quicknav-card">
      <div class="docs-quicknav-icon">
        <Icon name="book" />
      </div>
      <div>
        <div class="docs-quicknav-label">Live Components</div>
        <div class="docs-quicknav-title">Storybook</div>
      </div>
    </a>
    <a href="/figma" class="docs-quicknav-card">
      <div class="docs-quicknav-icon">
        <Icon name="palette" />
      </div>
      <div>
        <div class="docs-quicknav-label">Design Tokens</div>
        <div class="docs-quicknav-title">Figma</div>
      </div>
    </a>
    <a href="/mcp" class="docs-quicknav-card">
      <div class="docs-quicknav-icon">
        <Icon name="smart_toy" />
      </div>
      <div>
        <div class="docs-quicknav-label">AI Protocol</div>
        <div class="docs-quicknav-title">MCP Explorer</div>
      </div>
    </a>
  </div>
</BaseLayout>
