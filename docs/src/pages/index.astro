---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import SectionHead from '../components/SectionHead.astro';
import CodeCard from '../components/CodeCard.astro';

const MCP_CONFIG = `{
  "mcpServers": {
    "storybook-angular": {
      "type": "http",
      "url": "https://atelier.pieper.io/storybook-angular/mcp"
    },
    "storybook-react": {
      "type": "http",
      "url": "https://atelier.pieper.io/storybook-react/mcp"
    },
    "storybook-vue": {
      "type": "http",
      "url": "https://atelier.pieper.io/storybook-vue/mcp"
    }
  }
}`;

const SCAFFOLD_CMD = 'npx create-atelier-ui-workspace';
---

<BaseLayout
  description="Atelier — build UIs with AI, Storybook, and Figma. A framework-agnostic component library with Angular, React, and Vue adapters, designed for LLM-assisted development."
  currentPath="/"
>
  <!-- Hero -->
  <section class="docs-hero-v2" aria-labelledby="hero-title">
    <div class="docs-hero-grid-bg" aria-hidden="true"></div>
    <div class="docs-hero-glow" aria-hidden="true"></div>

    <div class="docs-hero-eyebrow">
      <span class="docs-hero-eyebrow-dot" aria-hidden="true"></span>
      Workshop · Component-driven UIs with AI
    </div>

    <h1 class="docs-hero-wordmark" id="hero-title">ATELIER</h1>

    <p class="docs-hero-subtitle">
      Design in Figma. Explore in Storybook. Ship with AI.
    </p>
    <p class="docs-hero-disclaimer">
      Teaching artifact &middot; not a production library
    </p>

    <div class="docs-hero-actions">
      <a href="/workshop" class="docs-btn docs-btn-primary">
        Start the workshop
      </a>
      <a href="/components" class="docs-btn docs-btn-outline">
        Browse components
      </a>
    </div>
  </section>

  <!-- Three pillars -->
  <section class="docs-pillars-section" aria-labelledby="pillars-title">
    <SectionHead
      eyebrow="The three pillars"
      title="A loop, not a stack."
      sub="Each tool reads the others through Model Context Protocol. Inspect → prompt → ship → iterate."
      align="center"
      id="pillars-title"
    />
    <div class="docs-pillars">
      <article class="docs-pillar">
        <div class="docs-pillar-step">01 &middot; Inspect</div>
        <div class="docs-pillar-icon" aria-hidden="true"><Icon name="figma" /></div>
        <h3 class="docs-pillar-name">Figma</h3>
        <p class="docs-pillar-desc">
          Single source of truth for tokens and component frames. Variables sync to <code>tokens.css</code>.
        </p>
        <div class="docs-pillar-meta">
          <span class="docs-pill-tag">Variables</span>
          <span class="docs-pill-tag">Frames</span>
        </div>
      </article>
      <article class="docs-pillar">
        <div class="docs-pillar-step">02 &middot; Prompt</div>
        <div class="docs-pillar-icon" aria-hidden="true"><Icon name="book" /></div>
        <h3 class="docs-pillar-name">Storybook</h3>
        <p class="docs-pillar-desc">
          Per-framework live explorer. Each instance hosts an MCP endpoint Claude can call.
        </p>
        <div class="docs-pillar-meta">
          <span class="docs-pill-tag">/mcp</span>
          <span class="docs-pill-tag">Stories</span>
        </div>
      </article>
      <article class="docs-pillar">
        <div class="docs-pillar-step">03 &middot; Ship</div>
        <div class="docs-pillar-icon" aria-hidden="true"><Icon name="sparkles" /></div>
        <h3 class="docs-pillar-name">Claude + MCP</h3>
        <p class="docs-pillar-desc">
          Reads Figma + Storybook through MCP, writes spec-aligned code in Angular, React, or Vue.
        </p>
        <div class="docs-pillar-meta">
          <span class="docs-pill-tag">Spec-aware</span>
          <span class="docs-pill-tag">Parity</span>
        </div>
      </article>
    </div>
  </section>

  <!-- MCP setup -->
  <section class="docs-mcp-section" aria-labelledby="mcp-setup-title">
    <div class="docs-mcp-grid">
      <div>
        <SectionHead
          eyebrow="MCP setup"
          title="Three endpoints. One config."
          sub="Drop these into your Claude Code MCP config. Each Storybook instance exposes the same four tools — list-all-documentation, get-documentation, preview-stories, run-story-tests."
          id="mcp-setup-title"
        />
        <ul class="docs-mcp-checklist">
          <li>HTTP transport — no local processes to babysit.</li>
          <li>Hosted alongside the Storybook itself, no extra deploy.</li>
          <li>Spec-aware — Claude knows which props exist before suggesting code.</li>
        </ul>
      </div>
      <CodeCard lang=".mcp.json" code={MCP_CONFIG} id="home-mcp-config" />
    </div>
  </section>

  <!-- Scaffolder CTA -->
  <section class="docs-cta-section" aria-labelledby="cta-title">
    <div class="docs-cta">
      <div class="docs-cta-eyebrow">Get started in 60 seconds</div>
      <h2 class="docs-cta-title" id="cta-title">Scaffold a workspace.</h2>
      <p class="docs-cta-sub">
        An Nx workspace with your framework choice, the component library wired up, and the MCP config pre-seeded.
      </p>
      <div class="docs-cta-cmd">
        <Icon name="terminal" class="docs-cta-cmd-icon" />
        <span class="docs-cta-cmd-prompt" aria-hidden="true">$</span>
        <code class="docs-cta-cmd-text">{SCAFFOLD_CMD}</code>
        <button
          type="button"
          class="docs-cta-cmd-copy"
          data-cta-copy={SCAFFOLD_CMD}
          aria-label="Copy scaffold command to clipboard">
          Copy
        </button>
        <span class="docs-visually-hidden" data-cta-copy-status aria-live="polite" role="status"></span>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function bindCtaCopy() {
    const btns = document.querySelectorAll<HTMLButtonElement>('[data-cta-copy]');
    btns.forEach((btn) => {
      if (btn.dataset.ctaCopyBound === '1') return;
      btn.dataset.ctaCopyBound = '1';
      btn.addEventListener('click', async () => {
        const payload = btn.getAttribute('data-cta-copy') ?? '';
        const status = btn.parentElement?.querySelector<HTMLElement>('[data-cta-copy-status]');
        try {
          await navigator.clipboard.writeText(payload);
          const original = btn.textContent;
          btn.textContent = 'Copied';
          btn.classList.add('is-copied');
          if (status) status.textContent = 'Command copied to clipboard.';
          window.setTimeout(() => {
            btn.textContent = original;
            btn.classList.remove('is-copied');
            if (status) status.textContent = '';
          }, 1400);
        } catch (err) {
          console.error('Clipboard write failed', err);
          if (status) status.textContent = 'Copy failed. Select and copy manually.';
        }
      });
    });
  }

  document.addEventListener('astro:page-load', bindCtaCopy);
  bindCtaCopy();
</script>

<style>
  .docs-hero-eyebrow-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ui-color-primary);
    margin-right: 0.5rem;
    vertical-align: middle;
    animation: docs-hero-eyebrow-pulse 2s ease-in-out infinite;
  }

  @keyframes docs-hero-eyebrow-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }

  .docs-mcp-section,
  .docs-cta-section {
    margin-bottom: 0;
  }

  .docs-visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
