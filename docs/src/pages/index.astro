---
import BaseLayout from '../layouts/BaseLayout.astro';
import DiagramFigure from '../components/DiagramFigure.astro';
import Jargon from '../components/Jargon.astro';
import Icon from '../components/Icon.astro';
---

<style>
  .workflow-diagram {
    display: flex;
    align-items: stretch;
    margin-bottom: 2.5rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    gap: 0;
  }

  /* Hide the HTML workflow on wider screens — the SVG takes over */
  @media (min-width: 720px) {
    .workflow-diagram { display: none; }
  }

  /* Hide the SVG figure on narrow screens — the HTML fallback takes over */
  .workflow-svg-wrapper { display: block; }
  @media (max-width: 719px) {
    .workflow-svg-wrapper { display: none; }
  }

  .workflow-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.25rem 1rem;
    background: var(--ui-color-surface-raised);
    border: 1px solid var(--ui-color-border);
    border-radius: var(--ui-radius-lg);
    gap: 0.5rem;
    min-width: 120px;
    flex: 1;
  }

  .workflow-node--highlight {
    border-color: var(--ui-color-primary);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--ui-color-primary) 25%, transparent),
                0 4px 20px color-mix(in srgb, var(--ui-color-primary) 12%, transparent);
  }

  .workflow-node-icon {
    font-size: 1.5rem;
    width: 1em;
    height: 1em;
    color: var(--ui-color-primary);
    line-height: 1;
  }

  .workflow-node-title {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--ui-color-text);
    white-space: nowrap;
  }

  .workflow-node-desc {
    font-size: 0.72rem;
    color: var(--ui-color-text-muted);
    line-height: 1.4;
  }

  .workflow-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
    padding: 0 0.75rem;
    flex-shrink: 0;
  }

  .workflow-connector-label {
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ui-color-text-muted);
  }

  .workflow-connector-arrow {
    color: var(--ui-color-border-hover);
    font-size: 1.25rem;
    line-height: 1;
  }

  @media (max-width: 640px) {
    .workflow-diagram {
      flex-direction: column;
      align-items: stretch;
      overflow-x: visible;
    }

    .workflow-node {
      flex-direction: row;
      text-align: left;
      gap: 0.75rem;
      min-width: unset;
    }

    .workflow-node-icon {
      flex-shrink: 0;
    }

    .workflow-connector {
      flex-direction: row;
      padding: 0.25rem 0;
      justify-content: center;
    }

    .workflow-connector-arrow {
      transform: rotate(90deg);
    }
  }
</style>

<BaseLayout
  description="Atelier UI — build UIs with AI, Storybook, and Figma. A framework-agnostic component library with Angular, React, and Vue adapters, designed for LLM-assisted development."
  currentPath="/"
>
  <!-- Hero -->
  <section class="docs-hero-v2">
    <div class="docs-hero-grid-bg"></div>
    <div class="docs-hero-glow"></div>
    <div class="docs-hero-glow-2"></div>

    <div class="docs-hero-eyebrow">
      <span>✦</span> AI Workshop for Component-Driven UIs
    </div>

    <h1 class="docs-hero-wordmark">ATELIER</h1>

    <p class="docs-hero-subtitle">
      Build UIs with AI, Storybook, and Figma.
      Design in Figma. Explore in Storybook. Ship with AI.
    </p>

    <div class="docs-hero-actions">
      <a href="/workshop" class="docs-btn docs-btn-primary">
        Start the Workshop →
      </a>
      <a href="/figma" class="docs-btn docs-btn-outline">
        View Figma File
      </a>
    </div>
  </section>

  <!-- Workflow section -->
  <div class="docs-home-section-heading">Workflow</div>

  <div class="workflow-svg-wrapper">
    <DiagramFigure caption="Design in Figma, explore in Storybook, ship with AI. The loop closes when the result feeds back into the next iteration.">
      <svg viewBox="0 0 960 300" role="img" aria-labelledby="wf-title wf-desc" preserveAspectRatio="xMidYMid meet">
        <title id="wf-title">Atelier workflow: Figma, Storybook, AI, Component</title>
        <desc id="wf-desc">Figma provides design tokens and component frames. Storybook exposes props and stories via MCP. Claude reads both sources and writes code that ships as a production component. The loop iterates as designs evolve.</desc>

        <defs>
          <marker id="wf-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10 z" class="diagram-arrow"/>
          </marker>
          <marker id="wf-arrow-accent" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10 z" class="diagram-arrow--accent"/>
          </marker>
          <marker id="wf-arrow-loop" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10 z" class="diagram-arrow--muted-accent"/>
          </marker>
        </defs>

        <!-- Connector labels -->
        <text x="252" y="62" class="diagram-eyebrow" text-anchor="middle">inspect</text>
        <text x="480" y="62" class="diagram-eyebrow" text-anchor="middle">prompt</text>
        <text x="708" y="62" class="diagram-eyebrow" text-anchor="middle">ships</text>
        <text x="480" y="280" class="diagram-eyebrow" text-anchor="middle">iterate</text>

        <!-- Curved connectors between nodes -->
        <path d="M 228 100 C 250 80 254 80 276 100" class="diagram-connector" marker-end="url(#wf-arrow)"/>
        <path d="M 456 100 C 478 80 482 80 504 100" class="diagram-connector" marker-end="url(#wf-arrow)"/>
        <path d="M 684 100 C 706 80 710 80 732 100" class="diagram-connector diagram-connector--accent" marker-end="url(#wf-arrow-accent)"/>

        <!-- Loop-back from Component back to Figma along the bottom -->
        <path d="M 822 168 C 822 230 800 248 760 248 L 200 248 C 160 248 138 230 138 168"
              class="diagram-connector diagram-connector--dashed"
              marker-end="url(#wf-arrow-loop)"/>

        <!-- Node: Figma -->
        <g>
          <rect x="48" y="56" width="180" height="112" rx="14" ry="14" class="diagram-node"/>
          <g transform="translate(123, 82)">
            <circle cx="8" cy="6" r="6" class="diagram-icon" style="fill: var(--ui-color-primary); stroke: none;"/>
            <circle cx="22" cy="6" r="6" class="diagram-icon" style="fill: var(--ui-color-primary); opacity: 0.55; stroke: none;"/>
            <circle cx="8" cy="20" r="6" class="diagram-icon" style="fill: var(--ui-color-primary); opacity: 0.75; stroke: none;"/>
            <circle cx="22" cy="20" r="6" class="diagram-icon" style="fill: var(--ui-color-primary); opacity: 0.35; stroke: none;"/>
          </g>
          <text x="138" y="134" text-anchor="middle" font-size="15" font-weight="700">Figma</text>
          <text x="138" y="153" text-anchor="middle" font-size="11" class="diagram-muted">Tokens · Frames</text>
        </g>

        <!-- Node: Storybook -->
        <g>
          <rect x="276" y="56" width="180" height="112" rx="14" ry="14" class="diagram-node"/>
          <g transform="translate(354, 78)">
            <path d="M 0 4 Q 0 0 4 0 L 28 0 Q 32 0 32 4 L 32 28 Q 32 32 28 32 L 4 32 Q 0 32 0 28 Z" class="diagram-icon"/>
            <path d="M 16 0 L 16 32" class="diagram-icon"/>
            <path d="M 6 10 L 13 10 M 6 16 L 13 16 M 19 10 L 26 10 M 19 16 L 26 16" class="diagram-icon"/>
          </g>
          <text x="366" y="134" text-anchor="middle" font-size="15" font-weight="700">Storybook</text>
          <text x="366" y="153" text-anchor="middle" font-size="11" class="diagram-muted">Props · Stories · MCP</text>
        </g>

        <!-- Node: AI (accent) -->
        <g>
          <rect x="504" y="56" width="180" height="112" rx="14" ry="14" class="diagram-node diagram-node--accent"/>
          <g transform="translate(582, 78)">
            <rect x="0" y="6" width="32" height="26" rx="6" ry="6" class="diagram-icon"/>
            <circle cx="10" cy="19" r="2.5" class="diagram-icon" style="fill: var(--ui-color-primary); stroke: none;"/>
            <circle cx="22" cy="19" r="2.5" class="diagram-icon" style="fill: var(--ui-color-primary); stroke: none;"/>
            <path d="M 16 0 L 16 6" class="diagram-icon"/>
            <circle cx="16" cy="0" r="1.75" class="diagram-icon" style="fill: var(--ui-color-primary); stroke: none;"/>
          </g>
          <text x="594" y="134" text-anchor="middle" font-size="15" font-weight="700">Claude</text>
          <text x="594" y="153" text-anchor="middle" font-size="11" class="diagram-muted">Reads both · Writes code</text>
        </g>

        <!-- Node: Component -->
        <g>
          <rect x="732" y="56" width="180" height="112" rx="14" ry="14" class="diagram-node"/>
          <g transform="translate(808, 78)">
            <circle cx="16" cy="16" r="15" class="diagram-icon"/>
            <path d="M 8 16 L 14 22 L 24 10" class="diagram-icon"/>
          </g>
          <text x="822" y="134" text-anchor="middle" font-size="15" font-weight="700">Component</text>
          <text x="822" y="153" text-anchor="middle" font-size="11" class="diagram-muted">Design-accurate · Shippable</text>
        </g>
      </svg>
    </DiagramFigure>
  </div>

  <div class="workflow-diagram">
    <div class="workflow-node">
      <Icon name="palette" class="workflow-node-icon" />
      <div class="workflow-node-title">Figma</div>
      <div class="workflow-node-desc">Design tokens<br/>Component frames</div>
    </div>
    <div class="workflow-connector">
      <span class="workflow-connector-label">inspect</span>
      <span class="workflow-connector-arrow">→</span>
    </div>
    <div class="workflow-node">
      <Icon name="book" class="workflow-node-icon" />
      <div class="workflow-node-title">Storybook</div>
      <div class="workflow-node-desc">Props &amp; stories<br/>via MCP</div>
    </div>
    <div class="workflow-connector">
      <span class="workflow-connector-label">prompt</span>
      <span class="workflow-connector-arrow">→</span>
    </div>
    <div class="workflow-node workflow-node--highlight">
      <Icon name="smart_toy" class="workflow-node-icon" />
      <div class="workflow-node-title">AI · Claude</div>
      <div class="workflow-node-desc">Reads both sources<br/>Writes code</div>
    </div>
    <div class="workflow-connector">
      <span class="workflow-connector-label">ships</span>
      <span class="workflow-connector-arrow">→</span>
    </div>
    <div class="workflow-node">
      <Icon name="check_circle" class="workflow-node-icon" />
      <div class="workflow-node-title">Component</div>
      <div class="workflow-node-desc">Design-accurate<br/>Dark mode ready</div>
    </div>
  </div>

  <div class="docs-feature-grid">
    <div class="docs-feature-card">
      <span class="docs-feature-card-num">01</span>
      <h3 class="docs-feature-card-title">Design in Figma</h3>
      <p class="docs-feature-card-desc">
        Figma is the single source of truth. <Jargon term="design tokens">Design tokens</Jargon>, component frames, and spacing — all defined here before code is written.
      </p>
      <a href="/figma" class="docs-btn docs-btn-outline" style="margin-top: auto; width: fit-content; font-size: 0.8rem; padding: 0.35rem 0.75rem">Explore Figma →</a>
    </div>

    <div class="docs-feature-card">
      <span class="docs-feature-card-num">02</span>
      <h3 class="docs-feature-card-title">Explore in Storybook</h3>
      <p class="docs-feature-card-desc">
        Storybook is the live component library. Browse props, test states, and reference stories — AI reads it directly via <Jargon term="MCP">MCP</Jargon>.
      </p>
      <a href="/storybook" class="docs-btn docs-btn-outline" style="margin-top: auto; width: fit-content; font-size: 0.8rem; padding: 0.35rem 0.75rem">Open Storybook →</a>
    </div>

    <div class="docs-feature-card">
      <span class="docs-feature-card-num">03</span>
      <h3 class="docs-feature-card-title">Build with AI</h3>
      <p class="docs-feature-card-desc">
        Claude Code connects Figma specs to Storybook components. Reference a Figma frame, ask AI, get production-ready component code.
      </p>
      <a href="/mcp" class="docs-btn docs-btn-outline" style="margin-top: auto; width: fit-content; font-size: 0.8rem; padding: 0.35rem 0.75rem">AI Tools →</a>
    </div>
  </div>

  <!-- 3-pillar ribbon -->
  <div class="docs-stats-ribbon" style="grid-template-columns: repeat(3, 1fr)">
    <div class="docs-stat-item">
      <span class="docs-stat-num" style="font-size: 1.25rem">Figma</span>
      <span class="docs-stat-lbl">Design Source of Truth</span>
    </div>
    <div class="docs-stat-item">
      <span class="docs-stat-num" style="font-size: 1.25rem">Storybook</span>
      <span class="docs-stat-lbl">Live Component Explorer</span>
    </div>
    <div class="docs-stat-item">
      <span class="docs-stat-num" style="font-size: 1.25rem">AI · MCP</span>
      <span class="docs-stat-lbl">Connects Design to Code</span>
    </div>
  </div>

  <!-- Terminal showcase -->
  <div class="docs-home-section-heading">Get Started</div>
  <div class="docs-terminal">
    <div class="docs-terminal-bar">
      <div class="docs-terminal-dots">
        <span class="docs-terminal-dot docs-terminal-dot--red"></span>
        <span class="docs-terminal-dot docs-terminal-dot--yellow"></span>
        <span class="docs-terminal-dot docs-terminal-dot--green"></span>
      </div>
      <span class="docs-terminal-title">terminal — atelier-init — 80x24</span>
      <div style="width: 2.5rem"></div>
    </div>
    <div class="docs-terminal-body">
      <div>
        <span class="docs-term-prompt">➜</span>
        <span class="docs-term-cmd">npx create-atelier-ui-workspace</span>
      </div>
      <div class="docs-term-muted">Initializing Atelier workspace...</div>
      <div class="docs-term-row">
        <span class="docs-term-tag">[STAGE]</span>
        <span>Fetch Component Registry.</span>
        <span class="docs-term-ok">DONE</span>
      </div>
      <div class="docs-term-row">
        <span class="docs-term-tag">[STAGE]</span>
        <span>Inject Design Tokens.......</span>
        <span class="docs-term-ok">DONE</span>
      </div>
      <div class="docs-term-row">
        <span class="docs-term-tag">[STAGE]</span>
        <span>Wire MCP Server...........</span>
        <span class="docs-term-running">RUNNING (87%)</span>
      </div>
      <div class="docs-terminal-success">
        <div class="docs-term-success-msg">✓ Workspace created at ./my-workshop</div>
        <div class="docs-term-muted">Start dev server: <span class="docs-term-cmd">nx serve my-workshop</span></div>
      </div>
      <div>
        <span class="docs-term-prompt">➜</span>
        <span class="docs-term-blink">█</span>
      </div>
    </div>
  </div>

  <!-- Quick nav grid -->
  <div class="docs-home-section-heading">Explore</div>
  <div class="docs-quicknav" style="grid-template-columns: repeat(4, 1fr)">
    <a href="/workshop" class="docs-quicknav-card">
      <div class="docs-quicknav-icon">
        <Icon name="build_circle" />
      </div>
      <div>
        <div class="docs-quicknav-label">Setup</div>
        <div class="docs-quicknav-title">Workshop</div>
      </div>
    </a>
    <a href="/storybook" class="docs-quicknav-card">
      <div class="docs-quicknav-icon">
        <Icon name="book" />
      </div>
      <div>
        <div class="docs-quicknav-label">Live Components</div>
        <div class="docs-quicknav-title">Storybook</div>
      </div>
    </a>
    <a href="/figma" class="docs-quicknav-card">
      <div class="docs-quicknav-icon">
        <Icon name="palette" />
      </div>
      <div>
        <div class="docs-quicknav-label">Design Tokens</div>
        <div class="docs-quicknav-title">Figma</div>
      </div>
    </a>
    <a href="/mcp" class="docs-quicknav-card">
      <div class="docs-quicknav-icon">
        <Icon name="smart_toy" />
      </div>
      <div>
        <div class="docs-quicknav-label">AI Protocol</div>
        <div class="docs-quicknav-title">MCP Explorer</div>
      </div>
    </a>
  </div>
</BaseLayout>
