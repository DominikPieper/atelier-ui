---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Code } from 'astro-expressive-code/components';
import DiagramFigure from '../components/DiagramFigure.astro';
import Jargon from '../components/Jargon.astro';
import Icon from '../components/Icon.astro';

const FRAMEWORKS = ['Angular', 'React', 'Vue'] as const;
const PKG_MANAGERS = ['npm', 'pnpm', 'yarn'] as const;

const INSTALL_CMD: Record<string, Record<string, string>> = {
  Angular: {
    npm:  'npm install @atelier-ui/angular',
    pnpm: 'pnpm add @atelier-ui/angular',
    yarn: 'yarn add @atelier-ui/angular',
  },
  React: {
    npm:  'npm install @atelier-ui/react',
    pnpm: 'pnpm add @atelier-ui/react',
    yarn: 'yarn add @atelier-ui/react',
  },
  Vue: {
    npm:  'npm install @atelier-ui/vue',
    pnpm: 'pnpm add @atelier-ui/vue',
    yarn: 'yarn add @atelier-ui/vue',
  },
};

const TOKEN_IMPORT: Record<string, string> = {
  Angular: "@import '@atelier-ui/angular/styles/tokens.css';",
  React:   "@import '@atelier-ui/react/styles/tokens.css';",
  Vue:     "@import '@atelier-ui/vue/styles/tokens.css';",
};

// Where the token import lives per framework. Listed as file paths
// the user can search for in their scaffolded app.
const TOKEN_FILE: Record<string, { file: string; notes: string }> = {
  Angular: {
    file: 'src/styles.css',
    notes: 'Referenced automatically by angular.json under architect.build.options.styles.',
  },
  React: {
    file: 'src/index.css  (or src/App.css)',
    notes: 'The file that is imported from src/main.tsx — any global stylesheet your app already loads on boot.',
  },
  Vue: {
    file: 'src/assets/main.css  (or src/style.css)',
    notes: 'The file imported from src/main.ts — Vite/Vue projects usually ship one global stylesheet.',
  },
};

const COMPONENT_FILE: Record<string, { file: string; notes: string }> = {
  Angular: {
    file: 'any standalone component .ts file',
    notes: 'Import into the component where you need it and add to the imports array — standalone, no NgModule registration.',
  },
  React: {
    file: 'any component .tsx file',
    notes: 'Standard named ES imports — the bundler tree-shakes unused components automatically.',
  },
  Vue: {
    file: 'any <script setup> block',
    notes: 'Import inside <script setup> in a .vue SFC, then use the component in the template.',
  },
};

const COMPONENT_IMPORT: Record<string, string> = {
  Angular: `import {\n  LlmButton, LlmCard, LlmInput, LlmTextarea,\n  LlmCheckbox, LlmToggle, LlmBadge, LlmAlert,\n  LlmSelect, LlmOption, LlmDialog, LlmTabGroup,\n  LlmTab, LlmAccordionGroup, LlmMenu, LlmMenuItem,\n  LlmTooltip, LlmToast, LlmSkeleton, LlmAvatar\n} from '@atelier-ui/angular';`,
  React:   `import {\n  LlmButton, LlmCard, LlmInput, LlmTextarea,\n  LlmCheckbox, LlmToggle, LlmBadge, LlmAlert,\n  LlmSelect, LlmOption, LlmDialog, LlmTabGroup,\n  LlmTab, LlmAccordionGroup, LlmMenu, LlmMenuItem,\n  LlmTooltip, LlmToastProvider, useLlmToast,\n  LlmSkeleton, LlmAvatar, LlmAvatarGroup\n} from '@atelier-ui/react';`,
  Vue:     `import {\n  LlmButton, LlmCard, LlmInput, LlmTextarea,\n  LlmCheckbox, LlmToggle, LlmBadge, LlmAlert,\n  LlmSelect, LlmOption, LlmDialog, LlmTabGroup,\n  LlmTab, LlmAccordionGroup, LlmMenu, LlmMenuItem,\n  LlmTooltip, LlmSkeleton, LlmAvatar, LlmAvatarGroup\n} from '@atelier-ui/vue';`,
};

// Why the import sets differ across frameworks: each framework wires toasts
// in the idiomatic way for its own DI / composition model. The underlying
// component set is otherwise identical.
const IMPORT_NOTE: Record<string, string> = {
  Angular: 'Toasts are shown via LlmToast on a host element; an injectable LlmToastService triggers them. No Provider tree needed — Angular DI handles it.',
  React:   'Toasts need a root <LlmToastProvider>. Call useLlmToast() inside any descendant component to push messages. LlmAvatarGroup is a React-only composition helper.',
  Vue:     'Toasts use the composition API: call useLlmToast() inside <script setup>. No Provider component — a module-scoped store is shared across the app.',
};
---

<BaseLayout
  title="Installation"
  description="Install Atelier for Angular, React, or Vue — package commands for npm, pnpm, and yarn, plus token and component imports."
  currentPath="/install"
>
  <div class="docs-inline-page">

    <div style="margin-bottom: 2rem">
      <div class="page-eyebrow">
        <span class="page-eyebrow-kind page-eyebrow-kind--howto">How-To</span>
      </div>
      <h1 class="docs-page-h1">
        Installation
      </h1>
      <p style="font-size: 0.9rem; color: var(--ui-color-text-muted); margin: 0; max-width: 580px; line-height: 1.65">
        Add Atelier to an existing app — package commands for npm, pnpm, and yarn,
        plus the one-line token import that wires up dark mode and theming.
      </p>
    </div>

    <!-- Framework selector -->
    <div class="docs-multi-code-tabs" style="border-radius: 8px; margin-bottom: 2rem; width: fit-content">
      {FRAMEWORKS.map((fw, i) => (
        <button class={`docs-multi-code-tab${i === 0 ? ' active' : ''}`} data-fw-btn={fw}>{fw}</button>
      ))}
    </div>

    <DiagramFigure caption="Each step produces the artifact the next step consumes. No config files, no bundler plugins.">
      <svg viewBox="0 0 880 220" role="img" aria-labelledby="ins-title ins-desc" preserveAspectRatio="xMidYMid meet">
        <title id="ins-title">Three-step installation flow</title>
        <desc id="ins-desc">First install the package, which updates package.json. Second import the token stylesheet into global CSS. Third import components into your code. Result: tree-shakeable UI ready to use.</desc>

        <defs>
          <marker id="ins-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
            <path d="M 0 0 L 10 5 L 0 10 z" class="diagram-arrow"/>
          </marker>
        </defs>

        <!-- Step 1: Install package -->
        <g>
          <rect x="24" y="40" width="248" height="128" rx="14" ry="14" class="diagram-node"/>
          <text x="48" y="68" font-size="11" font-weight="700" style="fill: var(--ui-color-primary)">STEP 1</text>
          <g transform="translate(200, 52)">
            <rect x="0" y="0" width="28" height="26" rx="3" ry="3" class="diagram-icon"/>
            <path d="M 0 8 L 28 8" class="diagram-icon"/>
            <path d="M 14 0 L 14 8" class="diagram-icon"/>
          </g>
          <text x="48" y="100" font-size="15" font-weight="700">Install package</text>
          <text x="48" y="122" font-size="11" class="diagram-muted">Adds dependency to</text>
          <text x="48" y="148" class="diagram-mono" font-size="12" style="fill: var(--ui-color-primary)">package.json</text>
        </g>

        <line x1="272" y1="104" x2="312" y2="104" class="diagram-connector" marker-end="url(#ins-arrow)"/>

        <!-- Step 2: Import tokens -->
        <g>
          <rect x="312" y="40" width="248" height="128" rx="14" ry="14" class="diagram-node"/>
          <text x="336" y="68" font-size="11" font-weight="700" style="fill: var(--ui-color-primary)">STEP 2</text>
          <g transform="translate(488, 52)">
            <circle cx="8" cy="8" r="6" class="diagram-icon" style="fill: var(--ui-color-primary); stroke: none;"/>
            <circle cx="22" cy="8" r="6" class="diagram-icon" style="fill: var(--ui-color-secondary); stroke: none; opacity: 0.6;"/>
            <circle cx="15" cy="22" r="6" class="diagram-icon" style="fill: var(--ui-color-primary); stroke: none; opacity: 0.4;"/>
          </g>
          <text x="336" y="100" font-size="15" font-weight="700">Import tokens</text>
          <text x="336" y="122" font-size="11" class="diagram-muted">Adds CSS variables to</text>
          <text x="336" y="148" class="diagram-mono" font-size="12" style="fill: var(--ui-color-primary)">styles.css</text>
        </g>

        <line x1="560" y1="104" x2="600" y2="104" class="diagram-connector" marker-end="url(#ins-arrow)"/>

        <!-- Step 3: Import components -->
        <g>
          <rect x="600" y="40" width="248" height="128" rx="14" ry="14" class="diagram-node diagram-node--accent"/>
          <text x="624" y="68" font-size="11" font-weight="700" style="fill: var(--ui-color-primary)">STEP 3</text>
          <g transform="translate(776, 54)">
            <path d="M 8 0 L 0 12 L 8 24" class="diagram-icon"/>
            <path d="M 22 0 L 30 12 L 22 24" class="diagram-icon"/>
            <path d="M 18 2 L 12 22" class="diagram-icon"/>
          </g>
          <text x="624" y="100" font-size="15" font-weight="700">Import components</text>
          <text x="624" y="122" font-size="11" class="diagram-muted">Tree-shakeable named imports</text>
          <text x="624" y="148" class="diagram-mono" font-size="12" style="fill: var(--ui-color-primary)">import &#123; Llm… &#125; from …</text>
        </g>

        <!-- Ready badge -->
        <g transform="translate(368, 184)">
          <rect x="0" y="0" width="144" height="28" rx="14" ry="14" style="fill: color-mix(in srgb, var(--ui-color-success) 15%, transparent); stroke: var(--ui-color-success); stroke-width: 1;"/>
          <text x="72" y="18" text-anchor="middle" font-size="11" font-weight="700" style="fill: var(--ui-color-success)">✓ ready to build</text>
        </g>
      </svg>
    </DiagramFigure>

    <!-- Step 1: Install -->
    <div class="docs-section">
      <h2 class="docs-section-title">1. Install the package</h2>
      <div class="docs-multi-code-tabs" style="border-radius: 8px 8px 0 0; margin-bottom: 0">
        {PKG_MANAGERS.map((pm, i) => (
          <button class={`docs-multi-code-tab${i === 0 ? ' active' : ''}`} data-pm-btn={pm}>{pm}</button>
        ))}
      </div>
      {FRAMEWORKS.map((fw) =>
        PKG_MANAGERS.map((pm, pi) => (
          <div data-install={`${fw}-${pm}`} hidden={fw !== 'Angular' || pi !== 0}>
            <Code code={INSTALL_CMD[fw][pm]} lang="shell" />
          </div>
        ))
      )}
    </div>

    <!-- Step 2: Tokens -->
    <div class="docs-section">
      <h2 class="docs-section-title">2. Import design tokens</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1rem">
        Add the token stylesheet to your global styles file:
      </p>
      {FRAMEWORKS.map((fw, i) => (
        <div data-fw-panel={fw} hidden={i !== 0}>
          <div class="docs-file-path">
            <Icon name="description" class="docs-file-path-icon" />
            <span class="docs-file-path-name">{TOKEN_FILE[fw].file}</span>
            <span class="docs-file-path-notes">{TOKEN_FILE[fw].notes}</span>
          </div>
          <Code code={TOKEN_IMPORT[fw]} lang="css" />
        </div>
      ))}
      <div style="padding: 1rem 1.25rem; background: var(--ui-color-primary-light); border: 1px solid color-mix(in srgb, var(--ui-color-primary) 20%, transparent); border-radius: var(--ui-radius-md); margin-top: 1rem">
        <p style="margin: 0 0 0.3rem; font-size: 0.82rem; font-weight: 700; color: var(--ui-color-text)">CSS Variables</p>
        <p style="margin: 0; font-size: 0.82rem; color: var(--ui-color-text-muted); line-height: 1.6">
          Atelier uses CSS custom properties for all design tokens, enabling dynamic
          theme switching between light and dark mode with zero JavaScript.
        </p>
      </div>
    </div>

    <!-- Step 3: Components -->
    <div class="docs-section">
      <h2 class="docs-section-title">3. Import components</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1rem">
        Import only the components you need — all are <Jargon term="tree-shakeable">tree-shakeable</Jargon>:
      </p>
      {FRAMEWORKS.map((fw, i) => (
        <div data-fw-panel={fw} hidden={i !== 0}>
          <div class="docs-file-path">
            <Icon name="description" class="docs-file-path-icon" />
            <span class="docs-file-path-name">{COMPONENT_FILE[fw].file}</span>
            <span class="docs-file-path-notes">{COMPONENT_FILE[fw].notes}</span>
          </div>
          <Code code={COMPONENT_IMPORT[fw]} lang="ts" />
          <p style="margin: 0.6rem 0 0; padding: 0.55rem 0.85rem; font-size: 0.76rem; color: var(--ui-color-text-muted); line-height: 1.55; background: var(--ui-color-primary-light); border-radius: var(--ui-radius-sm); border-left: 2px solid var(--ui-color-primary)">
            <strong style="color: var(--ui-color-text); font-weight: 700">Why this list:</strong> {IMPORT_NOTE[fw]}
          </p>
        </div>
      ))}
    </div>

    <!-- What's included -->
    <div class="docs-section">
      <h2 class="docs-section-title">What's included</h2>
      <ul class="docs-checklist">
        <li>25+ components with identical APIs across Angular, React, and Vue</li>
        <li>CSS custom property token system — no runtime dependency</li>
        <li>Dark and light mode built in</li>
        <li>WCAG AA accessible defaults</li>
        <li>LLM-optimized flat APIs — no deep nesting</li>
        <li>MCP server for AI-assisted component discovery</li>
      </ul>
    </div>

    <!-- Next steps -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.85rem; margin-top: 2.5rem">
      {[
        { to: '/workshop', label: 'Next', title: 'Workshop Setup', icon: '⚙' },
        { to: '/components', label: 'Browse', title: 'Components', icon: '🧩' },
        { to: '/design-principles', label: 'Read', title: 'LLM-Optimized APIs', icon: '🧠' },
      ].map(({ to, label, title, icon }) => (
        <a href={to} style="display: flex; align-items: center; gap: 0.85rem; padding: 0.9rem 1rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); text-decoration: none; color: inherit; border: 1px solid var(--ui-color-border)">
          <span style="font-size: 1.25rem; flex-shrink: 0">{icon}</span>
          <div>
            <div style="font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ui-color-text-muted); margin-bottom: 0.15rem">{label}</div>
            <div style="font-size: 0.88rem; font-weight: 700; color: var(--ui-color-text)">{title}</div>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .docs-file-path {
    display: grid;
    grid-template-columns: auto auto 1fr;
    gap: 0.55rem;
    align-items: center;
    padding: 0.5rem 0.85rem;
    margin-bottom: 0.25rem;
    background: var(--ui-color-surface-sunken);
    border: 1px solid var(--ui-color-border);
    border-bottom: none;
    border-top-left-radius: var(--ui-radius-md);
    border-top-right-radius: var(--ui-radius-md);
    font-size: 0.76rem;
  }
  .docs-file-path-icon {
    font-size: 1rem;
    width: 1em;
    height: 1em;
    color: var(--ui-color-primary);
  }
  .docs-file-path-name {
    font-family: var(--font-mono), ui-monospace, SFMono-Regular, Menlo, monospace;
    font-weight: 700;
    color: var(--ui-color-text);
    font-size: 0.78rem;
  }
  .docs-file-path-notes {
    color: var(--ui-color-text-muted);
    font-size: 0.72rem;
    line-height: 1.45;
  }
  @media (max-width: 640px) {
    .docs-file-path {
      grid-template-columns: auto 1fr;
    }
    .docs-file-path-notes {
      grid-column: 1 / -1;
      padding-top: 0.25rem;
      border-top: 1px solid var(--ui-color-border);
    }
  }
</style>

<script>
  // Framework tabs ([data-fw-btn] / [data-fw-panel]) are driven by the shared
  // framework-pref-init script in BaseLayout. This script handles the package-
  // manager tabs and the combined [data-install] panels that key on fw+pm.
  import { getFramework, subscribeFramework, type Framework } from '../lib/framework-pref';

  function initInstallPmTabs() {
    let activePm = 'npm';

    function updateInstallPanels(fw: Framework) {
      const key = `${fw}-${activePm}`;
      document.querySelectorAll<HTMLElement>('[data-install]').forEach(el => {
        el.hidden = (el.dataset.install ?? '').toLowerCase() !== key;
      });
    }

    document.querySelectorAll<HTMLButtonElement>('[data-pm-btn]').forEach(btn => {
      btn.addEventListener('click', () => {
        activePm = btn.dataset.pmBtn ?? activePm;
        document.querySelectorAll('[data-pm-btn]').forEach(b => b.classList.toggle('active', b === btn));
        updateInstallPanels(getFramework());
      });
    });

    subscribeFramework(fw => updateInstallPanels(fw));
    updateInstallPanels(getFramework());
  }
  document.addEventListener('astro:page-load', initInstallPmTabs);
  initInstallPmTabs();
</script>
