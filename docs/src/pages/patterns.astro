---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Code } from 'astro-expressive-code/components';
import { PATTERNS, TAG_TO_SLUG } from '../data/patterns';
import PageEyebrow from '../components/PageEyebrow.astro';
import {
  LoginFormDemo,
  SettingsPageDemo,
  ConfirmationDemo,
  DataListDemo,
  NotificationCenterDemo,
  ManagementDashboardDemo,
} from '../components/PatternsPage';

const FRAMEWORKS = ['Angular', 'React', 'Vue'] as const;
type Framework = typeof FRAMEWORKS[number];

const LANG_MAP: Record<Framework, string> = {
  Angular: 'html',
  React: 'tsx',
  Vue: 'vue',
};

function frameworkCode(p: typeof PATTERNS[number], fw: Framework): string {
  return fw === 'Angular' ? p.angular : fw === 'React' ? p.react : p.vue;
}
---

<BaseLayout
  title="Cookbook Patterns"
  description="Reusable Atelier UI patterns — form layouts, data tables, dialogs, navigation shells, and other multi-component recipes."
  currentPath="/patterns"
>
  <nav slot="toc">
    {PATTERNS.map((p) => (
      <a href={`#pattern-${p.num}`} class="docs-toc-link">{p.title}</a>
    ))}
  </nav>

  <div class="docs-inline-page">

    <div style="margin-bottom: 1.25rem">
      <PageEyebrow kind="howto" tag={`${PATTERNS.length} patterns · 3 frameworks`} />
      <h1 class="docs-page-h1">
        Cookbook Patterns
      </h1>
      <p style="font-size: 0.9rem; color: var(--ui-color-text-muted); margin: 0; max-width: 640px; line-height: 1.65">
        Composition recipes for common UI scenarios. Each pattern shows the
        intended way to combine atomic components — Card with Form, Dialog
        with Alert, Table with Badge — and ships in Angular, React, and Vue.
      </p>
    </div>

    <!-- Why composed API -->
    <div style="padding: 0.85rem 1.1rem; background: color-mix(in srgb, var(--ui-color-primary) 6%, transparent); border: 1px solid color-mix(in srgb, var(--ui-color-primary) 20%, transparent); border-radius: var(--ui-radius-md); display: flex; gap: 0.75rem; align-items: flex-start; margin-bottom: 2.5rem">
      <span style="font-size: 1rem; flex-shrink: 0; margin-top: 1px">🧩</span>
      <p style="margin: 0; font-size: 0.82rem; color: var(--ui-color-text-muted); line-height: 1.6">
        <strong style="color: var(--ui-color-text)">Why the composed API.</strong>
        <code>LlmCard</code> breaks into <code>LlmCardHeader</code>, <code>LlmCardContent</code>, and <code>LlmCardFooter</code> instead of flat props like <code>header={'…'}</code> / <code>footer={'…'}</code>.
        Composition wins three things an LLM cannot: you can drop sections you don’t need (no empty <code>footer</code> slot to null-guard), you can put any JSX/markup inside each part (buttons, badges, form controls), and screen readers get a real DOM landmark for each section instead of a flat container.
        All Atelier UI container components follow the same pattern.
      </p>
    </div>

    {PATTERNS.map((p) => (
      <section id={`pattern-${p.num}`} class="pattern-section">
        <div class="pattern-section-head">
          <span class="pattern-num">{String(p.num).padStart(2, '0')}</span>
          <div style="flex: 1; min-width: 0">
            <h2 class="pattern-title">
              <a href={`/patterns/${p.id}`} class="pattern-title-link">{p.title}</a>
            </h2>
            <p class="pattern-desc">{p.description}</p>
            <div class="pattern-tags">
              {p.tags.map((tag) => {
                const slug = TAG_TO_SLUG[tag];
                return slug ? (
                  <a href={`/components/${slug}`} class="pattern-tag pattern-tag--link">{tag}</a>
                ) : (
                  <span class="pattern-tag">{tag}</span>
                );
              })}
            </div>
            <a href={`/patterns/${p.id}`} class="pattern-deeplink">Read full guide →</a>
          </div>
        </div>

        <!-- Live demo (React island, hydrates on idle).
             Astro requires each island to reference its imported component
             statically, so we switch on p.id rather than a map lookup. -->
        <div class="pattern-demo">
          {p.id === 'login-form'           && <LoginFormDemo client:idle />}
          {p.id === 'settings-page'        && <SettingsPageDemo client:idle />}
          {p.id === 'confirmation-dialog'  && <ConfirmationDemo client:idle />}
          {p.id === 'data-list'            && <DataListDemo client:idle />}
          {p.id === 'notification-center'  && <NotificationCenterDemo client:idle />}
          {p.id === 'management-dashboard' && <ManagementDashboardDemo client:idle />}
        </div>

        <!-- Framework-tabbed code blocks (SSG, indexable) -->
        <div class="docs-multi-code-tabs" style="border-radius: 8px 8px 0 0; margin: 0">
          {FRAMEWORKS.map((fw, i) => (
            <button
              class={`docs-multi-code-tab${i === 0 ? ' active' : ''}`}
              data-fw-btn={fw}
              type="button"
            >{fw}</button>
          ))}
        </div>
        {FRAMEWORKS.map((fw, i) => (
          <div data-fw-panel={fw} hidden={i !== 0}>
            <Code code={frameworkCode(p, fw)} lang={LANG_MAP[fw]} />
          </div>
        ))}
      </section>
    ))}

  </div>
</BaseLayout>

<style>
  .pattern-section {
    margin-bottom: 3.5rem;
    scroll-margin-top: 88px;
  }
  .pattern-section-head {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    margin-bottom: 1rem;
  }
  .pattern-num {
    font-family: var(--font-mono), ui-monospace, SFMono-Regular, monospace;
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--ui-color-primary);
    background: var(--ui-color-primary-light);
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    letter-spacing: 0.06em;
    flex-shrink: 0;
    margin-top: 6px;
  }
  .pattern-title {
    margin: 0 0 0.3rem;
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ui-color-text);
  }
  .pattern-desc {
    margin: 0;
    font-size: 0.85rem;
    color: var(--ui-color-text-muted);
    line-height: 1.6;
  }
  .pattern-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.55rem;
  }
  /* Surface-raised background (non-tinted) so the same-coloured text
   * keeps full contrast against its own background. --docs-secondary
   * is now AA-safe in both modes (indigo-700 light / blue-200 dark),
   * so we can use it directly without local overrides. */
  .pattern-tag {
    font-family: var(--font-mono), ui-monospace, SFMono-Regular, monospace;
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--docs-secondary);
    background: var(--ui-color-surface-raised);
    border: 1px solid color-mix(in srgb, var(--docs-secondary) 35%, var(--ui-color-border));
    padding: 0.12rem 0.42rem;
    border-radius: 3px;
    text-decoration: none;
  }
  .pattern-tag--link {
    transition: background 0.12s ease, border-color 0.12s ease;
  }
  .pattern-tag--link:hover {
    background: color-mix(in srgb, var(--docs-secondary) 10%, var(--ui-color-surface-raised));
    border-color: var(--docs-secondary);
  }
  .pattern-title-link {
    color: inherit;
    text-decoration: none;
  }
  .pattern-title-link:hover {
    color: var(--ui-color-primary);
  }
  .pattern-deeplink {
    display: inline-block;
    margin-top: 0.7rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--docs-secondary);
    text-decoration: none;
  }
  .pattern-deeplink:hover {
    text-decoration: underline;
  }
  .pattern-demo {
    background: var(--ui-color-surface-sunken);
    border: 1px solid var(--ui-color-border);
    border-radius: var(--ui-radius-md);
    padding: 2rem 1.5rem;
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }
</style>
