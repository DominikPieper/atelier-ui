---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Code } from 'astro-expressive-code/components';
import PageHero from '../components/PageHero.astro';
const SITE_URL = 'https://atelier.pieper.io';

const MCP_CONFIG = `{
  "mcpServers": {
    "storybook-react": {
      "type": "http",
      "url": "${SITE_URL}/storybook-react/mcp"
    },
    "storybook-angular": {
      "type": "http",
      "url": "${SITE_URL}/storybook-angular/mcp"
    },
    "storybook-vue": {
      "type": "http",
      "url": "${SITE_URL}/storybook-vue/mcp"
    }
  }
}`;

const STORYBOOK_LINKS = [
  // border = brand hue (decorative); text color comes from a per-framework
  // CSS class that picks an AA-safe shade per theme.
  { name: 'React',   pkg: '@atelier-ui/react',   href: `${SITE_URL}/storybook-react/`,   border: '#61dafb', textClass: 'storybook-card--react' },
  { name: 'Angular', pkg: '@atelier-ui/angular', href: `${SITE_URL}/storybook-angular/`, border: '#e23237', textClass: 'storybook-card--angular' },
  { name: 'Vue',     pkg: '@atelier-ui/vue',     href: `${SITE_URL}/storybook-vue/`,     border: '#42b883', textClass: 'storybook-card--vue' },
];
---

<BaseLayout
  title="Storybook"
  description="How Atelier UI uses Storybook as a live component explorer — stories per framework, MCP-backed docs, and visual regression tests."
  currentPath="/storybook"
>
  <div class="docs-inline-page">
    <PageHero
      kind="reference"
      title="Storybook"
      lede="Interactive component explorers for Angular, React, and Vue. Browse stories, inspect props, and test accessibility in isolation."
      ledeMax="520px"
    />

    <!-- Framework cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.85rem; margin-bottom: 3rem">
      {STORYBOOK_LINKS.map(({ name, pkg, href, border, textClass }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          style={`display: flex; flex-direction: column; gap: 0.5rem; padding: 1.1rem 1.1rem 0.9rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); text-decoration: none; border-left: 3px solid ${border}; transition: background 0.12s`}
          class={`storybook-card ${textClass}`}
        >
          <div style="display: flex; align-items: center; gap: 0.5rem">
            <span class="storybook-card__name">{name}</span>
          </div>
          <span style="font-family: monospace; font-size: 0.72rem; color: var(--ui-color-text-muted)">{pkg}</span>
          <span class="storybook-card__cta">Open</span>
        </a>
      ))}
    </div>

    <!-- MCP section -->
    <div>
      <h2 class="docs-section-title">MCP server</h2>
      <p style="margin: 0 0 1.75rem; font-size: 0.85rem; color: var(--ui-color-text-muted); line-height: 1.65">
        All three Storybook instances expose a hosted MCP endpoint so AI coding assistants can read component documentation directly — no local setup required.
      </p>

      <div class="docs-step-list">
        <!-- Step 01 -->
        <div class="docs-step-row">
          <span class="docs-step-badge">01</span>
          <div class="docs-step-body">
            <h3 class="docs-h3">Add the MCP server to your project</h3>
            <p class="docs-step-desc">
              In your AI assistant's MCP configuration (e.g. <code>.claude/settings.json</code> for Claude Code) add one or more servers:
            </p>
            <Code code={MCP_CONFIG} lang="json" />
          </div>
        </div>

        <!-- Step 02 -->
        <div class="docs-step-row">
          <span class="docs-step-badge">02</span>
          <div class="docs-step-body">
            <h3 class="docs-h3">Use it in your prompts</h3>
            <p class="docs-step-desc">
              Once connected, your AI assistant can look up component props, variants, and usage examples directly from Storybook:
            </p>
            <Code code={`Build a settings page using @atelier-ui/react components.\nUse the storybook-react MCP to check available props.`} lang="text" />
          </div>
        </div>

        <!-- Step 03 -->
        <div class="docs-step-row">
          <span class="docs-step-badge">03</span>
          <div class="docs-step-body">
            <h3 class="docs-h3">Two MCP surfaces</h3>
            <p class="docs-step-desc">
              Storybook 10.4 ships MCP in two layers. The <strong>hosted</strong> endpoint serves docs from a static manifest — works for any framework, no install. The <strong>local dev</strong> surface adds preview &amp; test tools while a local Storybook is running, and is officially React-preview only as of 10.4.
            </p>
            <table class="docs-props-table">
              <thead>
                <tr><th>Tool</th><th>Hosted (atelier.pieper.io)</th><th>Local dev (<code>nx storybook &lt;fw&gt;</code>)</th></tr>
              </thead>
              <tbody>
                <tr><td><code>list-all-documentation</code></td><td>React: components + docs · Angular/Vue: docs only</td><td>All frameworks</td></tr>
                <tr><td><code>get-documentation</code></td><td>React: full · Angular/Vue: docs only</td><td>All frameworks</td></tr>
                <tr><td><code>get-documentation-for-story</code></td><td>React: full · Angular/Vue: docs only</td><td>All frameworks</td></tr>
                <tr><td><code>preview-stories</code></td><td>—</td><td>React (preview); Vue/Angular experimental</td></tr>
                <tr><td><code>run-story-tests</code></td><td>—</td><td>React (preview); Vue/Angular experimental</td></tr>
                <tr><td><code>get-storybook-story-instructions</code></td><td>—</td><td>React (preview); Vue/Angular experimental</td></tr>
              </tbody>
            </table>
            <p class="docs-step-desc" style="margin-top: 0.75rem">
              The hosted endpoint reads <code>manifests/components.json</code> emitted by <code>@storybook/addon-mcp</code> at build time. As of Storybook 10.4 that file is only generated for <strong>React</strong> (via TypeScript Language Server docgen). Angular &amp; Vue static builds only emit <code>docs.json</code> — hosted MCPs for those frameworks return MDX docs (foundations, tokens) but no per-component props. Run the local Storybook dev server for per-component data in Angular/Vue, or use the React MCP as the cross-framework API reference (the spec is identical, only the binding differs).
            </p>
            <p class="docs-step-desc" style="margin-top: 0.5rem">
              The preview / test tools require a running Node.js Storybook dev server and are gated by Storybook 10.4 to React for now.
            </p>
          </div>
        </div>

        <!-- Step 04 -->
        <div class="docs-step-row">
          <span class="docs-step-badge">04</span>
          <div class="docs-step-body">
            <h3 class="docs-h3">Endpoints</h3>
            <table class="docs-props-table" style="margin-top: 0.25rem">
              <thead>
                <tr><th>Library</th><th>Hosted URL</th><th>Local dev URL</th></tr>
              </thead>
              <tbody>
                <tr><td><code>@atelier-ui/react</code></td><td><code>{SITE_URL}/storybook-react/mcp</code></td><td><code>http://localhost:6006/mcp</code></td></tr>
                <tr><td><code>@atelier-ui/angular</code></td><td><code>{SITE_URL}/storybook-angular/mcp</code></td><td><code>http://localhost:6006/mcp</code></td></tr>
                <tr><td><code>@atelier-ui/vue</code></td><td><code>{SITE_URL}/storybook-vue/mcp</code></td><td><code>http://localhost:6006/mcp</code></td></tr>
              </tbody>
            </table>
            <p class="docs-step-desc" style="margin-top: 0.5rem">
              Only one local Storybook can bind <code>localhost:6006</code> at a time — pick the framework you're actively working in.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .storybook-card:hover {
    background: var(--ui-color-surface-raised) !important;
    filter: brightness(1.05);
  }
  .storybook-card__name { font-weight: 700; font-size: 0.95rem; }
  .storybook-card__cta  { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.01em; margin-top: 0.1rem; }

  /* Per-framework AA-safe text colors. Light: -800 shades on raised surface.
     Dark: -300/-400 shades on dark raised surface. */
  .storybook-card--react   .storybook-card__name,
  .storybook-card--react   .storybook-card__cta   { color: #155e75; }
  .storybook-card--angular .storybook-card__name,
  .storybook-card--angular .storybook-card__cta   { color: #991b1b; }
  .storybook-card--vue     .storybook-card__name,
  .storybook-card--vue     .storybook-card__cta   { color: #166534; }

  :global([data-theme='dark']) .storybook-card--react   .storybook-card__name,
  :global([data-theme='dark']) .storybook-card--react   .storybook-card__cta   { color: #67e8f9; }
  :global([data-theme='dark']) .storybook-card--angular .storybook-card__name,
  :global([data-theme='dark']) .storybook-card--angular .storybook-card__cta   { color: #fca5a5; }
  :global([data-theme='dark']) .storybook-card--vue     .storybook-card__name,
  :global([data-theme='dark']) .storybook-card--vue     .storybook-card__cta   { color: #86efac; }
</style>
