---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Code } from 'astro-expressive-code/components';
const SITE_URL = 'https://atelier.pieper.io';

const MCP_CONFIG = `{
  "mcpServers": {
    "storybook-react": {
      "type": "http",
      "url": "${SITE_URL}/storybook-react/mcp"
    },
    "storybook-angular": {
      "type": "http",
      "url": "${SITE_URL}/storybook-angular/mcp"
    },
    "storybook-vue": {
      "type": "http",
      "url": "${SITE_URL}/storybook-vue/mcp"
    }
  }
}`;

const STORYBOOK_LINKS = [
  { name: 'React', pkg: '@atelier-ui/react', href: `${SITE_URL}/storybook-react/`, color: '#61dafb' },
  { name: 'Angular', pkg: '@atelier-ui/angular', href: `${SITE_URL}/storybook-angular/`, color: '#e23237' },
  { name: 'Vue', pkg: '@atelier-ui/vue', href: `${SITE_URL}/storybook-vue/`, color: '#42b883' },
];
---

<BaseLayout
  title="Storybook"
  description="How Atelier uses Storybook as a live component explorer — stories per framework, MCP-backed docs, and visual regression tests."
  currentPath="/storybook"
>
  <div class="docs-inline-page">
    <div style="margin-bottom: 2.5rem">
      <div class="page-eyebrow">
        <span class="page-eyebrow-kind page-eyebrow-kind--reference">Reference</span>
      </div>
      <h1 class="docs-page-h1">Storybook</h1>
      <p style="font-size: 0.9rem; color: var(--ui-color-text-muted); margin: 0; max-width: 520px; line-height: 1.65">
        Interactive component explorers for Angular, React, and Vue. Browse stories, inspect props, and test accessibility in isolation.
      </p>
    </div>

    <!-- Framework cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.85rem; margin-bottom: 3rem">
      {STORYBOOK_LINKS.map(({ name, pkg, href, color }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          style={`display: flex; flex-direction: column; gap: 0.5rem; padding: 1.1rem 1.1rem 0.9rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); text-decoration: none; border-left: 3px solid ${color}; transition: background 0.12s`}
          class="storybook-card"
        >
          <div style="display: flex; align-items: center; gap: 0.5rem">
            <span style={`font-weight: 700; font-size: 0.95rem; color: ${color}`}>{name}</span>
          </div>
          <span style="font-family: monospace; font-size: 0.72rem; color: var(--ui-color-text-muted)">{pkg}</span>
          <span style={`font-size: 0.75rem; color: ${color}; font-weight: 600; letter-spacing: 0.01em; margin-top: 0.1rem`}>Open →</span>
        </a>
      ))}
    </div>

    <!-- MCP section -->
    <div>
      <h2 class="docs-section-title">MCP Server</h2>
      <p style="margin: 0 0 1.75rem; font-size: 0.85rem; color: var(--ui-color-text-muted); line-height: 1.65">
        All three Storybook instances expose a hosted MCP endpoint so AI coding assistants can read component documentation directly — no local setup required.
      </p>

      <div class="docs-step-list">
        <!-- Step 01 -->
        <div class="docs-step-row">
          <span class="docs-step-badge">01</span>
          <div class="docs-step-body">
            <h3 class="docs-h3">Add the MCP server to your project</h3>
            <p class="docs-step-desc">
              In your AI assistant's MCP configuration (e.g. <code>.claude/settings.json</code> for Claude Code) add one or more servers:
            </p>
            <Code code={MCP_CONFIG} lang="json" />
          </div>
        </div>

        <!-- Step 02 -->
        <div class="docs-step-row">
          <span class="docs-step-badge">02</span>
          <div class="docs-step-body">
            <h3 class="docs-h3">Use it in your prompts</h3>
            <p class="docs-step-desc">
              Once connected, your AI assistant can look up component props, variants, and usage examples directly from Storybook:
            </p>
            <Code code={`Build a settings page using @atelier-ui/react components.\nUse the storybook-react MCP to check available props.`} lang="text" />
          </div>
        </div>

        <!-- Step 03 -->
        <div class="docs-step-row">
          <span class="docs-step-badge">03</span>
          <div class="docs-step-body">
            <h3 class="docs-h3">Framework Parity</h3>
            <p class="docs-step-desc">
              All frameworks support prop documentation and component search. Story previews and Vitest integration are currently React and Vue only.
            </p>
            <table class="docs-props-table">
              <thead>
                <tr><th>Feature</th><th>React</th><th>Vue</th><th>Angular</th></tr>
              </thead>
              <tbody>
                <tr><td>Prop Documentation</td><td>✅ Full</td><td>✅ Full</td><td>✅ Full</td></tr>
                <tr><td>Component Search</td><td>✅ Full</td><td>✅ Full</td><td>✅ Full</td></tr>
                <tr><td>Story Previews</td><td>✅ Full</td><td>✅ Full</td><td>⏳ Limited</td></tr>
                <tr><td>Vitest Integration</td><td>✅ Full</td><td>✅ Full</td><td>⏳ Planned</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Step 04 -->
        <div class="docs-step-row">
          <span class="docs-step-badge">04</span>
          <div class="docs-step-body">
            <h3 class="docs-h3">Endpoints</h3>
            <table class="docs-props-table" style="margin-top: 0.25rem">
              <thead>
                <tr><th>Library</th><th>URL</th></tr>
              </thead>
              <tbody>
                <tr><td><code>@atelier-ui/react</code></td><td><code>{SITE_URL}/storybook-react/mcp</code></td></tr>
                <tr><td><code>@atelier-ui/angular</code></td><td><code>{SITE_URL}/storybook-angular/mcp</code></td></tr>
                <tr><td><code>@atelier-ui/vue</code></td><td><code>{SITE_URL}/storybook-vue/mcp</code></td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .storybook-card:hover {
    background: var(--ui-color-surface-raised) !important;
    filter: brightness(1.05);
  }
</style>
