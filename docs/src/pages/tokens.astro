---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import BottomNav from '../components/BottomNav.astro';
import Callout from '../components/Callout.astro';

const colorGroups = [
  {
    label: 'Primary — Conciso deep teal',
    tokens: [
      { name: '--ui-color-primary',        light: '#006470', dark: '#34d8d8', desc: 'Brand primary action' },
      { name: '--ui-color-primary-hover',  light: '#004e58', dark: '#5ee5e5', desc: 'Hover state' },
      { name: '--ui-color-primary-active', light: '#003a42', dark: '#87efef', desc: 'Active / pressed state' },
      { name: '--ui-color-primary-light',  light: 'rgba(0,100,112,0.08)', dark: 'rgba(52,216,216,0.15)', desc: 'Tinted background' },
    ],
  },
  {
    label: 'Semantic',
    tokens: [
      { name: '--ui-color-danger',   light: '#b91c1c', dark: '#f87171', desc: 'Destructive actions, errors' },
      { name: '--ui-color-success',  light: '#15803d', dark: '#4ade80', desc: 'Confirmations, success' },
      { name: '--ui-color-warning',  light: '#b45309', dark: '#fbbf24', desc: 'Cautions, warnings' },
      { name: '--ui-color-info',     light: '#0369a1', dark: '#38bdf8', desc: 'Informational' },
      { name: '--ui-color-secondary',light: '#475569', dark: '#94a3b8', desc: 'Secondary actions' },
    ],
  },
  {
    label: 'Surface — clean white + cool slate',
    tokens: [
      { name: '--ui-color-surface',        light: '#ffffff', dark: '#0a1116', desc: 'Page / base background' },
      { name: '--ui-color-surface-raised', light: '#f8fafc', dark: '#131c24', desc: 'Cards, elevated surfaces' },
      { name: '--ui-color-surface-sunken', light: '#f1f5f9', dark: '#060c10', desc: 'Inset, recessed areas (code blocks)' },
    ],
  },
  {
    label: 'Border',
    tokens: [
      { name: '--ui-color-border',        light: '#e2e8f0', dark: '#1e293b', desc: 'Decorative border (card on raised)' },
      { name: '--ui-color-border-hover',  light: '#cbd5e1', dark: '#334155', desc: 'Hovered decorative border' },
      { name: '--ui-color-border-strong', light: '#64748b', dark: '#64748b', desc: 'Functional border ≥3:1 (inputs, outline buttons)' },
    ],
  },
  {
    label: 'Text',
    tokens: [
      { name: '--ui-color-text',            light: '#0f172a', dark: '#f1f5f9', desc: 'Primary text' },
      { name: '--ui-color-text-muted',      light: '#475569', dark: '#94a3b8', desc: 'Secondary / muted text' },
      { name: '--ui-color-text-on-primary', light: '#ffffff', dark: '#0a1116', desc: 'Text on primary background' },
    ],
  },
];

const spacing = [
  { name: '--ui-spacing-1',  rem: '0.25rem', px: '4px',  use: 'Icon insets, hairline gaps' },
  { name: '--ui-spacing-2',  rem: '0.5rem',  px: '8px',  use: 'Tight inline gaps, badge inset' },
  { name: '--ui-spacing-3',  rem: '0.75rem', px: '12px', use: 'Chip padding, button content gap' },
  { name: '--ui-spacing-4',  rem: '1rem',    px: '16px', use: 'Default body gap, form-field spacing' },
  { name: '--ui-spacing-5',  rem: '1.25rem', px: '20px', use: 'Compact section spacing' },
  { name: '--ui-spacing-6',  rem: '1.5rem',  px: '24px', use: 'Card padding, dialog inset' },
  { name: '--ui-spacing-8',  rem: '2rem',    px: '32px', use: 'Block-level section gap' },
  { name: '--ui-spacing-10', rem: '2.5rem',  px: '40px', use: 'Page-level vertical rhythm' },
  { name: '--ui-spacing-12', rem: '3rem',    px: '48px', use: 'Hero / major section break' },
  { name: '--ui-spacing-16', rem: '4rem',    px: '64px', use: 'Full-bleed section separation' },
];

const radii = [
  { name: '--ui-radius-sm',   value: '0.375rem', px: '6px',  use: 'Inputs, kbd glyphs, small chips' },
  { name: '--ui-radius-md',   value: '0.5rem',   px: '8px',  use: 'Default — buttons, badges, cards' },
  { name: '--ui-radius-lg',   value: '0.75rem',  px: '12px', use: 'Elevated cards, dialogs, panels' },
  { name: '--ui-radius-xl',   value: '1rem',     px: '16px', use: 'Hero / showcase surfaces' },
  { name: '--ui-radius-full', value: '9999px',   px: '∞',    use: 'Pills, avatars, circular icons' },
];

const typography = [
  { name: '--ui-font-size-xs',  value: '0.75rem',  px: '12px', label: 'xs',  use: 'Labels, captions, eyebrows' },
  { name: '--ui-font-size-sm',  value: '0.875rem', px: '14px', label: 'sm',  use: 'Secondary text, table cells' },
  { name: '--ui-font-size-md',  value: '1rem',     px: '16px', label: 'md',  use: 'Default body copy' },
  { name: '--ui-font-size-lg',  value: '1.125rem', px: '18px', label: 'lg',  use: 'Emphasized body, sub-heading' },
  { name: '--ui-font-size-xl',  value: '1.25rem',  px: '20px', label: 'xl',  use: 'Card titles, section heads' },
  { name: '--ui-font-size-2xl', value: '1.5rem',   px: '24px', label: '2xl', use: 'Page heads, hero titles' },
];

const shadows = [
  { name: '--ui-shadow-xs', label: 'xs', use: 'Inputs at rest, subtle inset hint' },
  { name: '--ui-shadow-sm', label: 'sm', use: 'Cards at rest' },
  { name: '--ui-shadow-md', label: 'md', use: 'Hovered cards, dropdowns' },
  { name: '--ui-shadow-lg', label: 'lg', use: 'Dialogs, drawers' },
  { name: '--ui-shadow-xl', label: 'xl', use: 'Tooltips, floating menus' },
];

const motion = [
  { name: '--ui-duration-fast',   value: '150ms', use: 'Micro-interactions — hover, focus, press' },
  { name: '--ui-duration-normal', value: '200ms', use: 'Standard UI transitions — toggle, expand' },
  { name: '--ui-duration-slow',   value: '300ms', use: 'Dialog / drawer enter and exit' },
];
---

<BaseLayout
  title="Design tokens"
  description="The Atelier UI design token system — colors, spacing, radii, and typography primitives that flow from Figma into every component."
  currentPath="/tokens"
>
  <div class="docs-inline-page">

    <PageHero kind="reference" title="Design tokens" ledeMax="520px">
      <strong>Tokens, not utilities.</strong> All CSS custom properties used by Atelier UI — colors, spacing, radius, typography, shadows, and motion. Import once via <code>tokens.css</code>; dark and light mode update automatically.
    </PageHero>

    <Callout tone="tip" title="Watch tokens swap live.">
      Use the theme toggle in the topbar to flip between light and dark — every swatch and value below updates instantly. In your own app, set <code>data-theme="dark"</code> on <code>&lt;html&gt;</code> to force dark mode, <code>data-theme="light"</code> to force light. With neither attribute set, the user’s OS preference wins.
    </Callout>

    <!-- Colors -->
    <div class="docs-section">
      <h2 class="docs-section-title">Colors</h2>
      <p style="color: var(--ui-color-text-muted); font-size: 0.82rem; line-height: 1.6; margin-bottom: 1.5rem">
        Swatches reflect the current theme. Toggle dark/light mode to see both.
      </p>

      {colorGroups.map(group => (
        <div style="margin-bottom: 1.75rem">
          <div style="font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ui-color-text-muted); margin-bottom: 0.6rem">{group.label}</div>
          <div style="display: flex; flex-direction: column; gap: 0.4rem">
            {group.tokens.map(token => (
              <div style="display: flex; align-items: center; gap: 0.85rem; padding: 0.6rem 0.85rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); border: 1px solid var(--ui-color-border)">
                <div style={`width: 2.25rem; height: 2.25rem; border-radius: var(--ui-radius-sm); background: var(${token.name}); border: 1px solid var(--ui-color-border); flex-shrink: 0`}></div>
                <div style="flex: 1; min-width: 0">
                  <div style="font-family: monospace; font-size: 0.8rem; font-weight: 600; color: var(--ui-color-text)">{token.name}</div>
                  <div style="font-size: 0.72rem; color: var(--ui-color-text-muted)">{token.desc}</div>
                </div>
                <div style="text-align: right; flex-shrink: 0; display: flex; gap: 0.5rem">
                  <span style="font-family: monospace; font-size: 0.68rem; color: var(--ui-color-text-muted); background: var(--ui-color-surface-sunken); padding: 0.1rem 0.35rem; border-radius: 3px" title="light">{token.light}</span>
                  <span style="font-family: monospace; font-size: 0.68rem; color: var(--ui-color-text-muted); background: var(--ui-color-surface-sunken); padding: 0.1rem 0.35rem; border-radius: 3px" title="dark">{token.dark}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Spacing -->
    <div class="docs-section">
      <h2 class="docs-section-title">Spacing</h2>
      <p style="color: var(--ui-color-text-muted); font-size: 0.82rem; line-height: 1.6; margin-bottom: 1rem">
        The same scale drives padding, gap, and margin. Pick the smallest token that gives the surface room to breathe — bigger numbers belong at higher levels of layout (sections, hero blocks).
      </p>
      <div style="display: flex; flex-direction: column; gap: 0.35rem">
        {spacing.map(s => (
          <div style="display: flex; align-items: center; gap: 0.85rem; padding: 0.5rem 0.85rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); border: 1px solid var(--ui-color-border); flex-wrap: wrap">
            <div style={`height: 6px; background: var(--ui-color-primary); border-radius: 3px; width: ${s.rem}; flex-shrink: 0; opacity: 0.7`}></div>
            <div style="font-family: monospace; font-size: 0.8rem; font-weight: 600; color: var(--ui-color-text); min-width: 160px">{s.name}</div>
            <div style="font-family: monospace; font-size: 0.75rem; color: var(--ui-color-text-muted); min-width: 4rem">{s.rem}</div>
            <div style="font-family: monospace; font-size: 0.75rem; color: var(--ui-color-text-muted); min-width: 3rem">{s.px}</div>
            <div style="font-size: 0.75rem; color: var(--ui-color-text-muted); flex: 1; min-width: 200px">{s.use}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Radius -->
    <div class="docs-section">
      <h2 class="docs-section-title">Border radius</h2>
      <p style="color: var(--ui-color-text-muted); font-size: 0.82rem; line-height: 1.6; margin-bottom: 1rem">
        Radius scales with surface importance. <code>md</code> is the project default; reach for <code>lg</code> when the surface lifts above the page (cards, dialogs).
      </p>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap">
        {radii.map(r => (
          <div style="display: flex; flex-direction: column; align-items: center; gap: 0.5rem; padding: 1rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); border: 1px solid var(--ui-color-border); min-width: 140px; max-width: 180px">
            <div style={`width: 48px; height: 48px; background: var(--ui-color-primary-light); border: 2px solid var(--ui-color-primary); border-radius: var(${r.name})`}></div>
            <div style="font-family: monospace; font-size: 0.68rem; font-weight: 600; color: var(--ui-color-text); text-align: center">{r.name.replace('--ui-radius-', '')}</div>
            <div style="font-family: monospace; font-size: 0.65rem; color: var(--ui-color-text-muted)">{r.value}</div>
            <div style="font-size: 0.7rem; color: var(--ui-color-text-muted); text-align: center; line-height: 1.4">{r.use}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Typography -->
    <div class="docs-section">
      <h2 class="docs-section-title">Typography scale</h2>
      <p style="color: var(--ui-color-text-muted); font-size: 0.82rem; line-height: 1.6; margin-bottom: 1rem">
        Body copy starts at <code>md</code>. Step down to <code>sm</code> / <code>xs</code> for secondary text and labels; up to <code>lg</code>+ for headings. Pair every step change with a heading-level shift in markup.
      </p>
      <div style="display: flex; flex-direction: column; gap: 0.35rem">
        {typography.map(t => (
          <div style="display: flex; align-items: baseline; gap: 1rem; padding: 0.6rem 0.85rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); border: 1px solid var(--ui-color-border); flex-wrap: wrap">
            <span style={`font-size: var(${t.name}); font-weight: 600; color: var(--ui-color-text); line-height: 1; flex-shrink: 0; min-width: 3.5rem`}>Aa</span>
            <span style="font-family: monospace; font-size: 0.8rem; color: var(--ui-color-text); min-width: 160px">{t.name}</span>
            <span style="font-family: monospace; font-size: 0.75rem; color: var(--ui-color-text-muted); min-width: 4rem">{t.value}</span>
            <span style="font-family: monospace; font-size: 0.75rem; color: var(--ui-color-text-muted); min-width: 3rem">{t.px}</span>
            <span style="font-size: 0.75rem; color: var(--ui-color-text-muted); flex: 1; min-width: 200px">{t.use}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Shadows -->
    <div class="docs-section">
      <h2 class="docs-section-title">Shadows</h2>
      <p style="color: var(--ui-color-text-muted); font-size: 0.82rem; line-height: 1.6; margin-bottom: 1rem">
        Shadows encode elevation. Larger token = higher layer in the stacking order. Keep the difference between hovered and resting states one step apart so movement reads as deliberate.
      </p>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap">
        {shadows.map(s => (
          <div style={`display: flex; flex-direction: column; align-items: center; gap: 0.6rem; padding: 1.25rem 1rem; background: var(--ui-color-surface); border-radius: var(--ui-radius-md); border: 1px solid var(--ui-color-border); min-width: 130px; max-width: 160px`}>
            <div style={`width: 48px; height: 48px; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); box-shadow: var(${s.name})`}></div>
            <div style="font-family: monospace; font-size: 0.72rem; font-weight: 600; color: var(--ui-color-text)">{s.label}</div>
            <div style="font-family: monospace; font-size: 0.65rem; color: var(--ui-color-text-muted)">{s.name.replace('--ui-', '')}</div>
            <div style="font-size: 0.7rem; color: var(--ui-color-text-muted); text-align: center; line-height: 1.4">{s.use}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Motion -->
    <div class="docs-section">
      <h2 class="docs-section-title">Motion</h2>
      <p style="color: var(--ui-color-text-muted); font-size: 0.82rem; line-height: 1.6; margin-bottom: 1rem">
        Durations match perceived weight: tiny things move fast, surfaces move slowly. Easing curves carry intent — <code>ease-out</code> for entrances, <code>ease-spring</code> for affirmative actions, <code>ease-in-out</code> for everything else.
      </p>
      <table class="docs-props-table">
        <thead>
          <tr><th>Token</th><th>Value</th><th>Use</th></tr>
        </thead>
        <tbody>
          {motion.map(m => (
            <tr>
              <td><code>{m.name}</code></td>
              <td><code>{m.value}</code></td>
              <td>{m.use}</td>
            </tr>
          ))}
          <tr><td><code>--ui-ease-out</code></td><td><code>cubic-bezier(0.16, 1, 0.3, 1)</code></td><td>Element entering view (toast, dropdown)</td></tr>
          <tr><td><code>--ui-ease-in-out</code></td><td><code>cubic-bezier(0.45, 0, 0.55, 1)</code></td><td>Symmetric transitions (toggle, accordion)</td></tr>
          <tr><td><code>--ui-ease-spring</code></td><td><code>cubic-bezier(0.34, 1.56, 0.64, 1)</code></td><td>Confirmations, success cues</td></tr>
        </tbody>
      </table>
    </div>

    <!-- Import snippet -->
    <div style="margin-top: 2rem; padding: 1rem 1.25rem; background: var(--ui-color-primary-light); border: 1px solid var(--ui-color-primary-border); border-radius: var(--ui-radius-md)">
      <p style="margin: 0 0 0.3rem; font-size: 0.82rem; font-weight: 700; color: var(--ui-color-text)">Import once in your global styles</p>
      <p style="margin: 0; font-size: 0.82rem; color: var(--ui-color-text-muted); font-family: monospace">
        @import '@atelier-ui/react/styles/tokens.css';
      </p>
    </div>

    <BottomNav items={[
      { to: '/figma',      label: 'Figma',   title: 'Figma variables', icon: 'palette' },
      { to: '/install',    label: 'Install', title: 'Installation',    icon: 'download' },
      { to: '/components', label: 'Browse',  title: 'Components',      icon: 'widgets' },
    ]} />

  </div>
</BaseLayout>
