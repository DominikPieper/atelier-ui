---
import BaseLayout from '../layouts/BaseLayout.astro';

const colorGroups = [
  {
    label: 'Primary — Conciso deep teal',
    tokens: [
      { name: '--ui-color-primary',        light: '#006470', dark: '#34d8d8', desc: 'Brand primary action' },
      { name: '--ui-color-primary-hover',  light: '#004e58', dark: '#5ee5e5', desc: 'Hover state' },
      { name: '--ui-color-primary-active', light: '#003a42', dark: '#87efef', desc: 'Active / pressed state' },
      { name: '--ui-color-primary-light',  light: 'rgba(0,100,112,0.08)', dark: 'rgba(52,216,216,0.15)', desc: 'Tinted background' },
    ],
  },
  {
    label: 'Semantic',
    tokens: [
      { name: '--ui-color-danger',   light: '#b91c1c', dark: '#f87171', desc: 'Destructive actions, errors' },
      { name: '--ui-color-success',  light: '#15803d', dark: '#4ade80', desc: 'Confirmations, success' },
      { name: '--ui-color-warning',  light: '#b45309', dark: '#fbbf24', desc: 'Cautions, warnings' },
      { name: '--ui-color-info',     light: '#0369a1', dark: '#38bdf8', desc: 'Informational' },
      { name: '--ui-color-secondary',light: '#475569', dark: '#94a3b8', desc: 'Secondary actions' },
    ],
  },
  {
    label: 'Surface — clean white + cool slate',
    tokens: [
      { name: '--ui-color-surface',        light: '#ffffff', dark: '#0a1116', desc: 'Page / base background' },
      { name: '--ui-color-surface-raised', light: '#f8fafc', dark: '#131c24', desc: 'Cards, elevated surfaces' },
      { name: '--ui-color-surface-sunken', light: '#f1f5f9', dark: '#060c10', desc: 'Inset, recessed areas (code blocks)' },
    ],
  },
  {
    label: 'Border',
    tokens: [
      { name: '--ui-color-border',        light: '#e2e8f0', dark: '#1e293b', desc: 'Decorative border (card on raised)' },
      { name: '--ui-color-border-hover',  light: '#cbd5e1', dark: '#334155', desc: 'Hovered decorative border' },
      { name: '--ui-color-border-strong', light: '#64748b', dark: '#64748b', desc: 'Functional border ≥3:1 (inputs, outline buttons)' },
    ],
  },
  {
    label: 'Text',
    tokens: [
      { name: '--ui-color-text',            light: '#0f172a', dark: '#f1f5f9', desc: 'Primary text' },
      { name: '--ui-color-text-muted',      light: '#475569', dark: '#94a3b8', desc: 'Secondary / muted text' },
      { name: '--ui-color-text-on-primary', light: '#ffffff', dark: '#0a1116', desc: 'Text on primary background' },
    ],
  },
];

const spacing = [
  { name: '--ui-spacing-1',  rem: '0.25rem', px: '4px'  },
  { name: '--ui-spacing-2',  rem: '0.5rem',  px: '8px'  },
  { name: '--ui-spacing-3',  rem: '0.75rem', px: '12px' },
  { name: '--ui-spacing-4',  rem: '1rem',    px: '16px' },
  { name: '--ui-spacing-5',  rem: '1.25rem', px: '20px' },
  { name: '--ui-spacing-6',  rem: '1.5rem',  px: '24px' },
  { name: '--ui-spacing-8',  rem: '2rem',    px: '32px' },
  { name: '--ui-spacing-10', rem: '2.5rem',  px: '40px' },
  { name: '--ui-spacing-12', rem: '3rem',    px: '48px' },
  { name: '--ui-spacing-16', rem: '4rem',    px: '64px' },
];

const radii = [
  { name: '--ui-radius-sm',   value: '0.375rem', px: '6px'  },
  { name: '--ui-radius-md',   value: '0.5rem',   px: '8px'  },
  { name: '--ui-radius-lg',   value: '0.75rem',  px: '12px' },
  { name: '--ui-radius-xl',   value: '1rem',     px: '16px' },
  { name: '--ui-radius-full', value: '9999px',   px: '∞'    },
];

const typography = [
  { name: '--ui-font-size-xs',  value: '0.75rem',  px: '12px', label: 'xs' },
  { name: '--ui-font-size-sm',  value: '0.875rem', px: '14px', label: 'sm' },
  { name: '--ui-font-size-md',  value: '1rem',     px: '16px', label: 'md' },
  { name: '--ui-font-size-lg',  value: '1.125rem', px: '18px', label: 'lg' },
  { name: '--ui-font-size-xl',  value: '1.25rem',  px: '20px', label: 'xl' },
  { name: '--ui-font-size-2xl', value: '1.5rem',   px: '24px', label: '2xl' },
];

const shadows = [
  { name: '--ui-shadow-xs', label: 'xs' },
  { name: '--ui-shadow-sm', label: 'sm' },
  { name: '--ui-shadow-md', label: 'md' },
  { name: '--ui-shadow-lg', label: 'lg' },
  { name: '--ui-shadow-xl', label: 'xl' },
];

const motion = [
  { name: '--ui-duration-fast',   value: '150ms' },
  { name: '--ui-duration-normal', value: '200ms' },
  { name: '--ui-duration-slow',   value: '300ms' },
];
---

<BaseLayout
  title="Design Tokens"
  description="The Atelier design token system — colors, spacing, radii, and typography primitives that flow from Figma into every component."
  currentPath="/tokens"
>
  <div class="docs-inline-page">

    <div style="margin-bottom: 2.5rem">
      <div class="page-eyebrow">
        <span class="page-eyebrow-kind page-eyebrow-kind--reference">Reference</span>
      </div>
      <h1 style="font-size: 2rem; font-weight: 800; letter-spacing: -0.04em; line-height: 1.1; margin: 0 0 0.6rem; background: linear-gradient(135deg, var(--ui-color-primary) 0%, var(--docs-secondary, #89ceff) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text">
        Design Tokens
      </h1>
      <p style="font-size: 0.9rem; color: var(--ui-color-text-muted); margin: 0; max-width: 520px; line-height: 1.65">
        All CSS custom properties used by Atelier — colors, spacing, radius, typography, shadows, and motion. Import once via <code>tokens.css</code>; dark and light mode update automatically.
      </p>
    </div>

    <div style="margin-bottom: 2rem; padding: 0.85rem 1.1rem; background: color-mix(in srgb, var(--ui-color-primary) 6%, transparent); border: 1px solid color-mix(in srgb, var(--ui-color-primary) 20%, transparent); border-radius: var(--ui-radius-md); display: flex; gap: 0.75rem; align-items: flex-start">
      <span style="font-size: 1rem; flex-shrink: 0; margin-top: 1px">🌓</span>
      <p style="margin: 0; font-size: 0.82rem; color: var(--ui-color-text-muted); line-height: 1.6">
        <strong style="color: var(--ui-color-text)">Watch tokens swap live.</strong>
        Use the <span style="font-family: monospace; padding: 0.05rem 0.3rem; border-radius: 3px; background: var(--ui-color-surface-sunken); border: 1px solid var(--ui-color-border)">☀︎/☾</span> toggle in the header to flip between light and dark — every swatch and value below updates instantly. In your own app, set
        <code>data-theme="dark"</code> on <code>&lt;html&gt;</code> to force dark mode, <code>data-theme="light"</code> to force light. With neither attribute set, the user’s OS preference wins.
      </p>
    </div>

    <!-- Colors -->
    <div class="docs-section">
      <h2 class="docs-section-title">Colors</h2>
      <p style="color: var(--ui-color-text-muted); font-size: 0.82rem; line-height: 1.6; margin-bottom: 1.5rem">
        Swatches reflect the current theme. Toggle dark/light mode to see both.
      </p>

      {colorGroups.map(group => (
        <div style="margin-bottom: 1.75rem">
          <div style="font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ui-color-text-muted); margin-bottom: 0.6rem">{group.label}</div>
          <div style="display: flex; flex-direction: column; gap: 0.4rem">
            {group.tokens.map(token => (
              <div style="display: flex; align-items: center; gap: 0.85rem; padding: 0.6rem 0.85rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); border: 1px solid var(--ui-color-border)">
                <div style={`width: 2.25rem; height: 2.25rem; border-radius: var(--ui-radius-sm); background: var(${token.name}); border: 1px solid var(--ui-color-border); flex-shrink: 0`}></div>
                <div style="flex: 1; min-width: 0">
                  <div style="font-family: monospace; font-size: 0.8rem; font-weight: 600; color: var(--ui-color-text)">{token.name}</div>
                  <div style="font-size: 0.72rem; color: var(--ui-color-text-muted)">{token.desc}</div>
                </div>
                <div style="text-align: right; flex-shrink: 0; display: flex; gap: 0.5rem">
                  <span style="font-family: monospace; font-size: 0.68rem; color: var(--ui-color-text-muted); background: var(--ui-color-surface-sunken); padding: 0.1rem 0.35rem; border-radius: 3px" title="light">{token.light}</span>
                  <span style="font-family: monospace; font-size: 0.68rem; color: var(--ui-color-text-muted); background: var(--ui-color-surface-sunken); padding: 0.1rem 0.35rem; border-radius: 3px" title="dark">{token.dark}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Spacing -->
    <div class="docs-section">
      <h2 class="docs-section-title">Spacing</h2>
      <div style="display: flex; flex-direction: column; gap: 0.35rem">
        {spacing.map(s => (
          <div style="display: flex; align-items: center; gap: 0.85rem; padding: 0.5rem 0.85rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); border: 1px solid var(--ui-color-border)">
            <div style={`height: 6px; background: var(--ui-color-primary); border-radius: 3px; width: ${s.rem}; flex-shrink: 0; opacity: 0.7`}></div>
            <div style="font-family: monospace; font-size: 0.8rem; font-weight: 600; color: var(--ui-color-text); min-width: 180px">{s.name}</div>
            <div style="font-family: monospace; font-size: 0.75rem; color: var(--ui-color-text-muted)">{s.rem}</div>
            <div style="font-family: monospace; font-size: 0.75rem; color: var(--ui-color-text-muted)">{s.px}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Radius -->
    <div class="docs-section">
      <h2 class="docs-section-title">Border Radius</h2>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap">
        {radii.map(r => (
          <div style="display: flex; flex-direction: column; align-items: center; gap: 0.5rem; padding: 1rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); border: 1px solid var(--ui-color-border); min-width: 100px">
            <div style={`width: 48px; height: 48px; background: var(--ui-color-primary-light); border: 2px solid var(--ui-color-primary); border-radius: var(${r.name})`}></div>
            <div style="font-family: monospace; font-size: 0.68rem; font-weight: 600; color: var(--ui-color-text); text-align: center">{r.name.replace('--ui-radius-', '')}</div>
            <div style="font-family: monospace; font-size: 0.65rem; color: var(--ui-color-text-muted)">{r.value}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Typography -->
    <div class="docs-section">
      <h2 class="docs-section-title">Typography Scale</h2>
      <div style="display: flex; flex-direction: column; gap: 0.35rem">
        {typography.map(t => (
          <div style="display: flex; align-items: baseline; gap: 1rem; padding: 0.6rem 0.85rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); border: 1px solid var(--ui-color-border)">
            <span style={`font-size: var(${t.name}); font-weight: 600; color: var(--ui-color-text); line-height: 1; flex-shrink: 0; min-width: 3.5rem`}>Aa</span>
            <span style="font-family: monospace; font-size: 0.8rem; color: var(--ui-color-text); min-width: 180px">{t.name}</span>
            <span style="font-family: monospace; font-size: 0.75rem; color: var(--ui-color-text-muted)">{t.value}</span>
            <span style="font-family: monospace; font-size: 0.75rem; color: var(--ui-color-text-muted)">{t.px}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Shadows -->
    <div class="docs-section">
      <h2 class="docs-section-title">Shadows</h2>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap">
        {shadows.map(s => (
          <div style={`display: flex; flex-direction: column; align-items: center; gap: 0.6rem; padding: 1.25rem 1rem; background: var(--ui-color-surface); border-radius: var(--ui-radius-md); border: 1px solid var(--ui-color-border); min-width: 90px`}>
            <div style={`width: 48px; height: 48px; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); box-shadow: var(${s.name})`}></div>
            <div style="font-family: monospace; font-size: 0.72rem; font-weight: 600; color: var(--ui-color-text)">{s.label}</div>
            <div style="font-family: monospace; font-size: 0.65rem; color: var(--ui-color-text-muted)">{s.name.replace('--ui-', '')}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Motion -->
    <div class="docs-section">
      <h2 class="docs-section-title">Motion</h2>
      <table class="docs-props-table">
        <thead>
          <tr><th>Token</th><th>Value</th></tr>
        </thead>
        <tbody>
          {motion.map(m => (
            <tr>
              <td><code>{m.name}</code></td>
              <td><code>{m.value}</code></td>
            </tr>
          ))}
          <tr><td><code>--ui-ease-out</code></td><td><code>cubic-bezier(0.16, 1, 0.3, 1)</code></td></tr>
          <tr><td><code>--ui-ease-in-out</code></td><td><code>cubic-bezier(0.45, 0, 0.55, 1)</code></td></tr>
          <tr><td><code>--ui-ease-spring</code></td><td><code>cubic-bezier(0.34, 1.56, 0.64, 1)</code></td></tr>
        </tbody>
      </table>
    </div>

    <!-- Import snippet -->
    <div style="margin-top: 2rem; padding: 1rem 1.25rem; background: var(--ui-color-primary-light); border: 1px solid color-mix(in srgb, var(--ui-color-primary) 20%, transparent); border-radius: var(--ui-radius-md)">
      <p style="margin: 0 0 0.3rem; font-size: 0.82rem; font-weight: 700; color: var(--ui-color-text)">Import once in your global styles</p>
      <p style="margin: 0; font-size: 0.82rem; color: var(--ui-color-text-muted); font-family: monospace">
        @import '@atelier-ui/react/styles/tokens.css';
      </p>
    </div>

    <!-- Bottom nav -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.85rem; margin-top: 2.5rem">
      {[
        { to: '/figma',      label: 'Figma',    title: 'Figma Variables', icon: '🎨' },
        { to: '/install',    label: 'Install',  title: 'Installation',    icon: '📦' },
        { to: '/components', label: 'Browse',   title: 'Components',      icon: '🧩' },
      ].map(({ to, label, title, icon }) => (
        <a href={to} style="display: flex; align-items: center; gap: 0.85rem; padding: 0.9rem 1rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); text-decoration: none; color: inherit; border: 1px solid var(--ui-color-border)">
          <span style="font-size: 1.25rem; flex-shrink: 0">{icon}</span>
          <div>
            <div style="font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ui-color-text-muted); margin-bottom: 0.15rem">{label}</div>
            <div style="font-size: 0.88rem; font-weight: 700; color: var(--ui-color-text)">{title}</div>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>
