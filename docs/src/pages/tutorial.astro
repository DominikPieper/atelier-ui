---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Code } from 'astro-expressive-code/components';
import DiagramFigure from '../components/DiagramFigure.astro';
import Jargon from '../components/Jargon.astro';
import Icon from '../components/Icon.astro';

const FRAMEWORKS = ['React', 'Angular', 'Vue'] as const;

const EXAMPLE_PROMPT = `I've selected the "Settings / Card" frame in Figma.

1. Use figma-console MCP (figma_get_component_for_development) to read
   the component spec — I need the boundVariables and the visual reference.
2. Use storybook-react MCP to look up LlmCard and LlmInput props.
3. Generate the React component using:
   - The Atelier components matched from Storybook
   - The exact token names from boundVariables (they map 1-to-1 to CSS
     custom properties — no conversion needed)`;

const OUTPUT: Record<string, string> = {
  React: `import { LlmCard, LlmInput, LlmButton } from '@atelier-ui/react';

export function SettingsCard() {
  return (
    <LlmCard
      variant="elevated"
      style={{ padding: 'var(--ui-spacing-6)', display: 'flex', flexDirection: 'column', gap: 'var(--ui-spacing-4)' }}
    >
      <h2 style={{ fontSize: 'var(--ui-font-size-lg)', fontWeight: 600, color: 'var(--ui-color-text)', margin: 0 }}>
        Account Settings
      </h2>
      <LlmInput label="Name" placeholder="Jane Smith" />
      <LlmInput label="Email" type="email" placeholder="jane@example.com" />
      <div>
        <LlmButton variant="primary">Save Changes</LlmButton>
      </div>
    </LlmCard>
  );
}`,

  Angular: `import { Component } from '@angular/core';
import { LlmCard, LlmInput, LlmButton } from '@atelier-ui/angular';

@Component({
  selector: 'app-settings-card',
  standalone: true,
  imports: [LlmCard, LlmInput, LlmButton],
  template: \`
    <llm-card variant="elevated" style="padding: var(--ui-spacing-6); display: flex; flex-direction: column; gap: var(--ui-spacing-4)">
      <h2 style="font-size: var(--ui-font-size-lg); font-weight: 600; color: var(--ui-color-text); margin: 0">
        Account Settings
      </h2>
      <llm-input label="Name" placeholder="Jane Smith" />
      <llm-input label="Email" type="email" placeholder="jane@example.com" />
      <div>
        <llm-button variant="primary">Save Changes</llm-button>
      </div>
    </llm-card>
  \`,
})
export class SettingsCardComponent {}`,

  Vue: `<script setup lang="ts">
import { LlmCard, LlmInput, LlmButton } from '@atelier-ui/vue';
</script>

<template>
  <LlmCard
    variant="elevated"
    style="padding: var(--ui-spacing-6); display: flex; flex-direction: column; gap: var(--ui-spacing-4)"
  >
    <h2 style="font-size: var(--ui-font-size-lg); font-weight: 600; color: var(--ui-color-text); margin: 0">
      Account Settings
    </h2>
    <LlmInput label="Name" placeholder="Jane Smith" />
    <LlmInput label="Email" type="email" placeholder="jane@example.com" />
    <div>
      <LlmButton variant="primary">Save Changes</LlmButton>
    </div>
  </LlmCard>
</template>`,
};

const PARITY_PROMPT = `Run figma_check_design_parity on the settings card node
against the component I just generated. Fix any discrepancies.`;

const RUN_IT: Record<string, { path: string; cmd: string; port: number; expected: string }> = {
  React: {
    path: 'apps/workshop-react/src/components/SettingsCard.tsx',
    cmd: 'npx nx serve workshop-react',
    port: 4201,
    expected: 'A card with two text inputs (Name, Email) and a primary "Save Changes" button — surface-raised background, padding from the Figma spacing token.',
  },
  Angular: {
    path: 'apps/workshop-angular/src/app/components/settings-card.component.ts',
    cmd: 'npx nx serve workshop-angular',
    port: 4200,
    expected: 'A card with two text inputs (Name, Email) and a primary "Save Changes" button — same surface, padding, and radius as the Figma frame.',
  },
  Vue: {
    path: 'apps/workshop-vue/src/components/SettingsCard.vue',
    cmd: 'npx nx serve workshop-vue',
    port: 4202,
    expected: 'A card with two text inputs (Name, Email) and a primary "Save Changes" button — surface-raised background, identical token-driven spacing.',
  },
};

const BOUND_VARS_EXAMPLE = `// What figma_get_component_for_development returns for a card frame:
{
  "name": "Settings / Card",
  "boundVariables": {
    "fills":         [{ "variable": "color/surface-raised" }],  // → --ui-color-surface-raised
    "paddingTop":    { "variable": "spacing/6" },               // → --ui-spacing-6
    "paddingLeft":   { "variable": "spacing/6" },               // → --ui-spacing-6
    "itemSpacing":   { "variable": "spacing/4" },               // → --ui-spacing-4
    "cornerRadius":  { "variable": "radius/lg" }                // → --ui-radius-lg
  },
  "image": "<2x rendered PNG — included automatically>"
}`;
---

<BaseLayout
  title="Figma to Code Tutorial"
  description="Step-by-step tutorial for turning a Figma component into framework-agnostic Atelier code with Claude, Storybook, and the MCP toolchain."
  currentPath="/tutorial"
>
  <div class="docs-inline-page">

    <div style="margin-bottom: 1.25rem">
      <div class="page-eyebrow">
        <span class="page-eyebrow-time">⏱ ~30 min</span>
        <span class="page-eyebrow-tag">Hands-on · Figma → Code</span>
      </div>
      <h1 style="font-size: 2rem; font-weight: 800; letter-spacing: -0.04em; line-height: 1.1; margin: 0 0 0.6rem; background: linear-gradient(135deg, var(--ui-color-primary) 0%, var(--docs-secondary, #89ceff) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text">
        Tutorial
      </h1>
      <p style="font-size: 0.9rem; color: var(--ui-color-text-muted); margin: 0; max-width: 520px; line-height: 1.65">
        Use <strong style="color: var(--ui-color-text)">figma-console <Jargon term="MCP">MCP</Jargon></strong> to read a Figma component spec directly — <Jargon term="design tokens">design tokens</Jargon> included — then <strong style="color: var(--ui-color-text)">Storybook MCP</strong> to match Atelier components, and let Claude Code write token-exact code.
      </p>
    </div>

    <!-- Learning objectives & assumed knowledge -->
    <div class="objective-box">
      <div class="objective-col">
        <h2 class="objective-heading objective-heading--accent">What you'll learn</h2>
        <ul class="objective-list">
          <li>Read a Figma component's <code>boundVariables</code> via MCP</li>
          <li>Match the right Atelier component through the Storybook MCP</li>
          <li>Generate token-exact code in Angular, React or Vue</li>
          <li>Verify design parity automatically</li>
        </ul>
      </div>
      <div class="objective-col">
        <h2 class="objective-heading">Before you start</h2>
        <ul class="objective-list objective-list--muted">
          <li>Completed the <a href="/workshop" style="color: var(--ui-color-primary)">Workshop setup</a></li>
          <li><code>figma-console</code> MCP configured — see <a href="/figma-token" style="color: var(--ui-color-primary)">Figma Setup</a></li>
          <li>Read access to the Atelier Figma file (linked below)</li>
          <li>One framework picked — Angular, React or Vue</li>
        </ul>
      </div>
    </div>

    <!-- Why this is different -->
    <div style="padding: 1rem 1.25rem; background: var(--ui-color-primary-light); border: 1px solid color-mix(in srgb, var(--ui-color-primary) 20%, transparent); border-radius: var(--ui-radius-md); margin-bottom: 2.5rem">
      <p style="margin: 0 0 0.35rem; font-size: 0.82rem; font-weight: 700; color: var(--ui-color-text)">No manual token copying</p>
      <p style="margin: 0; font-size: 0.82rem; color: var(--ui-color-text-muted); line-height: 1.6">
        The basic workshop workflow requires you to note token names from Figma's inspect panel. With the figma-console MCP, AI reads the component's <Jargon term="boundVariables"><code>boundVariables</code></Jargon> directly — every spacing, color, and radius value is already mapped to its CSS custom property name.
      </p>
    </div>

    <!-- What's an MCP? — mental model before specifics -->
    <div class="docs-section">
      <h2 class="docs-section-title">What's an <Jargon term="MCP">MCP</Jargon>, in 30 seconds?</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1.25rem; font-size: 0.85rem">
        Claude Code can call functions exposed by an external <strong style="color: var(--ui-color-text)">MCP server</strong>.
        The server fetches structured data from a source (Figma, Storybook, Nx) and hands it back —
        no screenshots, no copy-paste, no prompt-stuffing. Each call is one of four hops:
      </p>

      <DiagramFigure caption="Each MCP call is a four-hop round trip. The dashed return arrows carry the data Claude needs — boundVariables for figma-console, prop tables for storybook-*.">
        <svg viewBox="0 0 880 220" role="img" aria-labelledby="mcp-title mcp-desc" preserveAspectRatio="xMidYMid meet">
          <title id="mcp-title">MCP request and response flow</title>
          <desc id="mcp-desc">Four boxes left to right: User, Claude Code, MCP Server, Source. Solid arrows show the forward request flow (prompt, tool call, fetch). Dashed arrows show the return response flow (data, response, answer). Claude Code is highlighted as the active agent making the tool decision.</desc>

          <defs>
            <marker id="mcp-arr" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto">
              <path d="M 0 0 L 10 5 L 0 10 z" class="diagram-arrow--accent"/>
            </marker>
            <marker id="mcp-arr-back" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto">
              <path d="M 0 0 L 10 5 L 0 10 z" class="diagram-arrow--muted-accent"/>
            </marker>
          </defs>

          <!-- Nodes -->
          <rect x="40"  y="60" width="160" height="80" rx="12" ry="12" class="diagram-node"/>
          <text x="120" y="96"  text-anchor="middle" font-size="14" font-weight="700">User</text>
          <text x="120" y="118" text-anchor="middle" font-size="11" class="diagram-muted">"build this card"</text>

          <rect x="240" y="60" width="180" height="80" rx="12" ry="12" class="diagram-node diagram-node--accent"/>
          <text x="330" y="96"  text-anchor="middle" font-size="14" font-weight="700" style="fill: var(--ui-color-primary)">Claude Code</text>
          <text x="330" y="118" text-anchor="middle" font-size="11" class="diagram-muted">decides which tool to call</text>

          <rect x="460" y="60" width="180" height="80" rx="12" ry="12" class="diagram-node"/>
          <text x="550" y="96"  text-anchor="middle" font-size="14" font-weight="700">MCP Server</text>
          <text x="550" y="118" text-anchor="middle" font-size="11" class="diagram-mono diagram-muted">figma-console · storybook-*</text>

          <rect x="680" y="60" width="160" height="80" rx="12" ry="12" class="diagram-node"/>
          <text x="760" y="96"  text-anchor="middle" font-size="14" font-weight="700">Source</text>
          <text x="760" y="118" text-anchor="middle" font-size="11" class="diagram-muted">Figma · Storybook</text>

          <!-- Forward request arrows (top) -->
          <line x1="200" y1="88"  x2="240" y2="88"  class="diagram-connector diagram-connector--accent" marker-end="url(#mcp-arr)"/>
          <line x1="420" y1="88"  x2="460" y2="88"  class="diagram-connector diagram-connector--accent" marker-end="url(#mcp-arr)"/>
          <line x1="640" y1="88"  x2="680" y2="88"  class="diagram-connector diagram-connector--accent" marker-end="url(#mcp-arr)"/>

          <!-- Backward response arrows (bottom, dashed) -->
          <line x1="680" y1="116" x2="640" y2="116" class="diagram-connector diagram-connector--dashed" marker-end="url(#mcp-arr-back)"/>
          <line x1="460" y1="116" x2="420" y2="116" class="diagram-connector diagram-connector--dashed" marker-end="url(#mcp-arr-back)"/>
          <line x1="240" y1="116" x2="200" y2="116" class="diagram-connector diagram-connector--dashed" marker-end="url(#mcp-arr-back)"/>

          <!-- Connector labels -->
          <text x="220" y="78"  text-anchor="middle" font-size="10" class="diagram-eyebrow">prompt</text>
          <text x="440" y="78"  text-anchor="middle" font-size="10" class="diagram-eyebrow">tool call</text>
          <text x="660" y="78"  text-anchor="middle" font-size="10" class="diagram-eyebrow">fetch</text>

          <text x="220" y="138" text-anchor="middle" font-size="10" class="diagram-eyebrow diagram-muted">answer</text>
          <text x="440" y="138" text-anchor="middle" font-size="10" class="diagram-eyebrow diagram-muted">response</text>
          <text x="660" y="138" text-anchor="middle" font-size="10" class="diagram-eyebrow diagram-muted">data</text>

          <!-- Footer banner -->
          <text x="440" y="190" text-anchor="middle" font-size="11" class="diagram-muted">No screenshots · no copy-paste · structured data only</text>
        </svg>
      </DiagramFigure>

      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-top: 1rem; font-size: 0.82rem">
        This tutorial uses two MCP servers: <code>figma-console</code> (reads Figma component frames) and one of the <code>storybook-*</code> servers (returns Atelier component prop documentation). The next section walks the figma-console tools you'll use.
      </p>
    </div>

    <!-- What figma-console MCP provides -->
    <div class="docs-section">
      <h2 class="docs-section-title">What figma-console MCP provides</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1.25rem; font-size: 0.85rem">
        The key tool is <code>figma_get_component_for_development</code>. Given a node ID it returns:
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.75rem; margin-bottom: 1.25rem">
        {[
          { title: 'boundVariables', body: 'Each CSS property mapped to its Figma variable name — identical to the CSS custom property name in Atelier. No conversion needed.' },
          { title: '2× rendered image', body: 'A screenshot of the component, included automatically. AI gets visual and structural context in a single call.' },
          { title: 'Component tree', body: 'Full layout structure: padding, gap, constraints, text behaviour, and interaction states (reactions).' },
        ].map(({ title, body }) => (
          <div style="padding: 0.9rem 1rem; background: var(--ui-color-surface-raised); border-radius: var(--ui-radius-md); border: 1px solid var(--ui-color-border)">
            <div style="font-family: monospace; font-size: 0.78rem; font-weight: 700; color: var(--ui-color-primary); margin-bottom: 0.35rem">{title}</div>
            <div style="font-size: 0.78rem; color: var(--ui-color-text-muted); line-height: 1.6">{body}</div>
          </div>
        ))}
      </div>
      <Code code={BOUND_VARS_EXAMPLE} lang="js" title="figma_get_component_for_development — response shape" />
    </div>

    <!-- The workflow -->
    <div class="docs-section">
      <h2 class="docs-section-title">The Workflow</h2>

      <DiagramFigure caption="Each step passes concrete data to the next. The dashed arrow closes the loop when parity checks surface discrepancies.">
        <svg viewBox="0 0 960 260" role="img" aria-labelledby="tut-title tut-desc" preserveAspectRatio="xMidYMid meet">
          <title id="tut-title">Figma-to-code sequence diagram</title>
          <desc id="tut-desc">Five steps from selecting a frame in Figma to verifying design parity. Data flows from left to right: node ID, boundVariables, prop spec, generated code, parity score. A dashed loop returns discrepancies to the first step.</desc>

          <defs>
            <marker id="tut-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path d="M 0 0 L 10 5 L 0 10 z" class="diagram-arrow"/>
            </marker>
            <marker id="tut-arrow-loop" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
              <path d="M 0 0 L 10 5 L 0 10 z" class="diagram-arrow--muted-accent"/>
            </marker>
          </defs>

          <!-- Connector line under the step circles -->
          <line x1="96"  y1="100" x2="200" y2="100" class="diagram-connector" marker-end="url(#tut-arrow)"/>
          <line x1="264" y1="100" x2="368" y2="100" class="diagram-connector" marker-end="url(#tut-arrow)"/>
          <line x1="432" y1="100" x2="536" y2="100" class="diagram-connector" marker-end="url(#tut-arrow)"/>
          <line x1="600" y1="100" x2="704" y2="100" class="diagram-connector" marker-end="url(#tut-arrow)"/>
          <line x1="768" y1="100" x2="864" y2="100" class="diagram-connector" marker-end="url(#tut-arrow)"/>

          <!-- Data labels on connectors -->
          <text x="152" y="88" class="diagram-eyebrow" text-anchor="middle">node ID</text>
          <text x="316" y="88" class="diagram-eyebrow" text-anchor="middle">boundVariables</text>
          <text x="484" y="88" class="diagram-eyebrow" text-anchor="middle">prop spec</text>
          <text x="652" y="88" class="diagram-eyebrow" text-anchor="middle">code</text>
          <text x="816" y="88" class="diagram-eyebrow" text-anchor="middle">parity</text>

          <!-- Loop-back: parity discrepancies fold back to step A -->
          <path d="M 864 115 C 864 180 864 210 800 210 L 160 210 C 96 210 96 180 96 115"
                class="diagram-connector diagram-connector--dashed"
                marker-end="url(#tut-arrow-loop)"/>
          <text x="480" y="240" class="diagram-eyebrow" text-anchor="middle">discrepancies · iterate</text>

          <!-- Step circles with badges -->
          <!-- A -->
          <g>
            <circle cx="64" cy="100" r="30" class="diagram-node"/>
            <text x="64" y="107" text-anchor="middle" font-size="18" font-weight="700" style="fill: var(--ui-color-primary)">A</text>
            <text x="64" y="158" text-anchor="middle" font-size="12" font-weight="700">Select</text>
            <text x="64" y="176" text-anchor="middle" font-size="10" class="diagram-muted">Figma frame</text>
          </g>
          <!-- B -->
          <g>
            <circle cx="232" cy="100" r="30" class="diagram-node"/>
            <text x="232" y="107" text-anchor="middle" font-size="18" font-weight="700" style="fill: var(--ui-color-primary)">B</text>
            <text x="232" y="158" text-anchor="middle" font-size="12" font-weight="700">Read spec</text>
            <text x="232" y="176" text-anchor="middle" font-size="10" class="diagram-mono diagram-muted">figma_get_component</text>
          </g>
          <!-- C -->
          <g>
            <circle cx="400" cy="100" r="30" class="diagram-node"/>
            <text x="400" y="107" text-anchor="middle" font-size="18" font-weight="700" style="fill: var(--ui-color-primary)">C</text>
            <text x="400" y="158" text-anchor="middle" font-size="12" font-weight="700">Match props</text>
            <text x="400" y="176" text-anchor="middle" font-size="10" class="diagram-mono diagram-muted">storybook-* MCP</text>
          </g>
          <!-- D (accent — AI step) -->
          <g>
            <circle cx="568" cy="100" r="32" class="diagram-node diagram-node--accent"/>
            <text x="568" y="107" text-anchor="middle" font-size="18" font-weight="700" style="fill: var(--ui-color-primary)">D</text>
            <text x="568" y="158" text-anchor="middle" font-size="12" font-weight="700">Generate</text>
            <text x="568" y="176" text-anchor="middle" font-size="10" class="diagram-muted">Claude writes code</text>
          </g>
          <!-- E -->
          <g>
            <circle cx="736" cy="100" r="30" class="diagram-node"/>
            <text x="736" y="107" text-anchor="middle" font-size="18" font-weight="700" style="fill: var(--ui-color-primary)">E</text>
            <text x="736" y="158" text-anchor="middle" font-size="12" font-weight="700">Verify</text>
            <text x="736" y="176" text-anchor="middle" font-size="10" class="diagram-mono diagram-muted">check_design_parity</text>
          </g>
          <!-- Output chip -->
          <g>
            <rect x="870" y="82" width="82" height="36" rx="8" ry="8" class="diagram-node"/>
            <text x="911" y="104" text-anchor="middle" font-size="10" font-weight="700" style="fill: var(--ui-color-success)">✓ shipped</text>
            <text x="911" y="118" text-anchor="middle" font-size="9" class="diagram-muted">component</text>
          </g>
        </svg>
      </DiagramFigure>

      <div style="display: flex; flex-direction: column; gap: 1.5rem">

        <div class="step-row">
          <span class="step-badge">A</span>
          <div style="flex: 1">
            <h3 class="step-title">Select the component in Figma</h3>
            <p class="step-desc">Open the <a href="https://www.figma.com/design/QMnDD8uZQPldPrlCwZZ58T/LLM%20Components" target="_blank" rel="noopener noreferrer" style="color: var(--ui-color-primary)">Atelier Figma file</a> and click the frame you want to implement. The <Jargon term="node ID">node ID</Jargon> appears in the URL after <code>?node-id=</code> — copy that value, you’ll pass it to the MCP tool.</p>

            <DiagramFigure caption="The node ID is the value after ?node-id= in the Figma URL. Colons (:) appear URL-encoded as %3A or as a single dash.">
              <svg viewBox="0 0 880 160" role="img" aria-labelledby="url-title url-desc" preserveAspectRatio="xMidYMid meet">
                <title id="url-title">Figma URL with the node-id parameter highlighted</title>
                <desc id="url-desc">Screenshot mockup of a browser URL bar showing a Figma design URL. The node-id=695-313 parameter at the end is highlighted in cyan with a caption arrow pointing to it.</desc>

                <defs>
                  <marker id="url-arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                    <path d="M 0 0 L 10 5 L 0 10 z" class="diagram-arrow--accent"/>
                  </marker>
                </defs>

                <!-- URL bar pill -->
                <rect x="40" y="36" width="800" height="44" rx="22" ry="22" class="diagram-node"/>

                <!-- Lock icon -->
                <g transform="translate(62, 50)">
                  <rect x="0" y="6" width="14" height="12" rx="2" ry="2" class="diagram-icon"/>
                  <path d="M 3 6 V 3 A 4 4 0 0 1 11 3 V 6" class="diagram-icon"/>
                </g>

                <!-- URL text (broken into parts so we can highlight one segment) -->
                <text x="96" y="64" font-size="13" class="diagram-mono diagram-muted">figma.com/design/QMnDD8uZQPldPrlCwZZ58T/LLM-Components</text>

                <!-- Highlight box around the node-id parameter -->
                <rect x="592" y="44" width="208" height="28" rx="6" ry="6"
                      style="fill: color-mix(in srgb, var(--ui-color-primary) 18%, transparent); stroke: var(--ui-color-primary); stroke-width: 1.5;"/>
                <text x="600" y="64" font-size="13" font-weight="700" class="diagram-mono" style="fill: var(--ui-color-primary)">?node-id=695-313</text>

                <!-- Arrow and caption pointing to the node-id -->
                <path d="M 696 110 L 696 76" class="diagram-connector diagram-connector--accent" marker-end="url(#url-arrow)"/>
                <text x="696" y="132" text-anchor="middle" font-size="11" font-weight="600" style="fill: var(--ui-color-primary)">this is the node ID</text>
                <text x="696" y="146" text-anchor="middle" font-size="10" class="diagram-muted">pass it to figma_get_component_for_development</text>
              </svg>
            </DiagramFigure>
          </div>
        </div>

        <div class="step-row">
          <span class="step-badge">B</span>
          <div style="flex: 1">
            <h3 class="step-title">AI reads the spec</h3>
            <p class="step-desc">Claude Code calls <code>figma_get_component_for_development(nodeId)</code>. The response includes <code>boundVariables</code> listing every design token used in the frame, plus a rendered image for visual reference — no screenshots needed.</p>
          </div>
        </div>

        <div class="step-row">
          <span class="step-badge">C</span>
          <div style="flex: 1">
            <h3 class="step-title">AI matches to Atelier components</h3>
            <p class="step-desc">Claude Code queries the Storybook MCP (<code>list-all-documentation</code> → <code>get-documentation</code>) for the matching component. It gets exact prop names and variants — no guessing.</p>
          </div>
        </div>

        <div class="step-row">
          <span class="step-badge">D</span>
          <div style="flex: 1">
            <h3 class="step-title">AI generates token-exact code</h3>
            <p class="step-desc">With the Figma token names from <code>boundVariables</code> and the correct Atelier props from Storybook, the generated code uses the right component APIs and the exact CSS custom properties — no hardcoded values, no style overrides.</p>
          </div>
        </div>

        <div class="step-row">
          <span class="step-badge">E</span>
          <div style="flex: 1">
            <h3 class="step-title">Verify design parity (optional)</h3>
            <p class="step-desc"><code>figma_check_design_parity</code> compares the generated code against the Figma spec and returns a parity score plus specific discrepancies. Pass the prompt below to close the loop.</p>
            <Code code={PARITY_PROMPT} lang="text" title="parity check prompt" />
          </div>
        </div>

      </div>
    </div>

    <!-- Example prompt -->
    <div class="docs-section">
      <h2 class="docs-section-title">Example Prompt</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1rem; font-size: 0.85rem">
        A prompt that drives the full A–D workflow in one shot:
      </p>
      <Code code={EXAMPLE_PROMPT} lang="text" title="example prompt" />
    </div>

    <!-- Generated output -->
    <div class="docs-section">
      <h2 class="docs-section-title">Generated Output</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1.25rem; font-size: 0.85rem">
        What Claude Code produces — using <code>LlmCard</code> and <code>LlmInput</code> from Atelier with tokens drawn directly from Figma <code>boundVariables</code>:
      </p>
      <div class="docs-multi-code-tabs" style="border-radius: 8px 8px 0 0; margin-bottom: 0; width: fit-content">
        {FRAMEWORKS.map((fw, i) => (
          <button class={`docs-multi-code-tab${i === 0 ? ' active' : ''}`} data-fw-btn={fw}>{fw}</button>
        ))}
      </div>
      {FRAMEWORKS.map((fw, i) => (
        <div data-fw-panel={fw} hidden={i !== 0}>
          <Code code={OUTPUT[fw]} lang={fw === 'Angular' ? 'ts' : 'tsx'} />
        </div>
      ))}
    </div>

    <!-- Run it -->
    <div class="docs-section">
      <h2 class="docs-section-title">Run it</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1.25rem; font-size: 0.85rem">
        Save the generated component, start your dev server, and verify against the Figma frame.
        The framework tabs above stay in sync with this section.
      </p>
      {FRAMEWORKS.map((fw, i) => (
        <div data-fw-panel={fw} hidden={i !== 0}>
          <ol class="run-steps">
            <li>
              <span class="run-step-label">Save as</span>
              <code class="run-step-path">{RUN_IT[fw].path}</code>
            </li>
            <li>
              <span class="run-step-label">Start the dev server</span>
              <Code code={RUN_IT[fw].cmd} lang="shell" />
            </li>
            <li>
              <span class="run-step-label">Open</span>
              <a href={`http://localhost:${RUN_IT[fw].port}`} target="_blank" rel="noopener noreferrer" class="run-step-link">
                http://localhost:{RUN_IT[fw].port}
              </a>
              <span class="run-step-detail">{RUN_IT[fw].expected}</span>
            </li>
            <li>
              <span class="run-step-label">Verify parity</span>
              <span class="run-step-detail">Run the parity prompt above — Claude will list any discrepancies and propose fixes.</span>
            </li>
          </ol>
        </div>
      ))}
    </div>

    <!-- Tool reference -->
    <div class="docs-section">
      <h2 class="docs-section-title">figma-console MCP — Tools Used</h2>
      <table class="docs-props-table">
        <thead>
          <tr><th>Tool</th><th>When to use</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><code>figma_get_component_for_development</code></td>
            <td>Main tool — reads component tree, boundVariables, and renders a 2× image. Use for any "build this component" task.</td>
          </tr>
          <tr>
            <td><code>figma_get_component_for_development_deep</code></td>
            <td>For complex, deeply nested components (depth &gt; 4) — resolves all boundVariables to actual token names.</td>
          </tr>
          <tr>
            <td><code>figma_get_variables</code></td>
            <td>Export all design tokens as CSS / Tailwind / TypeScript. Handles Light and Dark mode values.</td>
          </tr>
          <tr>
            <td><code>figma_check_design_parity</code></td>
            <td>Compare generated code against the Figma spec. Returns a parity score and actionable fix list.</td>
          </tr>
          <tr>
            <td><code>figma_generate_component_doc</code></td>
            <td>Generate structured component documentation (anatomy, tokens, variants) by merging Figma data with code-side info.</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Bottom nav -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.85rem; margin-top: 2.5rem">
      {([
        { to: '/figma',     label: 'Design',  title: 'Figma File', icon: 'palette' },
        { to: '/workshop',  label: 'Setup',   title: 'Workshop',   icon: 'build_circle' },
        { to: '/storybook', label: 'Explore', title: 'Storybook',  icon: 'book' },
      ] as const).map(({ to, label, title, icon }) => (
        <a href={to} class="bottom-nav-card">
          <span class="bottom-nav-icon"><Icon name={icon} /></span>
          <div>
            <div class="bottom-nav-label">{label}</div>
            <div class="bottom-nav-title">{title}</div>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

