---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Code } from 'astro-expressive-code/components';
import Jargon from '../components/Jargon.astro';
import Icon from '../components/Icon.astro';
import HelpFooter from '../components/HelpFooter.astro';

const SITE_URL = 'https://atelier.pieper.io';

const SERVE_CMD = {
  Angular: 'npx nx serve workshop-angular',
  React: 'npx nx serve workshop-react',
  Vue: 'npx nx serve workshop-vue',
};

const PREREQ_CMD = {
  macOS: `# 1. Node 22+ (use Homebrew or nvm)\nnode --version   # need v22.12 or newer\n\n# 2. Claude Code CLI\nnpm install -g @anthropic-ai/claude-code\nclaude --version\n\n# 3. Figma access token (or use the demo token)\nexport FIGMA_ACCESS_TOKEN=figd_...`,
  Linux: `# 1. Node 22+ (nvm recommended)\nnode --version   # need v22.12 or newer\n\n# 2. Claude Code CLI\nnpm install -g @anthropic-ai/claude-code\nclaude --version\n\n# 3. Figma access token (or use the demo token)\nexport FIGMA_ACCESS_TOKEN=figd_...`,
  Windows: `# Run in PowerShell (or use WSL for the macOS/Linux steps)\n\n# 1. Node 22+ (winget or nvm-windows)\nnode --version   # need v22.12 or newer\n\n# 2. Claude Code CLI\nnpm install -g @anthropic-ai/claude-code\nclaude --version\n\n# 3. Figma access token\n$env:FIGMA_ACCESS_TOKEN = "figd_..."`,
};

const MCP_CONFIG = `{
  "mcpServers": {
    "nx-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["nx", "mcp"]
    },
    "storybook-angular": {
      "type": "http",
      "url": "${SITE_URL}/storybook-angular/mcp"
    },
    "storybook-react": {
      "type": "http",
      "url": "${SITE_URL}/storybook-react/mcp"
    },
    "storybook-vue": {
      "type": "http",
      "url": "${SITE_URL}/storybook-vue/mcp"
    },
    "figma-console": {
      "command": "npx",
      "args": ["-y", "figma-console-mcp@latest"],
      "env": {
        "FIGMA_ACCESS_TOKEN": "\${FIGMA_ACCESS_TOKEN}",
        "ENABLE_MCP_APPS": "true"
      }
    }
  }
}`;
---

<BaseLayout
  title="Workshop Setup"
  description="Set up the Atelier workshop end-to-end — clone the monorepo, install dependencies, run Storybook, and connect the AI tooling."
  currentPath="/workshop"
>
  <div class="docs-inline-page">

    <div style="margin-bottom: 1.25rem">
      <div class="page-eyebrow">
        <span class="page-eyebrow-kind page-eyebrow-kind--tutorial">Tutorial</span>
        <span class="page-eyebrow-time">⏱ ~25 min</span>
        <span class="page-eyebrow-tag">Hands-on · Setup</span>
      </div>
      <h1 style="font-size: 2rem; font-weight: 800; letter-spacing: -0.04em; line-height: 1.1; margin: 0 0 0.6rem; background: linear-gradient(135deg, var(--ui-color-primary) 0%, var(--docs-secondary, #89ceff) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text">
        Workshop Setup
      </h1>
      <p style="font-size: 0.9rem; color: var(--ui-color-text-muted); margin: 0; max-width: 520px; line-height: 1.65">
        Spin up a fully-configured Atelier workspace in one command — framework selection,
        library install, and <Jargon term="MCP">MCP</Jargon> server wired up automatically.
      </p>
    </div>

    <!-- Learning objectives & assumed knowledge -->
    <div class="objective-box">
      <div class="objective-col">
        <h2 class="objective-heading objective-heading--accent">What you'll learn</h2>
        <ul class="objective-list">
          <li>Scaffold an Atelier workspace with one command</li>
          <li>Verify your environment with <code>preflight</code></li>
          <li>Connect Claude Code to the Storybook MCP servers</li>
          <li>Run the Figma → token → component loop end-to-end</li>
        </ul>
      </div>
      <div class="objective-col">
        <h2 class="objective-heading">Before you start</h2>
        <ul class="objective-list objective-list--muted">
          <li>Frontend experience in Angular, React or Vue</li>
          <li>Comfortable with the terminal — Node 22+ available</li>
          <li>Claude Code CLI (we walk you through installing it)</li>
          <li>Figma account — optional, demo flow works without one</li>
        </ul>
      </div>
    </div>

    <!-- Shortcut for users arriving from a repo clone -->
    <aside class="docs-shortcut" aria-label="Shortcut for users with a local clone of the repo">
      <div class="docs-shortcut-eyebrow">Already cloned the repo?</div>
      <p class="docs-shortcut-desc">
        You can skip <strong>Install prerequisites</strong>, <strong>Step 01</strong>
        (workspace generator), and <strong>Step 02</strong> (preflight) — they're for
        a fresh-scaffolded workspace. Jump straight to picking a framework and serving.
      </p>
      <a href="#step-03" class="docs-shortcut-link">Skip to Step 03 — Serve your app →</a>
    </aside>

    <!-- Prerequisites -->
    <div class="docs-section" style="margin-bottom: 2rem; padding: 1.25rem 1.4rem; background: var(--ui-color-surface-raised); border: 1px solid var(--ui-color-border); border-radius: var(--ui-radius-md)">
      <div style="display: flex; justify-content: space-between; align-items: baseline; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.85rem">
        <h2 class="docs-section-title" style="margin: 0; font-size: 1rem">Install prerequisites</h2>
        <a href="/troubleshooting" style="font-size: 0.78rem; color: var(--ui-color-primary); text-decoration: none">Troubleshooting →</a>
      </div>
      <p style="margin: 0 0 0.85rem; color: var(--ui-color-text-muted); font-size: 0.85rem; line-height: 1.55">
        Pick your platform, run the commands below, then verify with <code>npm run preflight</code>
        inside the scaffolded workspace. Connecting Figma? See <a href="/figma-token" class="docs-link-primary">Figma Setup</a>
        — it walks through the Desktop Bridge plugin and the optional REST token.
      </p>
      <div class="docs-multi-code-tabs" style="border-radius: 8px 8px 0 0; margin-bottom: 0">
        {Object.keys(PREREQ_CMD).map((platform, i) => (
          <button class={`docs-multi-code-tab${i === 0 ? ' active' : ''}`} data-plat-btn={platform}>{platform}</button>
        ))}
      </div>
      {Object.entries(PREREQ_CMD).map(([platform, cmd], i) => (
        <div data-plat-panel={platform} hidden={i !== 0}>
          <Code code={cmd} lang="shell" />
        </div>
      ))}
    </div>

    <div style="display: flex; flex-direction: column; gap: 1.75rem; margin-bottom: 2.5rem">

      <!-- Step 01 -->
      <div class="step-row" data-step="1">
        <span class="step-badge">01</span>
        <div>
          <h3 class="step-title">Run the workspace generator</h3>
          <p class="step-desc">Run the following command, then follow the prompts to choose your workspace name and frameworks:</p>
          <Code code="npx create-atelier-ui-workspace" lang="shell" />
          <Code code={`? Workspace name: › my-workshop\n? Which framework(s) do you want to use?\n  ◉ Angular\n  ◉ React\n  ◉ Vue`} lang="text" />
          <p class="step-desc" style="margin-top: 0.75rem">Or pass the name directly to skip the first prompt:</p>
          <Code code="npx create-atelier-ui-workspace my-workshop" lang="shell" />
        </div>
      </div>

      <!-- Step 02 -->
      <div class="step-row" data-step="2">
        <span class="step-badge">02</span>
        <div>
          <h3 class="step-title">Install dependencies &amp; run preflight</h3>
          <p class="step-desc">Navigate into your workspace, install deps, and verify your environment:</p>
          <Code code={`cd my-workshop\nnpm install\nnpm run preflight`} lang="shell" />
          <p class="step-desc" style="margin-top: 0.75rem">
            <code>preflight</code> checks Node, Claude Code CLI, the Figma token, MCP reachability,
            and port availability. If anything fails, each line prints a one-step fix.
          </p>

          <div class="docs-multi-code-tabs" style="border-radius: 8px 8px 0 0; margin: 0.85rem 0 0">
            <button class="docs-multi-code-tab active" data-pre-btn="success" type="button">Successful run</button>
            <button class="docs-multi-code-tab" data-pre-btn="failed" type="button">Failed run</button>
          </div>

          <figure class="preflight-mock" data-pre-panel="success">
            <figcaption class="preflight-mock-title">
              <span class="preflight-mock-dot preflight-mock-dot--r"></span>
              <span class="preflight-mock-dot preflight-mock-dot--y"></span>
              <span class="preflight-mock-dot preflight-mock-dot--g"></span>
              <span class="preflight-mock-label">preflight — successful run</span>
            </figcaption>
            <pre class="preflight-mock-body">
<span class="pre-prompt">➜</span> <span class="pre-cmd">npm run preflight</span>

<span class="pre-muted">[preflight] Checking your environment…</span>

  <span class="pre-ok">✓</span> Node <span class="pre-val">v22.12.0</span>
  <span class="pre-ok">✓</span> npm <span class="pre-val">v10.2.4</span>
  <span class="pre-ok">✓</span> git <span class="pre-val">v2.43.0</span>
  <span class="pre-ok">✓</span> Claude Code CLI <span class="pre-val">v0.15.3</span>
  <span class="pre-ok">✓</span> FIGMA_ACCESS_TOKEN <span class="pre-muted">(figd_AbCd…)</span>
  <span class="pre-ok">✓</span> MCP · storybook-angular reachable
  <span class="pre-ok">✓</span> MCP · storybook-react reachable
  <span class="pre-ok">✓</span> MCP · storybook-vue reachable
  <span class="pre-ok">✓</span> MCP · nx-mcp reachable
  <span class="pre-ok">✓</span> Port 4200 available
  <span class="pre-ok">✓</span> Port 4201 available
  <span class="pre-ok">✓</span> Port 4202 available
  <span class="pre-ok">✓</span> Port 6006 available

<span class="pre-ok-strong">All checks passed. You are good to go.</span></pre>
          </figure>

          <figure class="preflight-mock" data-pre-panel="failed" hidden>
            <figcaption class="preflight-mock-title">
              <span class="preflight-mock-dot preflight-mock-dot--r"></span>
              <span class="preflight-mock-dot preflight-mock-dot--y"></span>
              <span class="preflight-mock-dot preflight-mock-dot--g"></span>
              <span class="preflight-mock-label">preflight — failed run with fix hints</span>
            </figcaption>
            <pre class="preflight-mock-body">
<span class="pre-prompt">➜</span> <span class="pre-cmd">npm run preflight</span>

<span class="pre-muted">[preflight] Checking your environment…</span>

  <span class="pre-ok">✓</span> Node <span class="pre-val">v22.12.0</span>
  <span class="pre-ok">✓</span> npm <span class="pre-val">v10.2.4</span>
  <span class="pre-ok">✓</span> git <span class="pre-val">v2.43.0</span>
  <span class="pre-fail">✗</span> Claude Code CLI <span class="pre-fail">not found</span>
    <span class="pre-fix">→ fix:</span> <span class="pre-cmd">npm install -g @anthropic-ai/claude-code</span>
  <span class="pre-ok">✓</span> FIGMA_ACCESS_TOKEN <span class="pre-muted">(figd_AbCd…)</span>
  <span class="pre-ok">✓</span> MCP · storybook-angular reachable
  <span class="pre-fail">✗</span> MCP · storybook-react <span class="pre-fail">unreachable (504)</span>
    <span class="pre-fix">→ fix:</span> check internet · or set <span class="pre-cmd">STORYBOOK_REACT_MCP=http://localhost:6006/mcp</span>
  <span class="pre-ok">✓</span> MCP · storybook-vue reachable
  <span class="pre-ok">✓</span> MCP · nx-mcp reachable
  <span class="pre-fail">✗</span> Port 4200 <span class="pre-fail">in use (pid 4711 — vite dev)</span>
    <span class="pre-fix">→ fix:</span> <span class="pre-cmd">kill 4711</span> · or set <span class="pre-cmd">PORT=4250</span> in <span class="pre-cmd">.env</span>
  <span class="pre-ok">✓</span> Port 4201 available
  <span class="pre-ok">✓</span> Port 4202 available
  <span class="pre-ok">✓</span> Port 6006 available

<span class="pre-issue">3 issues found</span> <span class="pre-muted">· re-run after fixing each line</span>
<span class="pre-muted">  See</span> <a href="/troubleshooting" class="pre-link">/troubleshooting</a> <span class="pre-muted">for context.</span></pre>
          </figure>
          <p class="step-desc" style="margin-top: 0.6rem; font-size: 0.76rem">
            Toggle the tabs above to compare. Each <span style="color: var(--ui-color-danger); font-weight: 700">✗</span> line ends with a one-step fix — copy, run, re-run <code>preflight</code>.
          </p>
        </div>
      </div>

      <!-- Step 03 -->
      <div class="step-row" data-step="3" id="step-03">
        <span class="step-badge">03</span>
        <div>
          <h3 class="step-title">Serve your app</h3>
          <p class="step-desc">Start the dev server for your chosen framework:</p>
          <div class="docs-multi-code-tabs" style="border-radius: 8px 8px 0 0; margin-bottom: 0">
            {Object.keys(SERVE_CMD).map((fw, i) => (
              <button class={`docs-multi-code-tab${i === 0 ? ' active' : ''}`} data-fw-btn={fw}>{fw}</button>
            ))}
          </div>
          {Object.entries(SERVE_CMD).map(([fw, cmd], i) => (
            <div data-fw-panel={fw} hidden={i !== 0}>
              <Code code={cmd} lang="shell" />
            </div>
          ))}
        </div>
      </div>

      <!-- Step 04 -->
      <div class="step-row" data-step="4">
        <span class="step-badge">04</span>
        <div>
          <h3 class="step-title">Open in Claude Code</h3>
          <p class="step-desc">
            Open the workspace in VS Code or any editor with Claude Code. The MCP servers
            connect automatically — your AI assistant can look up component props, variants,
            and usage examples directly from Storybook without any extra setup.
          </p>
          <div style="padding: 1rem 1.25rem; background: var(--ui-color-primary-light); border: 1px solid var(--ui-color-border); border-radius: var(--ui-radius-md)">
            <p style="margin: 0 0 0.35rem; font-size: 0.82rem; font-weight: 700; color: var(--ui-color-text)">MCP auto-configuration</p>
            <p style="margin: 0; font-size: 0.82rem; color: var(--ui-color-text-muted); line-height: 1.6">
              The generated <code>.claude/settings.json</code> wires up the Nx MCP and hosted
              Storybook MCP servers for all selected frameworks automatically.
            </p>
          </div>
        </div>
      </div>

    </div>

    <!-- The Workflow — what you do once everything is running -->
    <div class="docs-section" style="margin-top: 2.5rem">
      <h2 class="docs-section-title">The Workflow — once you are set up</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1.75rem">
        With the workspace running and MCP servers live, this is the loop you will use for every
        component: read the design in Figma, reference tokens in your prompt, let Claude match
        components against Storybook, ship.
      </p>
      <div style="display: flex; flex-direction: column; gap: 1.75rem">

        <div class="step-row" data-step="5">
          <span class="step-badge">A</span>
          <div>
            <h3 class="step-title">Open Figma — find your component frame</h3>
            <p class="step-desc">
              The <a href="https://www.figma.com/design/QMnDD8uZQPldPrlCwZZ58T/LLM%20Components" target="_blank" rel="noopener noreferrer" class="docs-link-primary">Atelier Figma file</a> contains all component frames and design token variables. Find the section for the component you want to build and note the token names in the inspect panel.
            </p>
          </div>
        </div>

        <div class="step-row" data-step="6">
          <span class="step-badge">B</span>
          <div>
            <h3 class="step-title">Reference design tokens in your prompt</h3>
            <p class="step-desc">Include token names from Figma directly. AI will use the identical names in code:</p>
            <Code code={`Build a settings card using LlmCard with variant="elevated".\nMatch the Figma spec: --ui-color-surface-raised background,\n--ui-spacing-6 padding, --ui-radius-lg border-radius.\nUse storybook-react MCP to check LlmCard props.`} lang="text" title="example prompt" />
          </div>
        </div>

        <div class="step-row" data-step="7">
          <span class="step-badge">C</span>
          <div>
            <h3 class="step-title">AI checks Storybook, writes component code</h3>
            <p class="step-desc">
              Claude Code reads the Storybook MCP for accurate prop names and usage examples, then generates code using the exact token values from Figma. The output is immediately usable — no prop guessing, no style overrides.
            </p>
          </div>
        </div>

        <div class="step-row" data-step="8">
          <span class="step-badge">D</span>
          <div>
            <h3 class="step-title">Ship — the component matches the design</h3>
            <p class="step-desc">
              Because Figma variables and CSS custom properties share the same token names, there is no gap between what the designer specified and what ships. Light and dark mode work automatically.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- What gets created -->
    <div class="docs-section" style="margin-top: 2.5rem">
      <h2 class="docs-section-title">What gets created</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1.25rem">
        Based on your framework selection the preset scaffolds one app per framework,
        installs the matching Atelier package, and pre-configures Claude Code's MCP servers.
      </p>
      <!-- Desktop / tablet: dense 4-column table -->
      <table class="docs-props-table docs-props-table--md-up" style="margin-bottom: 1.5rem">
        <thead>
          <tr><th>Framework</th><th>App</th><th>Package</th><th>MCP</th></tr>
        </thead>
        <tbody>
          <tr><td>Angular</td><td><code>workshop-angular</code></td><td><code>@atelier-ui/angular</code></td><td><code>storybook-angular</code></td></tr>
          <tr><td>React</td><td><code>workshop-react</code></td><td><code>@atelier-ui/react</code></td><td><code>storybook-react</code></td></tr>
          <tr><td>Vue</td><td><code>workshop-vue</code></td><td><code>@atelier-ui/vue</code></td><td><code>storybook-vue</code></td></tr>
        </tbody>
      </table>

      <!-- Mobile (≤640px): one card per framework, key/value rows.
           CSS hides whichever doesn't match the breakpoint, so screen
           readers only ever see one copy of the data. -->
      <div class="docs-fw-cards" style="margin-bottom: 1.5rem">
        {([
          { name: 'Angular', app: 'workshop-angular', pkg: '@atelier-ui/angular', mcp: 'storybook-angular' },
          { name: 'React',   app: 'workshop-react',   pkg: '@atelier-ui/react',   mcp: 'storybook-react' },
          { name: 'Vue',     app: 'workshop-vue',     pkg: '@atelier-ui/vue',     mcp: 'storybook-vue' },
        ] as const).map(({ name, app, pkg, mcp }) => (
          <div class="docs-fw-card">
            <div class="docs-fw-card-name">{name}</div>
            <dl class="docs-fw-card-list">
              <div class="docs-fw-card-row">
                <dt>App</dt><dd><code>{app}</code></dd>
              </div>
              <div class="docs-fw-card-row">
                <dt>Package</dt><dd><code>{pkg}</code></dd>
              </div>
              <div class="docs-fw-card-row">
                <dt>MCP</dt><dd><code>{mcp}</code></dd>
              </div>
            </dl>
          </div>
        ))}
      </div>
    </div>

    <!-- MCP configuration -->
    <div class="docs-section">
      <h2 class="docs-section-title">MCP configuration</h2>
      <p style="color: var(--ui-color-text-muted); line-height: 1.6; margin-bottom: 1.25rem">
        The generated <code>.claude/settings.json</code> wires up the Nx MCP, the hosted
        Storybook MCP servers for each selected framework, and <code>figma-console</code>
        — needed for the <a href="/tutorial" class="docs-link-primary">Figma-to-Code Tutorial</a>:
      </p>
      <Code code={MCP_CONFIG} lang="json" />
      <p style="margin: 0.75rem 0 0; font-size: 0.78rem; color: var(--ui-color-text-muted); line-height: 1.55">
        <code>figma-console</code> requires the Desktop Bridge plugin and a personal access
        token — see <a href="/figma-token" class="docs-link-primary">Figma Setup</a>.
        If you only want the Storybook MCP workflow, you can remove the <code>figma-console</code> entry.
      </p>
    </div>

    <HelpFooter page="workshop" />

    <!-- Bottom nav -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.85rem; margin-top: 2.5rem">
      {([
        { to: '/storybook', label: 'Next',   title: 'Storybook',    icon: 'book' },
        { to: '/figma',     label: 'Design', title: 'Figma File',   icon: 'palette' },
        { to: '/mcp',       label: 'Tools',  title: 'MCP Explorer', icon: 'cable' },
      ] as const).map(({ to, label, title, icon }) => (
        <a href={to} class="bottom-nav-card">
          <span class="bottom-nav-icon"><Icon name={icon} /></span>
          <div>
            <div class="bottom-nav-label">{label}</div>
            <div class="bottom-nav-title">{title}</div>
          </div>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
  .step-badge {
    font-family: monospace;
    font-size: 0.62rem;
    font-weight: 700;
    color: var(--ui-color-primary);
    background: rgba(68, 218, 218, 0.1);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    margin-top: 3px;
  }

  .step-row {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
  }

  /* Matches the .docs-h3 baseline (1rem · 700 · -0.01em) so step titles
   * sit visibly between body text and the section title. */
  .step-title {
    margin: 0 0 0.4rem;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--ui-color-text);
  }

  .step-desc {
    margin: 0 0 0.75rem;
    font-size: 0.82rem;
    color: var(--ui-color-text-muted);
    line-height: 1.6;
  }

  /* Remove bottom margin on last step-desc before a Code block */
  .step-desc:last-child {
    margin-bottom: 0;
  }

  /* Preflight mockup — styled like a terminal card.
   * Colors come from the --docs-term-* tokens in global.css so
   * this card stays in sync with .docs-terminal across themes.
   */
  .preflight-mock {
    margin: 0.85rem 0 0;
    background: var(--docs-term-bg);
    border: 1px solid var(--docs-term-border);
    border-radius: var(--ui-radius-md);
    overflow: hidden;
    font-family: var(--font-mono), ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .preflight-mock-title {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 0.85rem;
    background: var(--docs-term-bar-bg);
    color: var(--docs-term-heading);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .preflight-mock-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }
  .preflight-mock-dot--r { background: #ff5f56; }
  .preflight-mock-dot--y { background: #ffbd2e; }
  .preflight-mock-dot--g { background: #27c93f; }
  .preflight-mock-label {
    margin-left: 0.5rem;
  }
  .preflight-mock-body {
    margin: 0;
    padding: 0.85rem 1rem 1rem;
    font-size: 0.78rem;
    line-height: 1.6;
    color: var(--docs-term-text);
    white-space: pre-wrap;
  }
  .preflight-mock-body .pre-prompt { color: var(--docs-term-accent-strong); font-weight: 700; }
  .preflight-mock-body .pre-cmd { color: var(--docs-term-strong); }
  .preflight-mock-body .pre-muted { color: var(--docs-term-muted); }
  .preflight-mock-body .pre-ok { color: var(--docs-term-success); font-weight: 700; }
  .preflight-mock-body .pre-ok-strong { color: var(--docs-term-success); font-weight: 700; }
  .preflight-mock-body .pre-val { color: var(--docs-term-info); }
  .preflight-mock-body .pre-fail { color: var(--ui-color-danger); font-weight: 700; }
  .preflight-mock-body .pre-fix { color: var(--docs-term-accent-strong); font-weight: 700; }
  .preflight-mock-body .pre-issue { color: var(--ui-color-danger); font-weight: 700; }
  .preflight-mock-body .pre-link { color: var(--ui-color-primary); text-decoration: underline; }

  /* Stack the failed mockup directly under the tabs (no extra top margin
   * — the tabs already provide the visual seam). */
  .docs-multi-code-tabs + .preflight-mock { margin-top: 0; border-top-left-radius: 0; border-top-right-radius: 0; }
  .preflight-mock + .preflight-mock { margin-top: 0; }
</style>

<script>
  // Framework tabs handled by shared framework-pref-init script in BaseLayout.
  // This script handles platform (macOS/Linux/Windows) tabs and the
  // preflight success/failed mockup tabs.
  function initWorkshopPlatformTabs() {
    const platButtons = document.querySelectorAll<HTMLButtonElement>('[data-plat-btn]');
    const platPanels = document.querySelectorAll<HTMLElement>('[data-plat-panel]');
    platButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const plat = btn.dataset.platBtn;
        platButtons.forEach(b => b.classList.toggle('active', b === btn));
        platPanels.forEach(p => { p.hidden = p.dataset.platPanel !== plat; });
      });
    });
  }
  function initWorkshopPreflightTabs() {
    const preButtons = document.querySelectorAll<HTMLButtonElement>('[data-pre-btn]');
    const prePanels = document.querySelectorAll<HTMLElement>('[data-pre-panel]');
    preButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const pre = btn.dataset.preBtn;
        preButtons.forEach(b => b.classList.toggle('active', b === btn));
        prePanels.forEach(p => { p.hidden = p.dataset.prePanel !== pre; });
      });
    });
  }
  document.addEventListener('astro:page-load', () => {
    initWorkshopPlatformTabs();
    initWorkshopPreflightTabs();
  });
  initWorkshopPlatformTabs();
  initWorkshopPreflightTabs();
</script>
