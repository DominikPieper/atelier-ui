{
  "name": "create-atelier-ui-workspace",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/create-atelier-ui-workspace/bin",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "outputPath": "dist/{projectRoot}",
        "main": "libs/create-atelier-ui-workspace/bin/index.ts",
        "tsConfig": "libs/create-atelier-ui-workspace/tsconfig.lib.json",
        "assets": ["libs/create-atelier-ui-workspace/*.md"]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/create-atelier-ui-workspace/jest.config.cts"
      }
    },
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node libs/create-atelier-ui-workspace/e2e/cli.e2e.mjs",
        "cwd": "{workspaceRoot}"
      },
      "dependsOn": ["^build", "build"]
    }
  },
  "implicitDependencies": ["create-workspace"]
}
