{
  "name": "create-workspace",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/create-workspace/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": ["type:plugin"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "outputPath": "dist/{projectRoot}",
        "main": "libs/create-workspace/src/index.ts",
        "tsConfig": "libs/create-workspace/tsconfig.lib.json",
        "assets": [
          "libs/create-workspace/*.md",
          {
            "input": "./libs/create-workspace/src",
            "glob": "**/!(*.ts)",
            "output": "./src"
          },
          {
            "input": "./libs/create-workspace/src",
            "glob": "**/*.d.ts",
            "output": "./src"
          },
          {
            "input": "./libs/create-workspace",
            "glob": "generators.json",
            "output": "."
          },
          {
            "input": "./libs/create-workspace",
            "glob": "executors.json",
            "output": "."
          },

        ]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/create-workspace/jest.config.cts"
      }
    }
  }
}
