{
  "name": "Atelier UI Workshop",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [4200, 4201, 4202, 6006],
  "portsAttributes": {
    "4200": { "label": "Angular dev server", "onAutoForward": "notify" },
    "4201": { "label": "React dev server", "onAutoForward": "notify" },
    "4202": { "label": "Vue dev server", "onAutoForward": "notify" },
    "6006": { "label": "Storybook", "onAutoForward": "notify" }
  },
  "remoteEnv": {
    "FIGMA_ACCESS_TOKEN": "${localEnv:FIGMA_ACCESS_TOKEN}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "astro-build.astro-vscode",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "Angular.ng-template"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  },
  "waitFor": "postCreateCommand"
}
