{
  "name": "llm-components-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/llm-components-angular/src",
  "prefix": "llm",
  "projectType": "library",
  "tags": ["framework:angular", "type:ui-lib"],
  "targets": {
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../coverage/llm-components-angular"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx storybook dev --config-dir libs/llm-components-angular/.storybook --port 4400"
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/storybook/llm-components-angular"],
      "options": {
        "command": "npx storybook build --config-dir libs/llm-components-angular/.storybook --output-dir dist/storybook/llm-components-angular"
      }
    }
  }
}
