{
  "name": "react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/react/src",
  "projectType": "library",
  "tags": [
    "framework:react",
    "type:ui-lib"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{workspaceRoot}/dist/libs/react"],
      "options": {
        "outputPath": "dist/libs/react",
        "main": "libs/react/src/index.ts",
        "tsConfig": "libs/react/tsconfig.lib.json",
        "assets": ["libs/react/*.md"]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/react"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx storybook dev --config-dir libs/react/.storybook --port 4401"
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/storybook/react"
      ],
      "options": {
        "command": "npx storybook build --config-dir libs/react/.storybook --output-dir dist/storybook/react"
      }
    }
  }
}
