{
  "name": "react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/react/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": ["framework:react", "type:ui-lib"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "dependsOn": ["^build"],
      "options": {
        "outputPath": "dist/{projectRoot}",
        "main": "libs/react/src/index.ts",
        "tsConfig": "libs/react/tsconfig.lib.json",
        "assets": [
          "libs/react/*.md",
          {
            "input": "libs/react/src",
            "glob": "lib/**/*.css",
            "output": "src"
          },
          {
            "input": "libs/react/src",
            "glob": "styles/tokens.css",
            "output": "."
          }
        ]
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    },
    "test": {
      "outputs": [
        "{projectRoot}/{options.coverage.reportsDirectory}",
        "{workspaceRoot}/coverage/react"
      ],
      "options": {
        "coverage.reportsDirectory": "../../../coverage/react"
      }
    },
    "lint": {
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/.eslintrc.json",
        "{workspaceRoot}/.eslintignore",
        "{workspaceRoot}/eslint.config.mjs",
        "{workspaceRoot}/tools/eslint-rules/**/*",
        {
          "externalDependencies": ["eslint"]
        }
      ]
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx storybook dev --config-dir libs/react/.storybook --port 4401"
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/storybook/react"],
      "options": {
        "command": "npx storybook build --config-dir libs/react/.storybook --output-dir dist/storybook/react"
      }
    },
    "storybook-test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run --config vitest.storybook.config.ts",
        "cwd": "libs/react"
      }
    }
  }
}
