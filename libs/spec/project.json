{
  "name": "spec",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/spec/src",
  "projectType": "library",
  "tags": ["type:spec"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{workspaceRoot}/dist/libs/spec"],
      "options": {
        "outputPath": "dist/libs/spec",
        "main": "libs/spec/src/index.ts",
        "tsConfig": "libs/spec/tsconfig.lib.json"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/libs/spec"
      }
    }
  }
}
