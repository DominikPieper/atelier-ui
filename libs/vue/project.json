{
  "name": "vue",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/vue/src",
  "projectType": "library",
  "tags": [
    "framework:vue",
    "type:ui-lib"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/libs/vue"],
      "options": {
        "command": "vite build --config libs/vue/vite.config.mts",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{options.reportsDirectory}"
      ],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/vue"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx storybook dev --config-dir libs/vue/.storybook --port 4402"
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/storybook/vue"
      ],
      "options": {
        "command": "npx storybook build --config-dir libs/vue/.storybook --output-dir dist/storybook/vue"
      }
    }
  }
}
