<script setup lang="ts">
import { computed } from 'vue';
import './llm-<%= fileName %>.css';

defineOptions({ name: '<%= className %>' });

interface <%= className %>Props {
  /** Visual variant. */
  variant?: 'default';
}

const props = withDefaults(defineProps<<%= className %>Props>(), {
  variant: 'default',
});

const classes = computed(() => [
  'llm-<%= fileName %>',
  `variant-${props.variant}`,
]);
</script>

<template>
  <div :class="classes">
    <slot />
  </div>
</template>
