{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LlmComponentVue",
  "description": "Scaffold a Vue LLM-optimized component",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The component name (kebab-case, e.g. date-picker)",
      "$default": {
        "$source": "argv",
        "index": 0
      }
    },
    "directory": {
      "type": "string",
      "description": "Subdirectory under libs/vue/src/lib (defaults to name)"
    }
  },
  "required": ["name"]
}
