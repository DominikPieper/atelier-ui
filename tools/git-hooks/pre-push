#!/bin/sh
#
# pre-push hook — regenerate derived artifacts and abort the push if drift
# would be introduced. Prevents the recurring CI failure where the release
# bot bumps a version between local pushes (rebase pulls in chore(release):
# publish 0.0.X), leaving the llms.txt files or spec copies stale until
# someone notices the failed CI run on a follow-up push.
#
# Install once after clone:
#   bash tools/scripts/install-hooks.sh
#
# To bypass for one push (NOT recommended): git push --no-verify
#

set -e

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

# Staleness self-check — install-hooks.sh copies this file into .git/hooks, so
# an installed copy silently goes stale when the source hook changes. Compare
# the executing hook ($0) against the source and refuse to run if they differ.
# Skipped when the source file does not exist (e.g. shallow tooling checkouts).
SOURCE_HOOK="$ROOT/tools/git-hooks/pre-push"
if [ -f "$SOURCE_HOOK" ]; then
  if ! cmp -s "$0" "$SOURCE_HOOK"; then
    echo ""
    echo "✗ pre-push aborted: installed hook is stale"
    echo ""
    echo "  This hook ($0) differs from the source at"
    echo "  tools/git-hooks/pre-push. Reinstall it:"
    echo ""
    echo "    bash tools/scripts/install-hooks.sh"
    echo ""
    exit 1
  fi
fi

# Regenerate quietly. All scripts are idempotent.
# sync:generated = spec mirror + behaviors.generated + llms.txt + skill discovery.
npm run --silent sync:generated > /dev/null 2>&1 || true

drift=$(git diff --name-only -- \
  libs/angular/src/lib/spec.ts \
  libs/react/src/lib/spec.ts \
  libs/vue/src/lib/spec.ts \
  libs/spec/src/behaviors.generated.ts \
  docs/public/llms.txt \
  docs/public/llms-full.txt \
  'docs/public/.well-known/agent-skills/**' 2>/dev/null)

if [ -n "$drift" ]; then
  echo ""
  echo "✗ pre-push aborted: generated files drifted after regeneration"
  echo ""
  echo "  Files out of sync:"
  echo "$drift" | sed 's/^/    - /'
  echo ""
  echo "  This usually means a chore(release) commit was rebased in but the"
  echo "  generated artifacts were not regenerated. Fix:"
  echo ""
  echo "    git add libs/*/src/lib/spec.ts docs/public/llms.txt docs/public/llms-full.txt \\"
  echo "          'docs/public/.well-known/agent-skills/**'"
  echo "    git commit --amend --no-edit"
  echo "    git push"
  echo ""
  echo "  (Or: git push --no-verify to bypass — only for true emergencies.)"
  echo ""
  exit 1
fi

# Run the full drift suite (structural + story, spec, tokens, variants,
# behavior coverage, docs, llms, cookbook). Catches drift locally instead of
# on a failed CI run after the push has already landed.
if ! checkout=$(npm run --silent check:all 2>&1); then
  echo ""
  echo "✗ pre-push aborted: drift check failed"
  echo ""
  printf '%s\n' "$checkout" | sed 's/^/    /'
  echo ""
  echo "  Fix the reported drift, or: git push --no-verify to bypass."
  echo ""
  exit 1
fi
