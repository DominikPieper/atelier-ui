{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "atelier-ui",
  "main": "worker/index.ts",
  "compatibility_date": "2026-04-30",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/docs",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": [
      "/storybook-react/mcp",
      "/storybook-angular/mcp",
      "/storybook-vue/mcp"
    ]
  },
  "observability": {
    "enabled": true
  }
}
